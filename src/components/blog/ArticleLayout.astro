---
import { getStrings, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  summary: string;
  publishedDate: Date;
  coverImage?: string | null;
  readingMinutes: number;
}

const { lang, title, summary, publishedDate, coverImage, readingMinutes } = Astro.props;
const s = getStrings(lang);
const dateLabel = new Intl.DateTimeFormat(lang === 'sv' ? 'sv-SE' : 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(publishedDate);
---

<section class="article">
  <div class="article-inner">
    <a class="article-back reveal" href="/blog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      {s.blogBackToBlog}
    </a>

    <header class="article-head reveal">
      <h1 class="article-title">{title}</h1>
      <p class="article-summary">{summary}</p>
      <div class="article-meta">
        <time datetime={publishedDate.toISOString()}>{dateLabel}</time>
        <span class="dot" aria-hidden="true"></span>
        <span>{readingMinutes} {s.blogReadingTimeSuffix}</span>
      </div>
    </header>

    {coverImage && (
      <div class="article-cover reveal">
        <img src={coverImage} alt="" decoding="async" />
      </div>
    )}

    <div class="prose reveal">
      <slot />
    </div>
  </div>
</section>

<style>
  .article {
    background:
      radial-gradient(120% 60% at 50% 0%,
        color-mix(in srgb, var(--brand-primary) 4%, transparent), transparent 62%),
      var(--bg-paper);
    padding-top: calc(var(--section-py) + 36px);
  }
  .article-inner {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--slate-500);
    margin-bottom: 36px;
    transition: color .2s ease, gap .2s ease;
  }
  .article-back svg { width: 16px; height: 16px; }
  .article-back:hover { color: var(--brand-primary); gap: 11px; }

  .article-head { margin-bottom: 40px; }
  .article-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--brand-primary);
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .article-summary {
    font-size: 20px;
    line-height: 1.55;
    color: var(--slate-500);
    margin: 0 0 24px;
    text-wrap: pretty;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--slate-400);
  }
  .article-meta .dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--slate-300);
  }

  .article-cover {
    margin: 0 0 48px;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-soft);
  }
  /* Cover breaks out a little wider than the prose column for an editorial feel. */
  @media (min-width: 920px) {
    .article-cover { margin-inline: -80px; }
  }
  .article-cover img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 8;
    object-fit: cover;
  }

  /* ---------- Prose ---------- */
  .prose {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.75;
    color: var(--slate-600);
  }
  .prose :global(> * + *) { margin-top: 1.35em; }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 28px;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--brand-primary);
    margin-top: 1.9em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 21px;
    line-height: 1.3;
    color: var(--brand-primary);
    margin-top: 1.6em;
  }
  .prose :global(p) { margin: 0; }
  .prose :global(a) {
    color: var(--brand-primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--brand-primary) 35%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color .2s ease;
  }
  .prose :global(a:hover) { text-decoration-color: var(--brand-primary); }
  .prose :global(strong) { color: var(--brand-primary); font-weight: 600; }
  .prose :global(ul), .prose :global(ol) { margin: 0; padding-left: 1.3em; }
  .prose :global(li) { margin-top: 0.5em; }
  .prose :global(li)::marker { color: var(--brand-primary); }
  .prose :global(blockquote) {
    margin: 1.6em 0;
    padding: 4px 0 4px 24px;
    border-left: 3px solid var(--brand-primary);
    color: var(--slate-600);
    font-size: 20px;
    font-style: italic;
    line-height: 1.6;
  }
  .prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }
  .prose :global(hr) {
    border: 0;
    height: 1px;
    background: var(--border);
    margin: 2.4em 0;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.4em;
  }
  .prose :global(pre) {
    background: var(--brand-primary-dark);
    color: var(--slate-100);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    overflow-x: auto;
    font-size: 14.5px;
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: none;
    border: 0;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  @media (max-width: 768px) {
    .article { padding-top: calc(var(--section-py) + 12px); }
    .prose { font-size: 17px; }
    .prose :global(h2) { font-size: 24px; }
    .prose :global(h3) { font-size: 19px; }
  }
</style>

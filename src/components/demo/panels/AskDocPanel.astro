---
import { getStrings, type Lang } from '../../../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- "Fråga om dokument" — a focused chat (sidebar collapsed by the controller).
     The tour drags the source document into the input, then asks about it and the
     AI answers. Document cards drift on both sides over a soft cyan brand glow. -->
<div class="demo-panel" data-panel="ask">
  <div class="askdoc-stage">
    <span class="askdoc-glow" aria-hidden="true"></span>

    <div class="askdoc-carousel" aria-hidden="true">
      <span class="askdoc-doc-card c1"></span>
      <span class="askdoc-doc-card c2"></span>
      <span class="askdoc-doc-card c3"></span>
      <span class="askdoc-doc-card c4"></span>
      <span class="askdoc-doc-card c5"></span>
      <span class="askdoc-doc-card c6"></span>
    </div>

    <div class="askdoc-card" data-askdoc data-q={s.heroAskQuestion} data-a={s.heroAskAnswer}>
      <div class="askdoc-intro">
        <span class="askdoc-orb" aria-hidden="true"></span>
        <h3 class="askdoc-title">{s.heroAskTitle}</h3>
        <p class="askdoc-subtitle">{s.heroAskSubtitle}</p>
      </div>

      <div class="askdoc-thread" data-askdoc-thread aria-hidden="true"></div>

      <!-- Hidden message templates — cloned by the script so scoped styles apply. -->
      <div class="askdoc-tpl" hidden>
        <div class="askdoc-q" data-tpl="q"><span class="qtext"></span></div>
        <div class="askdoc-ai" data-tpl="ai">
          <span class="askdoc-ai-orb"></span>
          <div class="askdoc-bubble"><span class="askdoc-answer"></span><span class="askdoc-dots"><i></i><i></i><i></i></span></div>
        </div>
      </div>

      <div class="askdoc-input" data-askdoc-input>
        <div class="askdoc-drop" data-askdoc-drop>
          <span class="askdoc-drop-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.9A7 7 0 1 1 15.7 8h1.8a4.5 4.5 0 0 1 2.5 8.2"/><path d="M12 12v9M8 17l4-4 4 4"/></svg></span>
          <span class="askdoc-drop-text">{s.heroAskSubtitle}</span>
        </div>
        <div class="askdoc-chip" data-askdoc-chip aria-hidden="true">
          <span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>
          <span class="askdoc-chip-name">{s.heroAskDocName}</span>
        </div>
        <div class="askdoc-input-body">
          <span class="askdoc-typed" data-askdoc-typed></span>
          <span class="askdoc-caret" data-askdoc-caret aria-hidden="true"></span>
          <span class="askdoc-ph" data-askdoc-ph>{s.heroChatPlaceholder}</span>
        </div>
        <div class="askdoc-input-foot">
          <button class="askdoc-send" type="button" tabindex="-1" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- The source document the cursor grabs and drags into the input. -->
    <div class="askdoc-source" data-askdoc-source aria-hidden="true">
      <span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>
      <span class="askdoc-source-name">{s.heroAskDocName}</span>
    </div>
  </div>
</div>

<style>
.askdoc-stage {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
/* Soft cyan brand glow behind the focus card. */
.askdoc-glow {
  position: absolute;
  width: 120%; height: 80%;
  border-radius: 50%;
  background: radial-gradient(closest-side, rgba(86,179,235,.16), rgba(86,179,235,0) 70%);
  filter: blur(8px);
  pointer-events: none;
}
/* Side carousel — faded document/window cards drifting in the margins. */
.askdoc-carousel {
  position: absolute;
  inset: -6% -4%;
  pointer-events: none;
  -webkit-mask: radial-gradient(78% 86% at 50% 50%, transparent 34%, #000 62%, transparent 98%);
          mask: radial-gradient(78% 86% at 50% 50%, transparent 34%, #000 62%, transparent 98%);
}
.askdoc-doc-card {
  position: absolute;
  width: 168px; height: 124px;
  border-radius: 14px;
  /* A small Lucra-orb badge sits in the top-right corner (GitBook-style). */
  background:
    url(/assets/orb-avatar.png) right 12px top 12px / 22px no-repeat,
    var(--bg-paper);
  border: 1px solid var(--border);
  box-shadow: 0 24px 60px -28px rgba(61,80,109,.32);
  opacity: .5;
  will-change: transform;
}
/* A document header row + a small Lucra-orb badge in the corner. */
.askdoc-doc-card::before {
  content: ""; position: absolute; left: 12px; top: 12px; width: 30px; height: 7px;
  border-radius: 4px; background: var(--slate-200);
  box-shadow: 40px 0 0 -1px var(--slate-100), 72px 0 0 -1px var(--slate-100);
}
.askdoc-doc-card::after {
  content: ""; position: absolute; left: 12px; right: 40px; top: 34px; height: 58px;
  border-radius: 8px;
  background:
    linear-gradient(var(--slate-100) 0 0) left 0 top 0 / 100% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 18px / 70% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 36px / 86% 8px no-repeat;
}
.askdoc-doc-card.c1 { left: 2%;  top: 14%; width: 150px; animation: driftA 26s ease-in-out infinite; }
.askdoc-doc-card.c2 { left: 9%;  top: 56%; width: 124px; opacity: .42; animation: driftC 31s ease-in-out infinite -5s; }
.askdoc-doc-card.c3 { left: 16%; top: 84%; width: 132px; opacity: .36; animation: driftB 28s ease-in-out infinite -3s; }
.askdoc-doc-card.c4 { right: 2%; top: 12%; width: 168px; animation: driftB 24s ease-in-out infinite -2s; }
.askdoc-doc-card.c5 { right: 10%; top: 58%; width: 126px; opacity: .42; animation: driftA 29s ease-in-out infinite -7s; }
.askdoc-doc-card.c6 { right: 17%; top: 86%; width: 134px; opacity: .36; animation: driftC 27s ease-in-out infinite -4s; }

/* Centred focus card. */
.askdoc-card {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 560px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 30px 30px 24px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: 0 30px 70px -34px rgba(61,80,109,.4), 0 2px 6px -3px rgba(61,80,109,.12);
}
.askdoc-intro {
  display: flex; flex-direction: column; align-items: center;
  transition: opacity .4s ease, transform .45s var(--ease-out-expo), max-height .5s ease;
  max-height: 220px; overflow: hidden;
}
.askdoc-card.is-asked .askdoc-intro { opacity: 0; transform: translateY(-8px); max-height: 0; }
.askdoc-orb {
  width: 72px; height: 72px;
  background: url(/assets/orb-avatar.png) center / contain no-repeat;
  filter: drop-shadow(0 8px 22px rgba(86,179,235,.45));
}
.askdoc-title {
  margin: 16px 0 6px;
  font-family: var(--font-display);
  font-size: 22px; font-weight: 700;
  letter-spacing: -.01em;
  color: var(--brand-primary);
}
.askdoc-subtitle { margin: 0 0 20px; font-size: 14px; color: var(--slate-500); max-width: 360px; }

/* Answer thread. */
.askdoc-thread { display: none; width: 100%; flex-direction: column; gap: 14px; margin-bottom: 18px; text-align: left; }
.askdoc-card.is-asked .askdoc-thread { display: flex; }
.askdoc-q {
  align-self: flex-end;
  max-width: 80%;
  padding: 11px 16px;
  background: var(--brand-primary);
  color: #fff;
  font-size: 14px; line-height: 1.45;
  border-radius: 18px 18px 4px 18px;
  animation: askMsgIn .4s cubic-bezier(.2,.7,.2,1) both;
}
.askdoc-ai {
  display: flex; gap: 12px; align-items: flex-start;
  max-width: 94%;
  animation: askMsgIn .4s cubic-bezier(.2,.7,.2,1) both .1s;
}
.askdoc-ai-orb { position: relative; width: 28px; height: 28px; flex-shrink: 0; }
.askdoc-ai-orb::before { content: ""; position: absolute; inset: 0; background: url(/assets/orb-avatar.png) center / contain no-repeat; }
.askdoc-bubble {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-left: 3px solid #5B7A9B;
  padding: 12px 16px;
  border-radius: 0 16px 16px 16px;
  font-size: 14px; color: var(--slate-600); line-height: 1.55;
  box-shadow: var(--shadow-sm);
}
.askdoc-bubble :global(ul) { margin: 8px 0 0; padding-left: 18px; }
.askdoc-bubble :global(li) { margin: 4px 0; }
.askdoc-dots { display: none; gap: 4px; align-items: center; height: 16px; }
.askdoc-dots.show { display: inline-flex; }
.askdoc-dots i { width: 5px; height: 5px; border-radius: 50%; background: #5B7A9B; animation: askDot 1.6s infinite both cubic-bezier(.4,0,.2,1); }
.askdoc-dots i:nth-child(2) { animation-delay: .2s; }
.askdoc-dots i:nth-child(3) { animation-delay: .4s; }
@keyframes askDot { 0%,80%,100% { opacity: .25; transform: translateY(0); } 40% { opacity: 1; transform: translateY(-2.5px); } }
@keyframes askMsgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

/* Input with drop target + attached-file chip. */
.askdoc-input {
  position: relative;
  width: 100%;
  min-height: 132px;
  padding: 16px 18px;
  background: var(--bg-app);
  border: 1px solid var(--border);
  border-radius: 20px;
  text-align: left;
  transition: border-color .2s ease, background .2s ease, box-shadow .2s ease;
}
/* Drop hint — dashed zone shown until a document lands. */
.askdoc-drop {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 14px;
  border: 1.5px dashed var(--slate-300);
  border-radius: 14px;
  color: var(--slate-400);
  font-size: 13px;
  transition: border-color .2s ease, background .2s ease, color .2s ease;
}
.askdoc-drop-ic svg { width: 18px; height: 18px; }
.askdoc-input.is-armed { border-color: var(--brand-accent); box-shadow: 0 0 0 3px rgba(86,179,235,.16); }
.askdoc-input.is-armed .askdoc-drop { border-color: var(--brand-accent); background: rgba(86,179,235,.08); color: var(--brand-primary); }
.askdoc-input.has-doc .askdoc-drop { display: none; }
/* Attached file chip. */
.askdoc-chip { display: none; align-items: center; gap: 10px; padding: 8px 12px; background: var(--bg-paper); border: 1px solid var(--border); border-radius: 12px; }
.askdoc-input.has-doc .askdoc-chip { display: inline-flex; animation: askChipIn .4s var(--ease-out-expo) both; }
@keyframes askChipIn { from { opacity: 0; transform: translateY(-6px) scale(.96); } to { opacity: 1; transform: none; } }
.askdoc-chip .fileic {
  width: 30px; height: 30px; flex-shrink: 0;
  border-radius: var(--radius-md);
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--bg-active); color: var(--brand-primary);
}
.askdoc-chip .fileic svg { width: 16px; height: 16px; }
.askdoc-chip-name { font-size: 13px; font-weight: 500; color: var(--slate-600); }
/* Typed text + caret + placeholder. */
.askdoc-input-body { margin-top: 12px; min-height: 22px; font-size: 14px; color: var(--slate-600); line-height: 1.5; }
.askdoc-typed { white-space: pre-wrap; }
.askdoc-caret { display: none; width: 1.5px; height: 16px; margin-left: 1px; vertical-align: -3px; background: var(--brand-primary); animation: askCaret 1s step-end infinite; }
.askdoc-input.is-typing .askdoc-caret { display: inline-block; }
@keyframes askCaret { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
.askdoc-ph { color: var(--slate-400); }
.askdoc-input.is-typing .askdoc-ph,
.askdoc-input.has-text .askdoc-ph { display: none; }
.askdoc-input-foot { display: flex; justify-content: flex-end; margin-top: 12px; }
.askdoc-send {
  width: 34px; height: 34px;
  display: inline-flex; align-items: center; justify-content: center;
  border: 0; border-radius: 50%;
  background: var(--brand-primary); color: #fff;
}
.askdoc-send svg { width: 16px; height: 16px; }

/* The source document chip the cursor picks up. */
.askdoc-source {
  position: absolute;
  left: 7%; bottom: 12%;
  z-index: 3;
  display: inline-flex; align-items: center; gap: 10px;
  padding: 10px 14px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: 0 14px 30px -14px rgba(61,80,109,.4);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity .4s ease, transform .4s var(--ease-out-expo);
}
.askdoc-stage.show-source .askdoc-source { opacity: 1; transform: none; }
.askdoc-stage.grabbed .askdoc-source { opacity: 0; transform: scale(.9); }
.askdoc-source .fileic {
  width: 32px; height: 32px; flex-shrink: 0;
  border-radius: var(--radius-md);
  display: inline-flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, var(--slate-50), var(--bg-app));
  color: var(--slate-500);
}
.askdoc-source .fileic svg { width: 17px; height: 17px; }
.askdoc-source-name { font-size: 13px; font-weight: 500; color: var(--slate-600); }

/* Float keyframes (scoped copies — keyframe names don't cross component styles). */
@keyframes driftA { 0%, 100% { transform: translateY(0) rotate(-3deg); } 50% { transform: translateY(-22px) rotate(-1.5deg); } }
@keyframes driftB { 0%, 100% { transform: translateY(0) rotate(3deg); } 50% { transform: translateY(-16px) rotate(4.5deg); } }
@keyframes driftC { 0%, 100% { transform: translate(0, 0) rotate(-2deg); } 50% { transform: translate(8px, -26px) rotate(-3.5deg); } }

@media (prefers-reduced-motion: reduce) {
  .askdoc-doc-card { animation: none; }
  .askdoc-intro, .askdoc-source, .askdoc-input { transition: none; }
}
</style>

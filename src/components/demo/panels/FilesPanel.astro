---
import { getStrings, type Lang } from '../../../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Panel: Files -->
<div class="demo-panel files-panel" data-panel="docs">
  <div class="files-head">
    <h2 class="files-title">{s.heroDemoFilesTitle}</h2>
    <p class="files-sub">{s.heroDemoFilesSubtitle}</p>
  </div>
  <div class="files-tabs" role="tablist">
    <button class="files-tab is-active" data-ftab="uploaded" type="button" tabindex="-1">{s.heroDemoFilesTabUploaded}</button>
    <button class="files-tab" data-ftab="generated" type="button" tabindex="-1">{s.heroDemoFilesTabGenerated}</button>
  </div>
  <div class="files-toolbar">
    <div class="files-stats">
      <span class="fs-label">{s.heroDemoFilesStatsLabel}</span>
      <span class="fs-count" data-files-count>(10)</span>
      <span class="fs-size" data-files-size>4.58 MB</span>
    </div>
    <div class="files-top-actions">
      <span class="files-btn-ghost"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>{s.heroDemoFilesFortnox}</span>
      <span class="files-btn-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.9A7 7 0 1 1 15.7 8h1.8a4.5 4.5 0 0 1 2.5 8.2"/><path d="M12 12v9M8 17l4-4 4 4"/></svg>{s.heroDemoFilesAdd}</span>
    </div>
  </div>
  <div class="files-table">
    <div class="files-row files-head-row">
      <span class="fcb"><span class="fcheck"></span></span>
      <span>{s.heroDemoFilesColName}</span>
      <span class="fsize-h">{s.heroDemoFilesColSize}</span>
      <span class="facts-h">{s.heroDemoFilesColActions}</span>
    </div>
    <div class="files-list" data-flist="uploaded">

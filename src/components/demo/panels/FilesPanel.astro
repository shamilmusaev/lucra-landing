<style>
/* ----- Files panel ----- */
.files-head { margin-bottom: 14px; }
.files-title {
  font-family: var(--font-display);
  font-weight: 700; font-size: 24px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  margin: 0 0 4px;
}
.files-sub { font-size: 13px; color: var(--slate-500); margin: 0; }
.files-tabs {
  display: flex; gap: 6px;
  border-bottom: 1px solid var(--slate-200);
  margin-bottom: 16px;
}
.files-tab {
  position: relative;
  background: none; border: 0;
  padding: 10px 14px;
  font-family: var(--font-body);
  font-size: 13px; font-weight: 600;
  color: var(--slate-500);
  cursor: default;
  transition: color .2s ease;
}
.files-tab::after {
  content: "";
  position: absolute; left: 0; right: 0; bottom: -1px;
  height: 3px; border-radius: 3px 3px 0 0;
  background: var(--brand-primary);
  opacity: 0; transition: opacity .2s ease;
}
.files-tab.is-active { color: var(--brand-primary); }
.files-tab.is-active::after { opacity: 1; }
.files-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; flex-wrap: wrap;
  margin-bottom: 14px;
}
.files-stats { display: flex; align-items: baseline; gap: 8px; }
.fs-label { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--brand-primary); }
.fs-count { font-size: 14px; color: var(--slate-500); }
.fs-size { font-size: 13px; color: var(--slate-400); }
.files-top-actions { display: flex; align-items: center; gap: 8px; }
.files-btn-ghost,
.files-btn-primary {
  display: inline-flex; align-items: center; gap: 7px;
  height: 36px; padding: 0 14px;
  border-radius: var(--radius-lg);
  font-size: 13px; font-weight: 600;
}
.files-btn-ghost svg,
.files-btn-primary svg { width: 15px; height: 15px; }
.files-btn-ghost {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  color: var(--brand-primary);
}
.files-btn-ghost svg { color: var(--success-strong); }
.files-btn-primary {
  background: var(--brand-primary);
  color: #fff;
  box-shadow: var(--shadow-sm);
}
.files-table {
  background: var(--bg-paper);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-2xl);
  overflow: hidden;
}
.files-row {
  display: grid;
  grid-template-columns: 40px 1fr 100px 64px;
  align-items: center;
  gap: 12px;
  padding: 12px 18px;
  border-bottom: 1px solid var(--slate-100);
  font-size: 14px;
}
.files-row:last-child { border-bottom: 0; }
.files-head-row {
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.05em;
  color: var(--slate-500);
  padding: 12px 18px;
}
.fcb { display: flex; align-items: center; }
.fcheck {
  width: 16px; height: 16px;
  border: 1.5px solid var(--slate-300);
  border-radius: 5px;
  display: block;
}
.fname {
  display: flex; align-items: center; gap: 16px;
  min-width: 0;
  font-weight: 500; color: var(--slate-600);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.fileic {
  width: 36px; height: 36px;
  flex-shrink: 0;
  border-radius: var(--radius-md);
  display: inline-flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, var(--slate-50), var(--bg-app));
  color: var(--slate-500);
  transition: background .2s ease, color .2s ease;
}
.fileic svg { width: 18px; height: 18px; }
.files-list .files-row:hover { background: var(--slate-50); }
.files-row:hover .fileic { background: var(--bg-active); color: var(--brand-primary); }
.fsize-h, .fsize { color: var(--slate-500); }
.fsize { font-weight: 500; }
.facts-h { text-align: right; }
.facts { display: flex; justify-content: flex-end; }
.fdl {
  width: 18px; height: 18px;
  color: var(--slate-400);
  opacity: 0;
  transition: opacity .2s ease;
}
.files-row:hover .fdl { opacity: 1; }
</style>

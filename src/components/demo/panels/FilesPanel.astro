---
import { getStrings, type Lang } from '../../../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Panel: Files -->
<div class="demo-panel files-panel" data-panel="docs">
  <div class="files-head">
    <h2 class="files-title">{s.heroDemoFilesTitle}</h2>
    <p class="files-sub">{s.heroDemoFilesSubtitle}</p>
  </div>
  <div class="files-tabs" role="tablist">
    <button class="files-tab is-active" data-ftab="company" type="button" tabindex="-1">{s.heroDemoFilesTabCompany}</button>
    <button class="files-tab" data-ftab="conversation" type="button" tabindex="-1">{s.heroDemoFilesTabConversation}</button>
  </div>
  <div class="files-toolbar">
    <div class="files-stats">
      <span class="fs-label">{s.heroDemoFilesStatsLabel}</span>
      <span class="fs-count" data-files-count>(10)</span>
      <span class="fs-size" data-files-size>4.58 MB</span>
    </div>
    <div class="files-top-actions">
      <button class="files-btn-ghost" type="button" tabindex="-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="16" y="16" width="6" height="6" rx="1"/><path d="M12 8v4M6 16v-1a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"/></svg>
        {s.heroDemoFilesConnectFortnox}
      </button>
      <button class="files-btn-primary" type="button" tabindex="-1" data-files-add data-label-add={s.heroDemoFilesAdd} data-label-cancel={s.heroDemoFilesCancel}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.9A7 7 0 1 1 15.7 8h1.8a4.5 4.5 0 0 1 2.5 8.2"/><path d="M12 12v9M8 17l4-4 4 4"/></svg>
        <span data-files-add-label>{s.heroDemoFilesAdd}</span>
      </button>
    </div>
  </div>

  <!-- Upload section — expands when "Add files" is pressed (matches the app). -->
  <div class="files-upload" data-files-upload data-uploading={s.heroDemoFilesUploading} data-done={s.heroDemoFilesUploadDone}>
    <div class="files-upload-inner">
      <div class="fu-dropzone" data-fu-dropzone>
        <span class="fu-dz-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.9A7 7 0 1 1 15.7 8h1.8a4.5 4.5 0 0 1 2.5 8.2"/><path d="M12 12v9M8 17l4-4 4 4"/></svg></span>
        <div class="fu-dz-text">
          <p class="fu-dz-title">{s.heroDemoFilesDropTitle}</p>
          <p class="fu-dz-sub">{s.heroDemoFilesDropSub}</p>
        </div>
      </div>
      <div class="fu-status">
        <span class="fu-spin"></span>
        <span class="fu-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
        <p class="fu-status-text" data-fu-status-text></p>
      </div>
    </div>
  </div>

  <div class="files-table">
    <div class="files-row files-head-row">
      <span class="fcb"><span class="fcheck"></span></span>
      <span>{s.heroDemoFilesColName}</span>
      <span class="fsize-h">{s.heroDemoFilesColSize}</span>
      <span class="facts-h">{s.heroDemoFilesColActions}</span>
    </div>
    <div class="files-list" data-flist="company">
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Annual_Report_2025.pdf</span><span class="fsize">2.46 MB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Bank_Statement_SEB_2026-Q1.pdf</span><span class="fsize">541.7 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Rent_Agreement_Stockholm_Office.pdf</span><span class="fsize">488.45 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Employment_Contract_Anna_Lindqvist.pdf</span><span class="fsize">312.32 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>VAT_Declaration_2026-Q1.pdf</span><span class="fsize">210.94 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Invoice_2026-04_Spotify_AB.pdf</span><span class="fsize">184.32 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Supplier_Invoice_AWS_2026-03.pdf</span><span class="fsize">145.41 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Receipt_Office_Supplies_March.pdf</span><span class="fsize">96.26 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Payroll_April_2026.xlsx</span><span class="fsize">72.7 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Receipt_Business_Lunch_Sturehof.pdf</span><span class="fsize">67.58 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
    </div>
    <div class="files-list" data-flist="conversation" hidden>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Cash_Flow_Forecast_2026.pdf</span><span class="fsize">414.72 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Revenue_Analysis_2025_vs_2026.pdf</span><span class="fsize">354.3 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Financial_Summary_2026-Q1.pdf</span><span class="fsize">319.49 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Profit_Loss_Statement_2025.pdf</span><span class="fsize">287.74 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Expense_Breakdown_April_2026.pdf</span><span class="fsize">197.63 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>VAT_Report_2026-Q1.pdf</span><span class="fsize">176.13 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
      <div class="files-row"><span class="fcb"><span class="fcheck"></span></span><span class="fname"><span class="fileic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span>Tax_Estimate_2026.pdf</span><span class="fsize">141.31 KB</span><span class="facts"><svg class="fdl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg></span></div>
    </div>
  </div>
</div>

<style>
/* ----- Files panel ----- */
.files-head { margin-bottom: 14px; }
.files-title {
  font-family: var(--font-display);
  font-weight: 700; font-size: 24px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  margin: 0 0 4px;
}
.files-sub { font-size: 13px; color: var(--slate-500); margin: 0; }
.files-tabs {
  display: flex; gap: 6px;
  border-bottom: 1px solid var(--slate-200);
  margin-bottom: 16px;
}
.files-tab {
  position: relative;
  background: none; border: 0;
  padding: 10px 14px;
  font-family: var(--font-body);
  font-size: 13px; font-weight: 600;
  color: var(--slate-500);
  cursor: default;
  transition: color .2s ease;
}
.files-tab::after {
  content: "";
  position: absolute; left: 0; right: 0; bottom: -1px;
  height: 3px; border-radius: 3px 3px 0 0;
  background: var(--brand-primary);
  opacity: 0; transition: opacity .2s ease;
}
.files-tab.is-active { color: var(--brand-primary); }
.files-tab.is-active::after { opacity: 1; }
.files-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; flex-wrap: wrap;
  margin-bottom: 14px;
}
.files-stats { display: flex; align-items: baseline; gap: 8px; }
.fs-label { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--brand-primary); }
.fs-count { font-size: 14px; color: var(--slate-500); }
.fs-size { font-size: 13px; color: var(--slate-400); }
.files-top-actions { display: flex; align-items: center; gap: 12px; }
.files-btn-ghost,
.files-btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  height: 40px; padding: 0 16px;
  border: 0; border-radius: var(--radius-md);
  font-family: var(--font-body);
  font-size: 14px; font-weight: 500;
  cursor: default;
}
.files-btn-ghost svg,
.files-btn-primary svg { width: 18px; height: 18px; flex-shrink: 0; }
/* Connect Fortnox — outlined, neutral (Fortnox not connected by default) */
.files-btn-ghost {
  background: var(--bg-paper);
  border: 1px solid var(--slate-200);
  color: var(--slate-500);
}
/* Add files — dark filled primary */
.files-btn-primary {
  background: var(--brand-primary);
  color: var(--white);
  box-shadow: var(--shadow-sm);
}
/* Upload section — collapsed until "Add files" expands it (matches the app). */
.files-upload {
  max-height: 0; opacity: 0; overflow: hidden;
  margin-bottom: 0;
  transition: max-height .35s ease, opacity .35s ease, margin-bottom .35s ease;
}
.files-upload.is-open { max-height: 320px; opacity: 1; margin-bottom: 16px; }
.files-upload-inner {
  background: var(--bg-paper);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-2xl);
  padding: 20px;
}
.fu-dropzone {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 14px;
  min-height: 140px;
  padding: 24px;
  border: 1.5px dashed var(--slate-200);
  border-radius: var(--radius-xl);
  background: var(--slate-50);
  text-align: center;
  transition: border-color .2s ease, background .2s ease;
}
.files-upload.is-armed .fu-dropzone { border-color: var(--brand-primary); background: var(--bg-active); }
.fu-dz-icon {
  width: 56px; height: 56px;
  border-radius: 16px;
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--bg-paper);
  color: var(--slate-500);
  box-shadow: 0 4px 6px rgba(15,23,42,.02);
}
.fu-dz-icon svg { width: 28px; height: 28px; }
.fu-dz-text { display: flex; flex-direction: column; gap: 4px; }
.fu-dz-title { margin: 0; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--slate-600); }
.fu-dz-sub { margin: 0; font-size: 13px; color: var(--slate-400); }
/* Upload progress / done state — driven by state classes on .files-upload so the
   dropzone and the status swap cleanly (one visible at a time). */
.fu-status {
  display: none;
  flex-direction: column; align-items: center; justify-content: center;
  gap: 14px; min-height: 188px;
}
.files-upload.is-uploading .fu-dropzone,
.files-upload.is-done .fu-dropzone { display: none; }
.files-upload.is-uploading .fu-status,
.files-upload.is-done .fu-status { display: flex; }
.fu-spin {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 3px solid var(--slate-200);
  border-top-color: var(--brand-primary);
  animation: fupSpin .8s linear infinite;
}
.files-upload.is-done .fu-spin { display: none; }
.fu-check { display: none; color: var(--success-strong); }
.files-upload.is-done .fu-check { display: inline-flex; }
.fu-check svg { width: 44px; height: 44px; }
.fu-status-text { margin: 0; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--slate-600); }
.files-table {
  background: var(--bg-paper);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-2xl);
  overflow: hidden;
}
/* Newly "uploaded" row (added by the guided tour) */
.files-list .files-row.is-new { animation: fileRowIn .5s var(--ease-out-expo) both; }
@keyframes fileRowIn {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: none; }
}
.files-row.is-new .fileic { background: var(--bg-active); color: var(--brand-primary); }
@keyframes fupSpin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) {
  .files-list .files-row.is-new { animation: none; }
  .fu-status .fu-spin { animation: none; }
}
.files-row {
  display: grid;
  grid-template-columns: 40px 1fr 100px 64px;
  align-items: center;
  gap: 12px;

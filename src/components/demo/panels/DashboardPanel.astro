---
import { getStrings, type Lang } from '../../../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Panel: Dashboard -->
<div class="demo-panel" data-panel="dashboard">
  <div class="product-main-head">
    <div class="dash-head-left">
      <div class="dash-title">{s.heroDemoDashTitle}</div>
      <p class="dash-sub">{s.heroDemoDashSubtitle}</p>
    </div>
    <div class="dash-head-right">
      <div class="sync-chip">
        <span class="pulse"></span>
        {s.heroDemoSyncDashboard}
      </div>
      <div class="period-seg" aria-hidden="true">
        <span class="period-opt">{s.heroDemoPeriodMonth}</span>
        <span class="period-opt">{s.heroDemoPeriodQuarter}</span>
        <span class="period-opt is-active">{s.heroDemoPeriodYear}</span>
      </div>
    </div>
  </div>

  <!-- AI Insights -->
  <div class="ai-insights">
    <div class="ai-head">
      <svg class="ai-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      <span class="ai-orb" id="dash-insights-orb"></span>
      <span class="ai-titles">
        <span class="ai-title">{s.heroDemoAiTitle}</span>
        <span class="ai-sub">{s.heroDemoAiSubtitle}</span>
      </span>
    </div>
    <div class="ai-list">
      <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight1}></p></div>
      <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight2}></p></div>
      <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight3}></p></div>
    </div>
  </div>

  <!-- Metric cards -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
    <linearGradient id="sparkFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#3D506D" stop-opacity="0.16"/><stop offset="100%" stop-color="#3D506D" stop-opacity="0"/></linearGradient>
  </defs></svg>
  <div class="metric-grid">
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricRevenue}</span>
      <div class="val"><span class="num" data-count="658">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+28 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 29.9 L 80 5 L 120 14.1 L 160 9.5 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 29.9 L 80 5 L 120 14.1 L 160 9.5 L 200 18.6"/></svg>
    </div>
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricCosts}</span>
      <div class="val"><span class="num" data-count="435">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+24 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 32.2 L 80 5 L 120 15.2 L 160 11.8 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 32.2 L 80 5 L 120 15.2 L 160 11.8 L 200 18.6"/></svg>
    </div>
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricNet}</span>
      <div class="val"><span class="num" data-count="223">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 25.4 L 80 5 L 120 11.8 L 160 5 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 25.4 L 80 5 L 120 11.8 L 160 5 L 200 18.6"/></svg>
    </div>
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricCashFlow}</span>
      <div class="val"><span class="num" data-count="200">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 30.5 L 80 5 L 120 13.5 L 160 5 L 200 22 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 30.5 L 80 5 L 120 13.5 L 160 5 L 200 22"/></svg>
    </div>
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricEbitda}</span>
      <div class="val"><span class="num" data-count="257">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 27.7 L 80 5 L 120 10.7 L 160 5 L 200 16.3 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 27.7 L 80 5 L 120 10.7 L 160 5 L 200 16.3"/></svg>
    </div>
    <div class="metric">
      <span class="eyebrow">{s.heroDemoMetricVat}</span>
      <div class="val"><span class="num" data-count="9">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
      <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+39 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
      <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 39 L 80 5 L 120 5 L 160 5 L 200 39 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 39 L 80 5 L 120 5 L 160 5 L 200 39"/></svg>
    </div>
  </div>

  <!-- Income vs Expenses -->
  <div class="chart-card">
    <div class="chart-card-head">
      <h3>{s.heroDemoChartTitle}</h3>
      <div class="chart-legend">
        <span class="leg-pill"><i class="dot-rev"></i>{s.heroDemoMetricRevenue}</span>
        <span class="leg-pill"><i class="dot-exp"></i>{s.heroDemoMetricCosts}</span>
      </div>
    </div>
    <svg class="dash-chart" viewBox="0 0 1056 244" role="img" aria-hidden="true">
      <defs>
        <linearGradient id="chRev" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#3D506D" stop-opacity="0.14"/><stop offset="100%" stop-color="#3D506D" stop-opacity="0"/></linearGradient>
        <linearGradient id="chExp" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#EF4444" stop-opacity="0.12"/><stop offset="100%" stop-color="#EF4444" stop-opacity="0"/></linearGradient>
      </defs>
      <line class="ch-grid" x1="73.6" x2="1017.6" y1="212" y2="212"/>
      <text class="ch-ytick" x="57.6" y="215">0k</text>
      <line class="ch-grid" x1="73.6" x2="1017.6" y1="145.3" y2="145.3"/>
      <text class="ch-ytick" x="57.6" y="148.3">50k</text>
      <line class="ch-grid" x1="73.6" x2="1017.6" y1="78.7" y2="78.7"/>
      <text class="ch-ytick" x="57.6" y="81.7">100k</text>
      <line class="ch-grid" x1="73.6" x2="1017.6" y1="12" y2="12"/>
      <text class="ch-ytick" x="57.6" y="15">150k</text>
      <path class="ch-area ch-area-exp" d="M 73.6 140 L 159.36 137.3 L 245.28 129.3 L 331.04 132 L 416.8 130.7 L 502.72 134.7 L 588.48 122.7 L 674.4 120 L 760.16 109.3 L 845.92 113.3 L 931.84 112 L 1017.6 114.7 L 1017.6 212 L 73.6 212 Z"/>
      <path class="ch-area ch-area-rev" d="M 73.6 106.7 L 159.36 102.7 L 245.28 90.7 L 331.04 94.7 L 416.8 92 L 502.72 97.3 L 588.48 77.3 L 674.4 72 L 760.16 57.3 L 845.92 62.7 L 931.84 60 L 1017.6 65.3 L 1017.6 212 L 73.6 212 Z"/>
      <path class="ch-line ch-line-exp" pathLength="1" d="M 73.6 140 L 159.36 137.3 L 245.28 129.3 L 331.04 132 L 416.8 130.7 L 502.72 134.7 L 588.48 122.7 L 674.4 120 L 760.16 109.3 L 845.92 113.3 L 931.84 112 L 1017.6 114.7"/>
      <path class="ch-line ch-line-rev" pathLength="1" d="M 73.6 106.7 L 159.36 102.7 L 245.28 90.7 L 331.04 94.7 L 416.8 92 L 502.72 97.3 L 588.48 77.3 L 674.4 72 L 760.16 57.3 L 845.92 62.7 L 931.84 60 L 1017.6 65.3"/>
      <circle class="ch-pt ch-pt-exp" cx="73.6" cy="140" r="2.5" style="--d:0.60s"/>
      <circle class="ch-pt ch-pt-exp" cx="159.36" cy="137.3" r="2.5" style="--d:0.65s"/>
      <circle class="ch-pt ch-pt-exp" cx="245.28" cy="129.3" r="2.5" style="--d:0.70s"/>

<style>
.product-main-head {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 16px; flex-wrap: wrap;
  margin-bottom: 20px;
}
.dash-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 26px;
  letter-spacing: -0.025em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.sync-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0 12px; height: 30px;
  background: var(--blue-20);
  border: 1px solid var(--slate-300);
  border-radius: 999px;
  color: var(--brand-primary);
  font-size: 12px;
  font-weight: 500;
}
.sync-chip .pulse {
  width: 6px; height: 6px;
  background: var(--brand-primary);
  border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(61,80,109,.5);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(61,80,109,.5); }
  70% { box-shadow: 0 0 0 8px rgba(61,80,109,0); }
  100% { box-shadow: 0 0 0 0 rgba(61,80,109,0); }
}
.dash-head-left { display: flex; flex-direction: column; gap: 2px; }
.dash-sub { font-size: 14px; color: var(--slate-500); margin: 0; }
.dash-head-right { display: flex; align-items: center; gap: 10px; }
.period-seg {
  display: flex; gap: 4px;
  height: 30px; align-items: center;
  padding: 4px;
  background: var(--bg-app);
  border-radius: var(--radius-lg);
}
.period-opt {
  padding: 5px 12px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 500;
  color: var(--slate-500);
}
.period-opt.is-active {
  background: var(--bg-paper);
  color: var(--slate-600);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* AI Insights panel */
.ai-insights {
  background: linear-gradient(135deg, var(--slate-50) 0%, var(--slate-100) 100%);
  border: 1px solid rgba(61,80,109,0.10);
  box-shadow: 0 1px 2px rgba(61,80,109,0.04);
  border-radius: var(--radius-2xl);
  padding: 22px;
  margin-bottom: 16px;
}
.ai-head { display: flex; align-items: center; gap: 12px; cursor: pointer; }
.ai-chev { width: 18px; height: 18px; color: var(--slate-400); flex-shrink: 0; transition: transform .3s ease; }
.ai-insights.is-collapsed .ai-chev { transform: rotate(-90deg); }
.ai-orb {
  position: relative;
  width: 32px; height: 32px;
  flex-shrink: 0;
}
/* Conic ring shown only until the real WebGL orb mounts (then .orb-live hides it). */
.ai-orb::before {
  content: "";
  position: absolute; inset: 0;
  border-radius: 50%;
  background: conic-gradient(from 210deg, #56B3EB, #4A6B95, #3D506D, #4A6B95, #56B3EB);
  -webkit-mask: radial-gradient(closest-side, transparent 56%, #000 60%);
          mask: radial-gradient(closest-side, transparent 56%, #000 60%);
  box-shadow: 0 0 10px rgba(86,179,235,.4);
  transition: opacity .3s ease;
}
.ai-orb.orb-live::before { opacity: 0; }
.ai-orb canvas { display: block; width: 100% !important; height: 100% !important; }
.ai-titles { display: flex; flex-direction: column; }
.ai-title { font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--brand-primary); }
.ai-sub { font-size: 12px; font-weight: 500; color: var(--slate-500); }
.ai-list {
  display: flex; flex-direction: column; gap: 12px;
  margin-top: 20px;
  max-height: 420px;
  overflow: hidden;
  transition: max-height .5s var(--ease-out-expo), opacity .35s ease, margin-top .5s var(--ease-out-expo);
}
.ai-insights.is-collapsed .ai-list { max-height: 0; margin-top: 0; opacity: 0; }
.ai-item {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 14px 16px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}
.ai-bullet { width: 6px; height: 6px; border-radius: 50%; background: var(--brand-primary); margin-top: 7px; flex-shrink: 0; }
.ai-item p { margin: 0; font-size: 14px; font-weight: 500; line-height: 1.6; color: var(--slate-500); }
.ai-item p strong { color: var(--brand-primary); font-weight: 600; }

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}
.metric {
  position: relative;
  overflow: hidden;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 18px 18px 0;
  display: flex; flex-direction: column; gap: 8px;
}
.metric .eyebrow {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate-500);
}
.metric .val {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 700;
  color: var(--brand-primary);
  line-height: 1;
  display: flex; align-items: baseline;
}
.metric .val .suf { font-size: 18px; font-weight: 700; }
.metric .val .cur {
  font-size: 14px;
  color: var(--slate-500);
  font-weight: 500;
  margin-left: 5px;
}
.metric .trend {
  font-size: 12px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  margin-bottom: 8px;
}
.metric .trend.up { color: var(--brand-primary); }
.metric .trend.down { color: var(--error); }
.metric .trend .ti { width: 14px; height: 14px; }
.metric .trend .lbl { color: var(--slate-400); font-weight: 500; font-size: 11px; margin-left: 4px; }
.metric .spark {
  width: calc(100% + 36px); height: 40px; display: block; margin: 0 -18px -1px;
  /* Left-to-right reveal wipe. A clip-path is used instead of the stroke-dash
     draw trick because these sparks are stretched (preserveAspectRatio=none)
     with non-scaling-stroke, a combo Blink miscomputes for dash patterns. */
  clip-path: inset(0 100% 0 0);
}
.spark-area { fill: url(#sparkFill); }
.spark-line {
  fill: none; stroke: var(--brand-primary); stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}
/* Power-on stagger — each metric card's sparkline wipes in a beat after the
   last, left-to-right / top-to-bottom. */
.demo-panel[data-panel="dashboard"].is-active .spark {
  clip-path: inset(0 0 0 0);
  transition: clip-path .9s var(--ease-out-expo);
}
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(1) .spark { transition-delay: .18s; }
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(2) .spark { transition-delay: .25s; }
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(3) .spark { transition-delay: .32s; }
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(4) .spark { transition-delay: .39s; }
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(5) .spark { transition-delay: .46s; }
.demo-panel[data-panel="dashboard"].is-active .metric:nth-child(6) .spark { transition-delay: .53s; }

.chart-card {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 22px 24px;
}
.chart-card-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px;
}
.chart-card-head h3 {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  color: var(--brand-primary);
  margin: 0;
}
.chart-legend {
  display: flex; gap: 4px;
  padding: 4px;
  background: var(--bg-app);
  border-radius: var(--radius-lg);
}
.leg-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 5px 12px;
  background: var(--bg-paper);
  border-radius: 8px;
  font-size: 12px; font-weight: 600;
  color: var(--brand-primary);
  box-shadow: var(--shadow-sm);

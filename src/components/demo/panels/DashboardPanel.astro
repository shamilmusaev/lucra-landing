      <circle class="ch-pt ch-pt-exp" cx="931.84" cy="112" r="2.5" style="--d:1.10s"/>
      <circle class="ch-pt ch-pt-exp" cx="1017.6" cy="114.7" r="2.5" style="--d:1.15s"/>
      <circle class="ch-pt ch-pt-rev" cx="73.6" cy="106.7" r="2.5" style="--d:0.60s"/>
      <circle class="ch-pt ch-pt-rev" cx="159.36" cy="102.7" r="2.5" style="--d:0.65s"/>
      <circle class="ch-pt ch-pt-rev" cx="245.28" cy="90.7" r="2.5" style="--d:0.70s"/>
      <circle class="ch-pt ch-pt-rev" cx="331.04" cy="94.7" r="2.5" style="--d:0.75s"/>
      <circle class="ch-pt ch-pt-rev" cx="416.8" cy="92" r="2.5" style="--d:0.80s"/>
      <circle class="ch-pt ch-pt-rev" cx="502.72" cy="97.3" r="2.5" style="--d:0.85s"/>
      <circle class="ch-pt ch-pt-rev" cx="588.48" cy="77.3" r="2.5" style="--d:0.90s"/>
      <circle class="ch-pt ch-pt-rev" cx="674.4" cy="72" r="2.5" style="--d:0.95s"/>
      <circle class="ch-pt ch-pt-rev" cx="760.16" cy="57.3" r="2.5" style="--d:1.00s"/>
      <circle class="ch-pt ch-pt-rev" cx="845.92" cy="62.7" r="2.5" style="--d:1.05s"/>
      <circle class="ch-pt ch-pt-rev" cx="931.84" cy="60" r="2.5" style="--d:1.10s"/>
      <circle class="ch-pt ch-pt-rev" cx="1017.6" cy="65.3" r="2.5" style="--d:1.15s"/>
      <text class="ch-xtick" x="73.6" y="232">01-2025</text>
      <text class="ch-xtick" x="159.36" y="232">02-2025</text>
      <text class="ch-xtick" x="245.28" y="232">03-2025</text>
      <text class="ch-xtick" x="331.04" y="232">04-2025</text>
      <text class="ch-xtick" x="416.8" y="232">05-2025</text>
      <text class="ch-xtick" x="502.72" y="232">06-2025</text>
      <text class="ch-xtick" x="588.48" y="232">01-2026</text>
      <text class="ch-xtick" x="674.4" y="232">02-2026</text>
      <text class="ch-xtick" x="760.16" y="232">03-2026</text>
      <text class="ch-xtick" x="845.92" y="232">04-2026</text>

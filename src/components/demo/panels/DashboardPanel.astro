      <circle class="ch-pt ch-pt-exp" cx="502.72" cy="134.7" r="2.5" style="--d:0.85s"/>
      <circle class="ch-pt ch-pt-exp" cx="588.48" cy="122.7" r="2.5" style="--d:0.90s"/>

---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import DashboardPanel from './panels/DashboardPanel.astro';
import ChatPanel from './panels/ChatPanel.astro';
import FilesPanel from './panels/FilesPanel.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<p class="sr-only">{s.heroDemoSrSummary}</p>
<!-- Product chrome preview -->
<div class="container hero-chrome-wrap reveal delay-3">
  <div class="demo-tabs" role="tablist" aria-label={s.heroDemoTablistLabel}>
    <span class="demo-tab-ind" aria-hidden="true"></span>
    <button class="demo-tab is-active" data-panel="chat" role="tab" type="button">
      <svg viewBox="0 0 19 19" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5.9125 15.6319C7.58251 16.4886 9.50357 16.7206 11.3295 16.2862C13.1555 15.8518 14.7662 14.7795 15.8715 13.2625C16.9768 11.7456 17.504 9.88375 17.358 8.01252C17.212 6.14129 16.4025 4.38373 15.0753 3.05655C13.7482 1.72937 11.9906 0.919847 10.1194 0.773866C8.24813 0.627885 6.38629 1.15504 4.86934 2.26034C3.3524 3.36564 2.28011 4.9764 1.84569 6.80235C1.41128 8.6283 1.64332 10.5494 2.5 12.2194L0.75 17.3819L5.9125 15.6319Z"/></svg>
      {s.heroTabChat}
    </button>
    <button class="demo-tab" data-panel="dashboard" role="tab" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
      {s.heroTabDashboard}
    </button>
    <button class="demo-tab" data-panel="docs" role="tab" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6C5.46957 2 4.96086 2.21071 4.58579 2.58579C4.21071 2.96086 4 3.46957 4 4V20C4 20.5304 4.21071 21.0391 4.58579 21.4142C4.96086 21.7893 5.46957 22 6 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V7.5L14.5 2Z"/><path d="M14 2V8H20"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
      {s.heroTabDocs}
    </button>
  </div>
  <a class="demo-cta" href="/signup">
    {s.heroDemoCtaPill}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
  </a>
  <div class="demo-drift" aria-hidden="true">
    <span class="drift-card d1"></span>
    <span class="drift-card d2"></span>
    <span class="drift-card d3"></span>
    <span class="drift-card d4"></span>
    <span class="drift-card d5"></span>
  </div>
  <!-- The simulated app screen is decorative; the sr-only summary above covers it.
       Tabs and the CTA live outside this node, so they stay real, focusable controls. -->
  <div class="browser-chrome" aria-hidden="true">
    <div class="browser-bar">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>

    <!-- Per-tab explainer callouts: arrowed, anchored to real elements, revealed
         one after another for the active panel (positioned + sequenced in JS). -->
    <div class="product-shell">
    <div class="product-shell-inner">
      <aside class="product-sidebar">
        <div class="brand-row">
          <img src="/assets/logo.svg" alt="" width="22" height="20" />
          <span class="brand-word">Lucra</span>
        </div>

        <!-- Company switcher — the demo cursor opens this and picks a company
             before any chat. Mirrors the real app's client-company selector. -->
        <div class="sb-company-wrap">
          <button class="sb-company" type="button" tabindex="-1" data-co-trigger>
            <span class="av">AA</span>
            <span class="sb-co-text">
              <span class="sb-co-top">
                <span class="nm" data-co-current>Alma AB</span>
                <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </span>
              <span class="sb-co-firm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                Nordö Redovisning
              </span>
            </span>
          </button>
          <div class="sb-co-dropdown" data-co-dropdown>
            <div class="sb-co-search">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              {s.heroChatCoSearch}
            </div>
            <div class="sb-co-head">{s.heroChatCoHeader}</div>
            <button class="sb-co-item is-picked" type="button" tabindex="-1" data-co-pick>
              <span class="sb-co-mark">AA</span>
              <span class="sb-co-meta"><span class="sb-co-name">Alma AB</span><span class="sb-co-sub">559123-4567 · {s.heroChatCoOwner}</span></span>
              <span class="sb-co-pill linked">{s.heroChatCoLinked}</span>
            </button>
            <button class="sb-co-item" type="button" tabindex="-1">
              <span class="sb-co-mark">NS</span>
              <span class="sb-co-meta"><span class="sb-co-name">Nordstream AB</span><span class="sb-co-sub">556789-1234 · {s.heroChatCoOwner}</span></span>
              <span class="sb-co-pill linked">{s.heroChatCoLinked}</span>
            </button>
            <button class="sb-co-item" type="button" tabindex="-1">
              <span class="sb-co-mark">PB</span>
              <span class="sb-co-meta"><span class="sb-co-name">Pixelbit Studio</span><span class="sb-co-sub">559456-7890 · {s.heroChatCoOwner}</span></span>
              <span class="sb-co-pill">{s.heroChatCoUnlinked}</span>
            </button>
            <div class="sb-co-divider"></div>
            <button class="sb-co-manage" type="button" tabindex="-1">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              {s.heroChatCoManage}
            </button>
          </div>
        </div>

        <div class="sb-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          {s.heroDemoSearch}
        </div>

        <div class="sidebar-item active" data-panel="chat">
          <Icon name="square-pen" size={16} /> {s.heroDemoNewChat}
        </div>
        <div class="sidebar-item disabled">
          <Icon name="file-plus-2" size={16} /> {s.heroDemoMonthlyReport}
        </div>
        <div class="sidebar-item" data-panel="dashboard">
          <Icon name="layout-grid" size={16} /> {s.heroDemoNavDashboard}
        </div>
        <div class="sidebar-item" data-panel="docs">
          <Icon name="folder" size={16} /> {s.heroDemoNavFiles}
        </div>

        <div class="sb-history-head">
          <span>{s.heroDemoHistory}</span>
          <svg class="hist-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </div>
        <div class="sb-history-date">{s.heroDemoHistoryToday}</div>
        <div class="sidebar-chat-row" data-hist-live data-default={s.heroDemoChatDefault} data-title={s.heroChatTitleGenerated} aria-hidden="true"></div>
        <div class="sidebar-chat-row">{s.heroDemoChatRecent1}</div>
        <div class="sb-history-date">{s.heroDemoHistoryYesterday}</div>
        <div class="sidebar-chat-row">{s.heroDemoChatRecent2}</div>
        <div class="sidebar-chat-row">{s.heroDemoChatRecent3}</div>

        <div class="sb-spacer"></div>

        <div class="sb-user">
          <span class="av">EK</span>
          <span class="meta">
            <span class="nm">Erik Karlsson</span>
            <span class="em">erik@almaab.se</span>
          </span>
          <svg class="logout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
        </div>
      </aside>

      <main class="product-main">
        <DashboardPanel lang={lang} />

        <ChatPanel lang={lang} />

        <FilesPanel lang={lang} />

      </main>

      <!-- Guided-tour layer — a soft pointer dot the chat intro drives to the
           company switcher and then the chat input, with two explainer tips.
           Positioned in shell-local coordinates by JS; decorative. -->
      <div class="tour-tip" data-tour-tip="chat-1" aria-hidden="true"><p>{s.heroChatTourTip1}</p></div>
      <div class="tour-tip" data-tour-tip="chat-2" aria-hidden="true"><p>{s.heroChatTourTip2}</p></div>
      <div class="tour-tip" data-tour-tip="dash-1" aria-hidden="true"><p>{s.heroDashTip1}</p></div>
      <div class="tour-tip" data-tour-tip="dash-2" aria-hidden="true"><p>{s.heroDashTip2}</p></div>
      <div class="tour-tip" data-tour-tip="dash-3" aria-hidden="true"><p>{s.heroDashTip3}</p></div>
      <div class="tour-tip" data-tour-tip="files-1" aria-hidden="true"><p>{s.heroFilesTip1}</p></div>
      <div class="tour-tip" data-tour-tip="files-2" aria-hidden="true"><p>{s.heroFilesTip2}</p></div>
      <span class="demo-cursor" data-demo-cursor aria-hidden="true"><span class="demo-cursor-dot"></span></span>
    </div>
    </div>
  </div>
</div>

<style>
/* ---------- Hero product chrome ---------- */
.hero-chrome-wrap {
  margin: 72px auto 0;
  padding: 0;
  position: relative;
  z-index: 1;
  /* Inside the demo window only, swap the brand typeface for the real app's
     fonts (Inter body / Plus Jakarta Sans headings) so it reads 1:1 with the
     product. Redefining the vars here re-points every var(--font-*) below. */
  --font-display: var(--demo-font-head);
  --font-body: var(--demo-font-body);
  font-family: var(--demo-font-body);
}
/* Crisp mac window — no top fade (GitBook-style). */
.product-shell {
  background: var(--bg-app);
  border-radius: var(--radius-shell);
  padding: 16px;
  box-shadow: var(--shadow-window);
  border: 1px solid rgba(226,232,240,.8);
}
.product-shell-inner {
  position: relative;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 16px;
  min-height: 560px;
}
.product-sidebar {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.product-sidebar .brand-row {
  display: flex; align-items: center; gap: 10px;
  padding: 6px 8px 12px;
}
.product-sidebar .brand-word { font-size: 18px; }
/* Wordmark inside the demo sidebar — brand gradient (mirrors the nav brand). */
.brand-word {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 28px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
/* Company switcher — gradient avatar + name/chevron + firm sub-row, with a
   dropdown the guided tour opens. Mirrors the real app's client selector. */
.sb-company-wrap { position: relative; margin-bottom: 10px; }
.sb-company {
  display: flex; align-items: center; gap: 12px;
  width: 100%;
  padding: 8px 10px;
  border: 1px solid transparent;
  border-radius: var(--radius-lg);
  background: var(--bg-app);
  text-align: left;
  transition: background .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.sb-company-wrap.is-open .sb-company {
  background: var(--bg-active);
  border-color: rgba(61,80,109,.32);
  box-shadow: 0 6px 18px -8px rgba(15,23,42,.18);
}
.sb-company .av {
  width: 36px; height: 36px; flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #3D506D 0%, #4A5F7F 55%, #56B3EB 130%);
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 700; font-size: 12px;
  color: #fff;
}
.sb-co-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
.sb-co-top { display: flex; align-items: center; gap: 6px; }
.sb-company .nm { flex: 1; min-width: 0; font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--slate-900); letter-spacing: -.012em; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sb-company .chev { width: 14px; height: 14px; color: var(--slate-400); flex-shrink: 0; transition: transform .2s ease, color .15s ease; }
.sb-company-wrap.is-open .sb-company .chev { color: var(--brand-primary); transform: rotate(-90deg); }
.sb-co-firm {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11.5px; font-weight: 600; color: var(--slate-500);
  min-width: 0;
}
.sb-co-firm svg { width: 11px; height: 11px; color: var(--slate-400); flex-shrink: 0; }
/* Dropdown */
.sb-co-dropdown {
  position: absolute; top: calc(100% + 6px); left: 0;
  width: 250px;
  padding: 10px 8px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: var(--shadow-pop);
  display: flex; flex-direction: column; gap: 4px;
  z-index: 20;
  opacity: 0; visibility: hidden;
  transform: translateY(-4px) scale(.98);
  transform-origin: top left;
  transition: opacity .18s ease, transform .28s var(--ease-out-expo), visibility 0s linear .28s;
}
.sb-company-wrap.is-open .sb-co-dropdown {
  opacity: 1; visibility: visible; transform: none;
  transition: opacity .18s ease, transform .28s var(--ease-out-expo);
}
.sb-co-search {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 12px; margin-bottom: 4px;
  background: var(--bg-app);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  font-size: 13px; color: var(--slate-400);
}
.sb-co-search svg { width: 15px; height: 15px; flex-shrink: 0; }
.sb-co-head {
  padding: 4px 10px 6px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .08em;
  color: var(--slate-400);
}
.sb-co-item {
  display: flex; align-items: center; gap: 10px;
  width: 100%; padding: 8px 10px;
  border: 0; border-radius: var(--radius-sm);
  background: transparent; text-align: left;
  font-size: 13px; color: var(--slate-600);
  transition: background .15s ease;
}
.sb-co-item.is-picked { background: var(--bg-active); }
.sb-co-mark {
  width: 26px; height: 26px; flex-shrink: 0;
  border-radius: 50%;
  background: var(--bg-paper);
  border: 1.5px solid var(--border);
  color: var(--brand-primary);
  display: grid; place-items: center;
  font-family: var(--font-display); font-size: 9px; font-weight: 700;
  transition: background .2s ease, border-color .2s ease, color .2s ease;
}
.sb-co-item.is-picked .sb-co-mark { background: var(--brand-primary); border-color: var(--brand-primary); color: #fff; }
.sb-co-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.sb-co-name { font-family: var(--font-display); font-size: 13px; font-weight: 500; color: var(--slate-600); line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sb-co-item.is-picked .sb-co-name { color: var(--brand-primary); font-weight: 600; }
.sb-co-sub { font-size: 11px; color: var(--slate-400); line-height: 1.3; }
.sb-co-pill {
  flex-shrink: 0;
  font-size: 10px; font-weight: 600;
  color: var(--slate-500); background: var(--bg-app);
  padding: 2px 7px; border-radius: 999px;
}
.sb-co-pill.linked { background: var(--bg-active); color: var(--brand-primary); }
.sb-co-divider { height: 1px; background: var(--border); margin: 6px 4px; }
.sb-co-manage {
  display: flex; align-items: center; gap: 10px;
  width: 100%; padding: 8px 10px;
  border: 0; border-radius: var(--radius-sm);
  background: transparent; text-align: left;
  font-size: 13px; font-weight: 500; color: var(--slate-500);
}
.sb-co-manage svg { width: 14px; height: 14px; flex-shrink: 0; }
/* Guided-tour pointer — a soft dot the chat intro glides between targets. */
.demo-cursor {
  position: absolute; left: 0; top: 0;
  z-index: 30; pointer-events: none;
  opacity: 0;
  transition: transform .7s cubic-bezier(.5,.05,.2,1), opacity .3s ease;
}
.demo-cursor.is-on { opacity: 1; }
.demo-cursor-dot {
  position: absolute; left: -9px; top: -9px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: rgba(61,80,109,.92);
  border: 2px solid rgba(255,255,255,.95);
  box-shadow: 0 3px 10px -1px rgba(15,23,42,.35);
  transition: transform .16s ease;
}
.demo-cursor.is-pressing .demo-cursor-dot { transform: scale(.66); }
.demo-cursor.is-pressing::after {
  content: ""; position: absolute; left: -9px; top: -9px;
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 2px solid rgba(61,80,109,.5);
  animation: cursorRipple .5s ease-out forwards;
}
@keyframes cursorRipple {
  from { opacity: .7; transform: scale(.5); }
  to   { opacity: 0; transform: scale(2.6); }
}
/* Explainer tips that ride alongside the pointer (positioned by JS). */
.tour-tip {
  position: absolute; left: 0; top: 0;
  z-index: 29; pointer-events: none;
  width: max-content; max-width: 230px;
  padding: 10px 13px;
  background: linear-gradient(150deg, var(--brand-primary-light), var(--brand-primary));
  border-radius: 12px;
  box-shadow: 0 10px 26px -10px rgba(61,80,109,.55), 0 2px 6px -2px rgba(61,80,109,.3);
  font-size: 12px; font-weight: 500; line-height: 1.4;
  opacity: 0;
  transform: translateY(6px) scale(.96);
  transition: opacity .3s ease, transform .3s ease;
}
.tour-tip p { margin: 0; color: rgba(255,255,255,.9); }
.tour-tip.is-shown { opacity: 1; transform: none; transition: opacity .4s ease, transform .5s var(--ease-out-expo); }
@media (prefers-reduced-motion: reduce) {
  .demo-cursor, .tour-tip { transition: none; }
}
/* Search */
.sb-search {
  display: flex; align-items: center; gap: 8px;
  height: 36px; padding: 0 10px;
  background: var(--bg-app);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  color: var(--slate-400);
  font-size: 13px;
  margin-bottom: 8px;
}
.sb-search svg { width: 15px; height: 15px; flex-shrink: 0; }
/* Nav rows: New chat / Generate report / Dashboard / Files */
.sidebar-item {
  display: flex; align-items: center; gap: 10px;
  height: 38px;
  padding: 0 10px;
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--nav-icon-default);
  font-weight: 500;
  cursor: default;
}
.sidebar-item.active {
  background: var(--bg-active);
  color: var(--brand-primary);
  font-weight: 600;
}
.sidebar-item.disabled { color: var(--slate-300); }
.sidebar-item.disabled svg { opacity: .5; }
.sidebar-item svg { width: 16px; height: 16px; opacity: .8; }
.sidebar-item.active svg { opacity: 1; }
/* History */
.sb-history-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 10px 4px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--slate-400);
}
.sb-history-head .hist-chev { width: 14px; height: 14px; color: var(--slate-400); }
.sb-history-date {
  padding: 6px 10px 4px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--slate-300);
}
.sidebar-chat-row {
  font-size: 13px;
  padding: 7px 10px;
  color: var(--slate-600);
  border-radius: var(--radius-md);
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
}
/* Live "AI is naming this chat" row: collapsed until the chat opens it, then it
   slides in (as the default label), shimmers, and the generated title types in. */
.sidebar-chat-row[data-hist-live] { display: none; }
.sidebar-chat-row[data-hist-live].is-new {
  display: block;
  background: var(--bg-active);
  color: var(--brand-primary);

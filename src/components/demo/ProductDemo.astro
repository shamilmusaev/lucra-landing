.hero-chrome-wrap { position: relative; }

/* Background drift — abstract, faded slate "app window" silhouettes that float
   slowly in the hero margins behind the demo window, giving the section depth and
   life (GitBook-style) without competing with the real product. Decorative only. */
.demo-drift {
  position: absolute;
  left: -34%; right: -34%; top: -7%; bottom: -7%;
  z-index: 0;
  pointer-events: none;
  /* Fade the centre (where the window sits) and the far edges so cards only
     whisper in the side margins. */
  -webkit-mask: radial-gradient(115% 92% at 50% 48%, transparent 30%, #000 64%, transparent 96%);
          mask: radial-gradient(115% 92% at 50% 48%, transparent 30%, #000 64%, transparent 96%);
}
.drift-card {
  position: absolute;
  width: 168px; height: 122px;
  border-radius: 14px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  box-shadow: 0 24px 60px -28px rgba(61,80,109,.30);
  opacity: .5;
  will-change: transform;
}
/* Abstract window header + content lines (slate placeholders, not real screens). */
.drift-card::before {
  content: ""; position: absolute; left: 12px; top: 12px; width: 34px; height: 7px;
  border-radius: 4px; background: var(--slate-200);
  box-shadow: 44px 0 0 -1px var(--slate-100), 78px 0 0 -1px var(--slate-100);
}
.drift-card::after {
  content: ""; position: absolute; left: 12px; right: 12px; top: 34px; height: 60px;
  border-radius: 8px;
  background:
    linear-gradient(var(--slate-100) 0 0) left 0 top 0 / 100% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 18px / 72% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 36px / 88% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 54px / 60% 8px no-repeat;
}
.drift-card.d1 { left: 1%;  top: 16%; width: 156px; animation: driftA 26s ease-in-out infinite; }
.drift-card.d2 { left: 11%; top: 62%; width: 122px; opacity: .42; animation: driftC 31s ease-in-out infinite -5s; }
.drift-card.d3 { right: 2%; top: 12%; width: 172px; animation: driftB 24s ease-in-out infinite -2s; }
.drift-card.d4 { right: 9%; top: 60%; width: 128px; opacity: .42; animation: driftA 29s ease-in-out infinite -7s; }
.drift-card.d5 { left: 47%; top: -7%; width: 104px; opacity: .36; animation: driftB 34s ease-in-out infinite -11s; }
@keyframes driftA { 0%, 100% { transform: translateY(0) rotate(-3deg); } 50% { transform: translateY(-22px) rotate(-1.5deg); } }
@keyframes driftB { 0%, 100% { transform: translateY(0) rotate(3deg); } 50% { transform: translateY(-16px) rotate(4.5deg); } }
@keyframes driftC { 0%, 100% { transform: translate(0, 0) rotate(-2deg); } 50% { transform: translate(8px, -26px) rotate(-3.5deg); } }
@media (prefers-reduced-motion: reduce) {
  .demo-drift .drift-card { animation: none; }
}

  transform: translate(-50%, -18px);
  transition: opacity .45s ease, transform .55s cubic-bezier(.4,0,.2,1);
}
.hero-chrome-wrap.tabs-visible .demo-tabs {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, 0);
}
.demo-tab {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 16px;
  border: 0;
  background: transparent;
  border-radius: 999px;
  font-family: 'General Sans', var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-500);

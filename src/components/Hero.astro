  color: var(--brand-primary);
  font-size: 12px;
  font-weight: 500;
}
.sync-chip .pulse {
  width: 6px; height: 6px;
  background: var(--success);
  border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(34,197,94,.5);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
  70% { box-shadow: 0 0 0 8px rgba(34,197,94,0); }
  100% { box-shadow: 0 0 0 0 rgba(34,197,94,0); }
}
/* Dashboard header: title + subtitle on the left, sync chip + period segment on the right */
.dash-head-left { display: flex; flex-direction: column; gap: 2px; }
.dash-sub { font-size: 13px; color: var(--slate-500); margin: 0; }
.dash-head-right { display: flex; align-items: center; gap: 10px; }
.period-seg {
  display: flex; gap: 4px;
  padding: 4px;
  background: var(--bg-app);
  border-radius: var(--radius-lg);
}
.period-opt {
  padding: 5px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
  color: var(--slate-500);
}
.period-opt.is-active {
  background: var(--bg-paper);
  color: var(--slate-600);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* AI Insights panel */
.ai-insights {
  background: linear-gradient(135deg, var(--slate-50) 0%, var(--slate-100) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 18px 20px;
  margin-bottom: 16px;
}
.ai-head { display: flex; align-items: center; gap: 12px; }
.ai-chev { width: 18px; height: 18px; color: var(--slate-400); flex-shrink: 0; }
.ai-orb {
  width: 30px; height: 30px;
  flex-shrink: 0;
  border-radius: 50%;
  background: conic-gradient(from 210deg, #56B3EB, #4A6B95, #3D506D, #4A6B95, #56B3EB);
  -webkit-mask: radial-gradient(closest-side, transparent 56%, #000 60%);
          mask: radial-gradient(closest-side, transparent 56%, #000 60%);
  box-shadow: 0 0 10px rgba(86,179,235,.4);
}
.ai-orb canvas { display: block; width: 100% !important; height: 100% !important; border-radius: 50%; }
.ai-titles { display: flex; flex-direction: column; }
.ai-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--brand-primary); }
.ai-sub { font-size: 12px; font-weight: 500; color: var(--slate-500); }
.ai-list { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
.ai-item {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 12px 14px;
  background: var(--bg-paper);
  border: 1px solid var(--slate-100);
  border-radius: var(--radius-lg);
}
.ai-bullet { width: 6px; height: 6px; border-radius: 50%; background: var(--brand-primary); margin-top: 7px; flex-shrink: 0; }
.ai-item p { margin: 0; font-size: 13px; font-weight: 500; line-height: 1.5; color: var(--slate-500); }
.ai-item p strong { color: var(--brand-primary); font-weight: 600; }

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}
.metric {
  position: relative;
  overflow: hidden;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 14px 16px 0;
  display: flex; flex-direction: column; gap: 6px;
}
.metric .eyebrow {
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate-500);
}
.metric .val {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  color: var(--brand-primary);
  line-height: 1;
  display: flex; align-items: baseline;
}
.metric .val .suf { font-size: 16px; font-weight: 700; }
.metric .val .cur {
  font-size: 12px;
  color: var(--slate-500);
  font-weight: 500;
  margin-left: 5px;
}
.metric .trend {
  font-size: 11px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  margin-bottom: 8px;
}
.metric .trend.up { color: var(--brand-primary); }
.metric .trend.down { color: var(--error); }
.metric .trend .ti { width: 13px; height: 13px; }
.metric .trend .lbl { color: var(--slate-400); font-weight: 500; font-size: 10px; margin-left: 4px; }
.metric .spark { width: calc(100% + 32px); height: 40px; display: block; margin: 0 -16px -1px; }
.spark-area { fill: url(#sparkFill); opacity: 0; transition: opacity .5s ease .35s; }
.spark-line {
  fill: none; stroke: var(--brand-primary); stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
  stroke-dasharray: 1; stroke-dashoffset: 1;
}
.demo-panel[data-panel="dashboard"].is-active .spark-line { animation: drawPath .9s cubic-bezier(.4,0,.2,1) forwards .25s; }
.demo-panel[data-panel="dashboard"].is-active .spark-area { opacity: 1; }
@keyframes drawPath { to { stroke-dashoffset: 0; } }

.chart-card {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 18px;
}
.chart-card-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 10px;
}
.chart-card-head h3 {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  color: var(--brand-primary);
  margin: 0;
}
.chart-legend {
  display: flex; gap: 4px;
  padding: 4px;
  background: var(--bg-app);
  border-radius: var(--radius-lg);
}
.leg-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 5px 12px;
  background: var(--bg-paper);
  border-radius: 8px;
  font-size: 12px; font-weight: 600;
  color: var(--brand-primary);
  box-shadow: var(--shadow-sm);
}
.leg-pill i { width: 8px; height: 8px; border-radius: 50%; }
.leg-pill .dot-rev { background: var(--brand-primary); }
.leg-pill .dot-exp { background: var(--error); }

/* Income vs Expenses chart */
.dash-chart { width: 100%; height: auto; display: block; }
.ch-grid { stroke: var(--slate-100); stroke-width: 1; }
.ch-ytick { fill: var(--slate-400); font-size: 11px; font-family: var(--font-body); text-anchor: end; }
.ch-xtick { fill: var(--slate-400); font-size: 11px; font-family: var(--font-body); text-anchor: middle; }
.ch-area { opacity: 0; transition: opacity .6s ease .4s; }
.ch-area-rev { fill: url(#chRev); }
.ch-area-exp { fill: url(#chExp); }
.ch-line {
  fill: none; stroke-width: 2.5;
  stroke-linecap: round; stroke-linejoin: round;
  stroke-dasharray: 1; stroke-dashoffset: 1;
}
.ch-line-rev { stroke: var(--brand-primary); }
.ch-line-exp { stroke: var(--error); stroke-width: 2; }
.ch-pt { fill: var(--bg-paper); stroke-width: 2; opacity: 0; transform: scale(.4); transform-origin: center; transform-box: fill-box; }
.ch-pt-rev { stroke: var(--brand-primary); }
.ch-pt-exp { stroke: var(--error); }
.demo-panel[data-panel="dashboard"].is-active .ch-area { opacity: 1; }
.demo-panel[data-panel="dashboard"].is-active .ch-line { animation: drawPath 1.1s cubic-bezier(.4,0,.2,1) forwards .2s; }
.demo-panel[data-panel="dashboard"].is-active .ch-pt { animation: ptIn .35s ease forwards; animation-delay: var(--d); }
@keyframes ptIn { to { opacity: 1; transform: scale(1); } }

/* Small avatar orbs — a lightweight CSS ring echoing the hero orb (cyan→slate
   gradient ring + glow, transparent centre). Used for every chat answer, so it
   stays CSS (no per-message WebGL contexts). */
.orb-gl {
  width: 28px; height: 28px;
  flex-shrink: 0;
  border-radius: 50%;
  background: conic-gradient(from 210deg, #56B3EB, #4A6B95, #3D506D, #4A6B95, #56B3EB);
  -webkit-mask: radial-gradient(closest-side, transparent 56%, #000 60%);
          mask: radial-gradient(closest-side, transparent 56%, #000 60%);
  box-shadow: 0 0 10px rgba(86,179,235,.4);
}

/* ============================================================
   DEMO TABS (scroll-reveal, auto-rotate) + macOS browser chrome
   ============================================================ */
.hero-chrome-wrap { position: relative; }

/* macOS window — clean slate canvas, traffic-light dots, soft deep shadow */
.browser-chrome {
  background: var(--bg-app);
  border: 1px solid rgba(226,232,240,.9);
  border-radius: var(--radius-shell);
  overflow: hidden;
  box-shadow:
    0 1px 1px rgba(15,23,42,.04),
    0 30px 60px -20px rgba(61,80,109,.18),
    0 60px 120px -40px rgba(15,23,42,.18);
}
.browser-bar {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 17px 20px 13px;
  background: transparent;
}
.browser-bar .dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  display: inline-block;
  box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.12);
}
.browser-bar .dot.red    { background: #FF5F57; }
.browser-bar .dot.yellow { background: #FEBC2E; }
.browser-bar .dot.green  { background: #28C840; }
/* Product shell sits inside browser chrome — drop its standalone shadow */
.browser-chrome .product-shell {
  border: 0;
  border-radius: 0;
  box-shadow: none;
  padding: 0;
}
.browser-chrome .product-shell-inner {
  margin: 16px;
}
.demo-tabs {
  position: absolute;
  top: -22px;
  left: 50%;
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 5px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: 0 12px 32px -10px rgba(15,23,42,.18), 0 2px 4px rgba(15,23,42,.04);
  z-index: 12;
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, -18px);
  transition: opacity .45s ease, transform .55s cubic-bezier(.4,0,.2,1);
}
.hero-chrome-wrap.tabs-visible .demo-tabs {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, 0);
}
.demo-tab {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 16px;
  border: 0;
  background: transparent;
  border-radius: 999px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-500);
  cursor: pointer;
  transition: color .42s cubic-bezier(.4,0,.2,1);
  white-space: nowrap;
}
.demo-tab svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  display: none;
}
.demo-tab.is-active svg { display: inline-block; }
.demo-tab:hover:not(.is-active) {
  color: var(--brand-primary);
  background: var(--bg-app);
}
.demo-tab.is-active {
  color: var(--white);
}
/* Active "bubble" — a single pill that flows from one tab into the next */
.demo-tab-ind {
  position: absolute;
  top: 5px;
  bottom: 5px;
  left: 0;
  width: 0;
  background: var(--brand-primary);
  border-radius: 999px;
  box-shadow: 0 2px 8px -2px rgba(61,80,109,.35);
  z-index: 0;
  pointer-events: none;
  opacity: 0;
  transition:
    left .5s cubic-bezier(.34,1.2,.32,1),
    width .5s cubic-bezier(.34,1.2,.32,1),
    opacity .3s ease;
}
.demo-tab-ind.ready { opacity: 1; }

/* Floating CTA pill — sits over the window's bottom edge (GitBook-style),
   appears with the tabs once the window is in view. */
.demo-cta {
  position: absolute;
  left: 50%;
  bottom: -19px;
  z-index: 13;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 11px 20px;
  background: var(--brand-gradient-2);
  color: #fff;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 14px;
  border-radius: 999px;
  box-shadow: 0 12px 28px -10px rgba(15,23,42,.5);
  opacity: 0;
  transform: translate(-50%, 10px);
  transition: opacity .5s ease, transform .5s ease, box-shadow .25s ease;
}
.hero-chrome-wrap.tabs-visible .demo-cta { opacity: 1; transform: translate(-50%, 0); }
.demo-cta svg { width: 16px; height: 16px; transition: transform .25s ease; }
.demo-cta:hover { box-shadow: 0 16px 34px -10px rgba(15,23,42,.6); }
.demo-cta:hover svg { transform: translateX(3px); }

/* Panel stack with cross-fade */
.product-main { position: relative; min-height: 620px; padding: 0; }
.demo-panel {
  position: absolute;
  inset: 22px 24px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  transition:
    opacity .35s ease,
    transform .45s cubic-bezier(.4,0,.2,1),
    visibility 0s linear .45s;
}
.demo-panel.is-active {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition: opacity .4s ease, transform .5s cubic-bezier(.4,0,.2,1);
}
/* Dashboard & Files are tall, scrolling views (like the real app) — let the panel
   scroll internally with a slim, unobtrusive scrollbar. */
.demo-panel[data-panel="dashboard"],
.demo-panel[data-panel="docs"] {
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--slate-300) transparent;
}
.demo-panel[data-panel="dashboard"]::-webkit-scrollbar,
.demo-panel[data-panel="docs"]::-webkit-scrollbar { width: 6px; }
.demo-panel[data-panel="dashboard"]::-webkit-scrollbar-thumb,
.demo-panel[data-panel="docs"]::-webkit-scrollbar-thumb { background: var(--slate-300); border-radius: 999px; }

/* Per-tab explainer callouts — a coach mark naming what each panel does. Shown
   for the active panel only (toggled by the tab orchestrator), above the CTA. */
.coach {
  position: absolute;
  left: 50%; top: 9px;
  z-index: 12;
  width: max-content; max-width: min(82%, 440px);
  display: flex; align-items: center; gap: 9px;
  padding: 10px 15px;
  background: var(--brand-primary);
  color: #fff;
  border-radius: 13px;
  box-shadow: var(--shadow-pop);
  font-size: 12.5px; font-weight: 500; line-height: 1.4;
  opacity: 0; pointer-events: none;
  transform: translate(-50%, -8px);
  transition: opacity .3s ease, transform .3s ease;
}
.coach p { margin: 0; color: #fff; }
.coach-ic { width: 15px; height: 15px; flex-shrink: 0; color: #A7D8F4; }
/* downward pointer into the panel content below */
.coach::after {
  content: "";
  position: absolute; left: 50%; bottom: -5px;
  width: 11px; height: 11px;
  background: var(--brand-primary);
  border-radius: 0 0 3px 0;
  transform: translateX(-50%) rotate(45deg);
}
.hero-chrome-wrap.tabs-visible .coach.is-shown {
  opacity: 1;
  transform: translate(-50%, 0);
  transition: opacity .45s ease .5s, transform .5s cubic-bezier(.4,0,.2,1) .5s;
}
@media (prefers-reduced-motion: reduce) {
  .coach { transition: opacity .2s ease; }
  .hero-chrome-wrap.tabs-visible .coach.is-shown { opacity: 1; transform: translate(-50%, 0); transition: opacity .2s ease; }
}

/* ============================================================
   CHAT panel — welcome-home (resting) → auto-typed conversation.
   Mirrors the real app's chat home; no fake source badges / inline
   charts (the real chat streams plain markdown text).
   ============================================================ */
.chat-scene { position: relative; height: 100%; }
.chat-welcome,
.chat-convo {
  position: absolute;
  inset: 0;
  transition: opacity .45s ease, transform .45s ease, visibility 0s linear .45s;
}
/* Welcome / resting state — vertically centred */
.chat-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}
[data-chat].is-sent .chat-welcome {
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
}
/* Welcome orb — the real WebGL hero orb (secondary instance mounted by script) */
.welcome-orb {
  width: 96px; height: 96px;
  margin-bottom: 22px;
}
.welcome-orb canvas { display: block; width: 100% !important; height: 100% !important; }
.welcome-greeting {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 32px;
  letter-spacing: -0.02em;
  margin: 0 0 6px;
  color: var(--brand-primary);
}
.welcome-subtitle {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: 19px;
  color: var(--slate-400);
  margin: 0 0 28px;
}
.welcome-subtitle .g { font-weight: 600; color: var(--slate-600); }
/* Input — large rounded card (company chip · text · send) */
.chat-input {
  display: flex; flex-direction: column;
  width: 100%; max-width: 600px;
  min-height: 150px;
  padding: 16px 18px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: 0 2px 14px rgba(61,80,109,.05);
  margin-bottom: 24px;
  text-align: left;
}
.chat-co {
  align-self: flex-start;
  font-family: var(--font-display);
  font-weight: 600; font-size: 12px;
  color: var(--brand-primary);
  background: var(--bg-active);
  padding: 4px 10px;
  border-radius: 999px;
  margin-bottom: 12px;
}
.chat-input-body {
  flex: 1;
  font-size: 15px;
  line-height: 1.5;
  color: var(--slate-600);
}
.chat-input-foot { display: flex; justify-content: flex-end; margin-top: 12px; }
.chat-placeholder { color: var(--slate-400); }
[data-chat].is-typing .chat-placeholder,
[data-chat].is-sent .chat-placeholder { display: none; }
.chat-typed { white-space: pre-wrap; }
.chat-caret {
  display: none;
  width: 1.5px; height: 17px;
  margin-left: 1px;
  vertical-align: -3px;
  background: var(--brand-primary);
  animation: caretBlink 1s step-end infinite;
}
[data-chat].is-typing .chat-caret { display: inline-block; }
@keyframes caretBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
.chat-send {
  flex-shrink: 0;
  width: 38px; height: 38px;
  border: 0; border-radius: 50%;
  background: var(--bg-app);
  color: var(--slate-400);
  display: inline-flex; align-items: center; justify-content: center;
  transition: background .25s ease, color .25s ease, transform .25s ease;
}
.chat-send svg { width: 17px; height: 17px; }
[data-chat].is-typing .chat-send { background: var(--brand-primary); color: #fff; transform: scale(1.04); }
/* Suggestion chips */
.chat-chips {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  width: 100%; max-width: 560px;
}
.chat-chip {
  text-align: left;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  padding: 16px;
  display: flex; flex-direction: column; gap: 6px;
  cursor: default;
  transition: border-color .25s ease, background .25s ease, transform .25s ease;
}
.chat-chip:hover {
  border-color: var(--blue-20, #E0E7FF);
  background: rgba(228,236,245,.5);
  transform: translateY(-2px);
}
.chip-head { display: flex; align-items: center; gap: 8px; }
.chip-ic { width: 18px; height: 18px; flex-shrink: 0; color: var(--brand-primary); }
.chip-ic svg { width: 18px; height: 18px; }
.chip-t {
  font-family: var(--font-display);
  font-weight: 600; font-size: 13px;
  color: var(--brand-primary);
}
.chip-d { font-size: 12px; line-height: 1.4; color: var(--slate-500); }

/* Conversation — message thread + a persistent bottom input bar */
.chat-convo {
  display: flex;
  flex-direction: column;
  max-width: 600px;
  margin: 0 auto;
  opacity: 0;
  visibility: hidden;
}
[data-chat].is-sent .chat-convo {
  opacity: 1;
  visibility: visible;
  transition: opacity .45s ease .12s;
}
.chat-thread {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 6px 2px 14px;
}
.chat-bar {
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  gap: 8px;
  padding: 8px 8px 8px 16px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(61,80,109,.05);
}
.chat-bar-body { flex: 1; min-height: 22px; padding: 4px 0; font-size: 14px; line-height: 1.5; color: var(--slate-600); }
.chat-bar-ph { color: var(--slate-400); }
[data-chat].is-typing2 .chat-bar-ph { display: none; }
[data-chat].is-typing2 .chat-bar .chat-caret { display: inline-block; }
.chat-bar .chat-send { width: 34px; height: 34px; }
[data-chat].is-typing2 .chat-bar .chat-send { background: var(--brand-primary); color: #fff; }
.chat-convo .uin {
  align-self: flex-end;
  max-width: 78%;
  background: var(--brand-primary);
  color: #fff;
  font-size: 14px;
  padding: 11px 16px;
  border-radius: 18px 18px 4px 18px;
  line-height: 1.45;
  animation: msgIn .4s cubic-bezier(.2,.7,.2,1) both;
}
.chat-convo .ain {
  display: flex; gap: 12px; align-items: flex-start;
  max-width: 92%;
  animation: msgIn .4s cubic-bezier(.2,.7,.2,1) both .1s;
}
.chat-convo .ain .bubble {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-left: 3px solid #5B7A9B;
  padding: 12px 16px;
  border-radius: 0 16px 16px 16px;
  font-size: 14px;
  color: var(--slate-600);
  line-height: 1.55;
  box-shadow: var(--shadow-sm);
}
.chat-convo .ain .bubble strong { color: var(--brand-primary); font-weight: 600; }
@keyframes msgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
/* User bubble — question text + timestamp */
.chat-convo .uin .utext { display: block; }
.chat-convo .uin .utime { display: block; margin-top: 4px; font-size: 11px; opacity: .65; }

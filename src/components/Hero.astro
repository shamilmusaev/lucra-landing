/* ============================================================
   HERO LOAD-INTRO — the orb wakes, fires a "big-bang" burst, and
   the expanding shockwave lights up the hero copy radially.
   Scoped to .hero-inner copy only — the dashboard below is NOT part
   of the intro (it stays put, seen on scroll).
   Without JS / reduced motion the hero is simply visible.
   Rules keyed off html.hero-intro use :global() on the ancestor so the
   scoped child selectors still match (Nav established this convention).
   ============================================================ */
.hero .reveal { opacity: 1; }            /* fallback: always visible */

/* Armed hidden state — only when JS has set html.hero-intro. */
:global(html.hero-intro) .hero-inner > .reveal,
:global(html.hero-intro) .hero-chrome-wrap {
  opacity: 0;
  transform: translateY(20px) scale(.985);
  filter: blur(8px);
  transition:
    opacity .7s cubic-bezier(.2,.7,.2,1),
    transform .7s cubic-bezier(.2,.7,.2,1),

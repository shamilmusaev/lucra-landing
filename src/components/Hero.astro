  color: var(--brand-primary);
}
.sb-company .nm { flex: 1; font-size: 13px; font-weight: 600; color: var(--brand-primary); }
.sb-company .chev { width: 14px; height: 14px; color: var(--slate-400); }
/* Search */
.sb-search {
  display: flex; align-items: center; gap: 8px;
  height: 36px; padding: 0 10px;
  background: var(--bg-app);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  color: var(--slate-400);
  font-size: 13px;
  margin-bottom: 8px;
}
.sb-search svg { width: 15px; height: 15px; flex-shrink: 0; }
/* Quick actions: New chat / Generate report */
.sb-action {
  display: flex; align-items: center; gap: 10px;
  height: 38px; padding: 0 10px;
  border-radius: var(--radius-md);
  font-size: 13px; font-weight: 500;
  color: var(--nav-icon-default);
  cursor: default;
}
.sb-action svg { width: 17px; height: 17px; flex-shrink: 0; }
.sb-action.primary { color: var(--brand-primary); font-weight: 600; }
.sb-divider { height: 1px; background: var(--border); margin: 8px 4px; }
.product-sidebar .nav-section-label {
  font-family: var(--font-display);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--slate-400);
  padding: 14px 10px 6px;
  font-weight: 700;
}
.sidebar-item {
  display: flex; align-items: center; gap: 10px;
  height: 38px;
  padding: 0 10px;
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--nav-icon-default);
  font-weight: 500;
  cursor: default;
}
.sidebar-item.active {
  background: var(--bg-active);
  color: var(--brand-primary);
  font-weight: 600;
}
.sidebar-item img { width: 16px; height: 16px; opacity: .8; }
.sidebar-item.active img { opacity: 1; }
.sidebar-chat-row {
  font-size: 12.5px;
  padding: 7px 10px;
  color: var(--slate-500);

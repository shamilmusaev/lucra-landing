  display: flex; align-items: center; gap: 8px;
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
}
.sidebar-chat-row::before {
  content: ""; width: 5px; height: 5px; border-radius: 50%;
  background: var(--slate-300); flex-shrink: 0;
}
/* Push the user footer to the bottom */
.sb-spacer { flex: 1 1 auto; min-height: 10px; }
.sb-user {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 6px 2px;
  margin-top: 6px;
  border-top: 1px solid var(--border);
}
.sb-user .av {
  width: 30px; height: 30px; flex-shrink: 0;
  border-radius: 50%;
  background: var(--nav-icon-badge);
  color: #fff;
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 700; font-size: 11px;
}
.sb-user .meta { display: flex; flex-direction: column; gap: 1px; min-width: 0; flex: 1; }
.sb-user .nm { font-family: var(--font-display); font-size: 13px; font-weight: 600; color: var(--brand-primary); }
.sb-user .em { font-size: 11px; color: var(--slate-500); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.sb-user .logout { width: 16px; height: 16px; color: var(--slate-400); flex-shrink: 0; }
.product-main {
  background: var(--bg-paper);
  border-radius: var(--radius-card);
  padding: 22px 24px;
  overflow: hidden;
  position: relative;
}
.product-main-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18px;
}
.dash-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 26px;
  letter-spacing: -0.025em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.sync-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0 12px; height: 30px;
  background: var(--blue-20);
  border: 1px solid var(--slate-300);
  border-radius: 999px;
  color: var(--brand-primary);
  font-size: 12px;
  font-weight: 500;
}
.sync-chip .pulse {
  width: 6px; height: 6px;
  background: var(--success);
  border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(34,197,94,.5);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
  70% { box-shadow: 0 0 0 8px rgba(34,197,94,0); }
  100% { box-shadow: 0 0 0 0 rgba(34,197,94,0); }
}
.metric-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 18px;
}
.metric {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 14px 16px;
  display: flex; flex-direction: column; gap: 6px;
}
.metric .eyebrow {
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate-500);
}
.metric .val {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--brand-primary);
  line-height: 1;
}
.metric .val .cur {
  font-size: 12px;
  color: var(--slate-500);
  font-weight: 500;
  margin-left: 4px;
}
.metric .trend {
  font-size: 11px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.metric .trend.up { color: var(--brand-primary); }
.metric .trend.down { color: var(--error); }
.metric .trend .lbl { color: var(--slate-400); font-weight: 500; font-size: 10px; margin-left: 4px; }
.chart-card {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-2xl);
  padding: 18px;
}
.chart-card-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px;
}
.chart-card-head h3 {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 600;
  color: var(--brand-primary);

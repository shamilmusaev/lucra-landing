<style>
.hero {
  /* Bottom padding lets the mac window float free: its soft drop-shadow
     renders fully (instead of being sliced by overflow:hidden) and there's
     breathing room before the problem section. */
  padding: 140px 0 120px;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 0%, rgba(86,179,235,0.10), transparent 55%),
    linear-gradient(180deg, var(--bg-paper) 0%, var(--bg-paper) 100%);
  isolation: isolate;
}
/* Diagonal slate beams — echo the tailark "night-background" sweep, in Lucra slate */
.hero-beams {
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
  opacity: 0.7;
}
.hero-beams::before,
.hero-beams::after,
.hero-beams span {
  content: "";
  position: absolute;
  left: -120px;
  top: -180px;
  width: 560px;
  height: 1280px;
  border-radius: 999px;
  transform: rotate(-42deg);
  filter: blur(40px);
}
.hero-beams::before {
  background: radial-gradient(60% 60% at 50% 35%,
    rgba(61,80,109,0.16) 0%,
    rgba(74,107,149,0.08) 45%,
    transparent 80%);
}
.hero-beams::after {
  left: 60px;
  width: 220px;
  background: radial-gradient(50% 50% at 50% 50%,
    rgba(86,179,235,0.18) 0%,
    rgba(86,179,235,0.06) 50%,
    transparent 100%);
}
.hero-beams span {
  left: 140px;
  top: -200px;
  width: 220px;
  background: radial-gradient(50% 50% at 50% 50%,
    rgba(61,80,109,0.10) 0%,
    rgba(61,80,109,0.04) 60%,
    transparent 100%);
}
/* ----------------------------------------------------------------
   Hero dot field — the dotted "cloud" from Landing.html, refined.
   A slate dot grid that fades out toward the edges. The dots are
   "fog": JS paints them onto a <canvas> and the cursor wipes them
   away like clearing a misted window, with the trail slowly fogging
   back over a second or two. The CSS background below is the static
   fallback shown when JS / canvas is unavailable or motion is reduced.
   ---------------------------------------------------------------- */
.hero-falling {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
  background-image: radial-gradient(circle, rgba(61,80,109,0.20) 1px, transparent 1.6px);
  background-size: 24px 24px;
  /* Soft dotted cloud: visible in the upper-centre, faded at the edges. */
  -webkit-mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
          mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
}
.hero-falling__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
/* Soft halo + fade to bg behind the headline */
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: radial-gradient(125% 125% at 50% 95%, transparent 0%, var(--bg-paper) 75%);
  pointer-events: none;
}
.hero::after {
  content: "";
  position: absolute;
  top: 80px; left: 50%;
  width: 760px; height: 760px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(224,231,255,0.55) 0%, rgba(238,242,255,0.20) 40%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: -1;
  /* Soft light source that drifts slowly across the hero. */
  transform: translateX(-50%);
  animation: heroLightDrift 22s ease-in-out infinite alternate;
  will-change: transform;
}
@keyframes heroLightDrift {
  0%   { transform: translateX(-50%) translate(-300px, 18px); }
  100% { transform: translateX(-50%) translate(300px, -14px); }
}
@media (prefers-reduced-motion: reduce) {
  .hero::after { animation: none; transform: translateX(-50%); }
}
.hero-inner { position: relative; z-index: 1; text-align: center; }

/* WebGL orb — hero centrepiece, sits above the announcement pill */
.hero-orb {
  display: block;
  width: 76px;
  height: 76px;
  margin: 0 auto 24px;
  position: relative;
  pointer-events: auto;   /* clickable: tap the orb to wipe the hero clean */
  cursor: pointer;
}
@media (max-width: 720px) {
  .hero-orb { width: 62px; height: 62px; margin-bottom: 20px; }
}
.hero-orb canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}
/* The orb's click reaction is a liquid ripple driven inside its WebGL
   shader (see mountHeroOrb) — no CSS overlay. */

/* Announcement pill at the top of the hero */
.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0 auto 36px;
  padding: 5px 6px 5px 6px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: 0 1px 2px rgba(15,23,42,0.05), 0 4px 12px -6px rgba(15,23,42,0.08);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-600);
  line-height: 1;
  white-space: nowrap;
  transition: background .25s ease, box-shadow .25s ease, border-color .25s ease;
}
.hero-pill:hover {
  border-color: var(--slate-300);
  box-shadow: 0 6px 18px -6px rgba(15,23,42,0.14);
}
/* "Nyhet" badge — pinned to the left edge, framed in Lucra's brand gradient */
.hero-pill .pill-badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 999px;
  background: var(--brand-gradient);
  color: var(--white);
  font-family: 'General Sans', var(--font-body);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1;
  box-shadow:
    0 2px 6px -2px rgba(61,80,109,0.45),
    inset 0 1px 0 rgba(255,255,255,0.18);
}
.hero-pill .pill-text {
  color: var(--brand-primary);
  font-weight: 600;
  position: relative;
  display: inline-block;
  overflow: hidden;
  vertical-align: middle;
  line-height: 1;
}
.hero-pill .pill-text .pill-swap {
  display: inline-block;
  will-change: transform, opacity;
}
.hero-pill .pill-text .pill-alt {
  position: absolute;
  inset: 0;
  white-space: nowrap;
}
.hero-pill .pill-text .pill-default {
  animation: pillSwapOut 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
.hero-pill .pill-text .pill-alt {
  animation: pillSwapIn 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
@keyframes pillSwapOut {
  0%, 45%   { transform: translateX(0);     opacity: 1; }
  50%, 95%  { transform: translateX(-110%); opacity: 0; }
  100%      { transform: translateX(0);     opacity: 1; }
}
@keyframes pillSwapIn {
  0%, 45%   { transform: translateX(110%);  opacity: 0; }
  50%, 95%  { transform: translateX(0);     opacity: 1; }
  100%      { transform: translateX(110%);  opacity: 0; }
}
@media (prefers-reduced-motion: reduce) {
  .hero-pill .pill-text .pill-default,
  .hero-pill .pill-text .pill-alt { animation: none; }
  .hero-pill .pill-text .pill-alt { opacity: 0; }
}
.hero-pill .arrow-wrap {
  background: var(--bg-app);
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  transition: background .35s ease;
}
.hero-pill:hover .arrow-wrap { background: var(--bg-active); }
.hero-pill .arrow-wrap svg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12px;
  height: 12px;
  color: var(--brand-primary);
  transform: translate(-50%, -50%);
  transition: transform .45s ease, opacity .3s ease;
}
.hero-pill .arrow-wrap svg.arrow-in {
  transform: translate(-180%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-out {
  transform: translate(80%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-in {
  transform: translate(-50%, -50%);
  opacity: 1;
}

.hero h1 {
  font-family: 'General Sans', var(--font-display);
  font-weight: 500;
  font-size: clamp(44px, 5.4vw, 70px);
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin: 0 auto 26px;
  padding-bottom: 0.12em;
  max-width: 960px;
  user-select: none;
  -webkit-user-select: none;
  -webkit-tap-highlight-color: transparent;
  cursor: default;
  background:
    radial-gradient(
      circle at var(--mx, 80%) var(--my, 50%),
      #56B3EB 0%,
      #4A6B95 30%,
      #3D506D 70%
    );
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  transition: --mx 600ms ease-out, --my 600ms ease-out;
}
@property --mx { syntax: '<percentage>'; inherits: true; initial-value: 80%; }
@property --my { syntax: '<percentage>'; inherits: true; initial-value: 50%; }
.hero-sub {
  font-family: 'General Sans', var(--font-body);
  font-weight: 500;
  font-size: 18px;
  line-height: 1.6;
  color: var(--slate-500);
  max-width: 640px;
  margin: 0 auto 40px;
  text-wrap: pretty;
}
.hero-ctas {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 22px;
}
.hero-ctas .btn {
  font-family: 'General Sans', var(--font-body);
  font-weight: 500;
}
/* Tailark-style frame around the primary CTA. On hover the headline's cyan
   races out from the top in BOTH directions and fills the ring fast, then
   snaps back the instant the pointer leaves. (--cta-fill 0→1 drives the arc.) */
@property --cta-fill { syntax: '<number>'; inherits: false; initial-value: 0; }
.cta-frame {
  position: relative;
  --cta-fill: 0;
  background:
    conic-gradient(from -90deg,
      #FFFFFF 0deg,
      #FFFFFF calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(360deg - var(--cta-fill) * 180deg),
      #FFFFFF calc(360deg - var(--cta-fill) * 180deg),
      #FFFFFF 360deg),
    linear-gradient(rgba(61,80,109,0.10), rgba(61,80,109,0.10));
  border: 1px solid rgba(61,80,109,0.14);
  border-radius: 16px;
  padding: 3px;
  display: inline-flex;
  isolation: isolate;
  /* retract is fast (base transition); fill on :hover is slightly longer */
  transition: --cta-fill .18s ease, box-shadow .25s ease, border-color .25s ease;
}
.cta-frame:hover {
  --cta-fill: 1;
  border-color: rgba(203,213,225,0.95);
  box-shadow: 0 6px 18px rgba(61,80,109,0.20), 0 0 0 1px rgba(255,255,255,0.5) inset;
  transition: --cta-fill .34s cubic-bezier(.3,.7,.25,1), box-shadow .25s ease, border-color .25s ease;
}
.cta-frame .btn {
  position: relative;
  z-index: 1;
  border-radius: 13px;
}

/* "Boka demo" — a soft secondary surface so it reads as a button, not a label. */
.hero-ctas .btn-ghost {
  height: 54px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  color: var(--brand-primary);
  box-shadow: 0 1px 2px rgba(15,23,42,0.05);
  overflow: hidden;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease;
}
.hero-ctas .btn-ghost::before {
  /* slate wash that wipes in from the left on hover */
  content: "";
  display: block;
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(90deg, var(--bg-active), rgba(86,179,235,0.10));
  transform: translateX(-101%);
  transition: transform .4s cubic-bezier(.4,0,.2,1);
  opacity: 1;
}
.hero-ctas .btn-ghost .arrow { width: 14px; height: 14px; transition: transform .25s ease; }
.hero-ctas .btn-ghost:hover {
  border-color: var(--brand-primary);
  transform: translateY(-2px);
  box-shadow: 0 12px 24px -10px rgba(61,80,109,0.35);
}
.hero-ctas .btn-ghost:hover::before { transform: translateX(0); }
.hero-ctas .btn-ghost:hover .arrow { transform: translateX(3px); }
@media (prefers-reduced-motion: reduce) {
  .cta-frame { transition: box-shadow .25s ease, border-color .25s ease; }
}
.hero-microcopy {
  font-size: 13px;
  color: var(--slate-400);
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
}
.hero-microcopy .sep {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--slate-300);
}
.hero-microcopy svg { width: 14px; height: 14px; }

/* ---------- Hero product chrome ---------- */
.hero-chrome-wrap {
  margin: 72px auto 0;
  padding: 0;
  position: relative;
  z-index: 1;
}
/* Crisp mac window — no top fade (GitBook-style). */
.product-shell {
  background: var(--bg-app);
  border-radius: var(--radius-shell);
  padding: 16px;
  box-shadow:
    0 1px 1px rgba(15,23,42,.04),
    0 30px 60px -20px rgba(61,80,109,.18),
    0 60px 120px -40px rgba(15,23,42,.18);
  border: 1px solid rgba(226,232,240,.8);
}
.product-shell-inner {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 16px;
  min-height: 560px;
}
.product-sidebar {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.product-sidebar .brand-row {
  display: flex; align-items: center; gap: 10px;
  padding: 6px 8px 12px;
}
.product-sidebar .brand-word { font-size: 18px; }
/* Wordmark inside the demo sidebar — brand gradient (mirrors the nav brand). */
.brand-word {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 28px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
/* Company selector — matches the real app's company switcher */
.sb-company {
  display: flex; align-items: center; gap: 10px;
  height: 40px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--bg-paper);
  margin-bottom: 8px;
}
.sb-company .av {
  width: 24px; height: 24px; flex-shrink: 0;
  border-radius: 7px;

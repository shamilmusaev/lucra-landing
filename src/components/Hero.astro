.coach::after {
  content: "";
  position: absolute; left: 50%;
  width: 10px; height: 10px;
  background: var(--brand-primary);
  transform: translateX(-50%) rotate(45deg);
}
.coach[data-side="bottom"]::after { top: -5px; background: var(--brand-primary-light); border-left: 1px solid var(--brand-primary-light); border-top: 1px solid var(--brand-primary-light); }
.coach[data-side="top"]::after { bottom: -5px; border-right: 1px solid var(--brand-primary-light); border-bottom: 1px solid var(--brand-primary-light); }
.coach.is-shown {
  opacity: 1;
  transform: translate(-50%, 0) scale(1);
  transition: opacity .4s ease, transform .5s var(--ease-out-expo);
}
@media (prefers-reduced-motion: reduce) {
  .coach { transition: opacity .2s ease; transform: translate(-50%, 0); }

}
.chart-legend {
  display: flex; gap: 14px;
  font-size: 11px;
  color: var(--slate-500);
}
.chart-legend span { display: inline-flex; align-items: center; gap: 5px; }
.chart-legend i {
  width: 8px; height: 8px;
  border-radius: 50%;
}

/* Floating chat bubble overlay on hero chrome */
.hero-chat-float {
  position: absolute;
  right: 32px;
  bottom: 28px;
  width: 320px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-left: 3px solid #5B7A9B;
  border-radius: 0 16px 16px 16px;
  padding: 14px 16px;
  box-shadow: var(--shadow-pop);
  display: flex; gap: 12px; align-items: flex-start;
}
.orb {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 30%, #A7D8F4 0%, #56B3EB 28%, #3D506D 70%, #0F172A 100%);
  box-shadow: inset 0 -4px 8px rgba(15,23,42,.4), 0 2px 6px rgba(61,80,109,.25);
  flex-shrink: 0;
}
.orb.lg {
  width: 56px; height: 56px;
  box-shadow: inset 0 -6px 12px rgba(15,23,42,.4), 0 4px 12px rgba(61,80,109,.3);
}
.orb.xl {
  width: 80px; height: 80px;
  box-shadow: inset 0 -8px 16px rgba(15,23,42,.4), 0 6px 16px rgba(61,80,109,.3);
}
.hero-chat-float .msg {
  font-size: 13px;
  color: var(--slate-600);
  line-height: 1.55;
}
.hero-chat-float .msg strong {
  color: var(--brand-primary);
  font-weight: 600;
}
.hero-chat-float .typing-dot {
  display: inline-block;
  width: 4px; height: 4px;
  background: var(--brand-primary);
  border-radius: 50%;
  margin-left: 2px;

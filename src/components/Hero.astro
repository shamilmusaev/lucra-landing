}
/* Below 1200px the interactive multi-tab demo (tabs, sidebar, chat/docs/companies,
   coach tour, drift cards, scroll-zoom) is dropped in favour of a single static
   Dashboard — fully rendered at rest, no choreography. The rotation/chat/coach
   controllers bail out at this width; this block forces the resting state. */
@media (max-width: 1199px) {
  .demo-tabs, .demo-cta, .demo-drift, .coach-layer, .product-sidebar { display: none; }
  .product-shell-inner { grid-template-columns: 1fr; }
  .product-main { min-height: 0; }
  :global(.demo-panel) { display: none; }
}
</style>

<script>
  import { initChat } from '../scripts/demo/chat';
  import { initDashboard } from '../scripts/demo/dashboard';
  import { initFiles } from '../scripts/demo/files';
  import { initController } from '../scripts/demo/controller';
  import { initScrollZoom } from '../scripts/demo/scrollZoom';
  import { initDemoOrbs } from '../scripts/demo/orbs';
  initScrollZoom();

  (function() {
    // ============================================================
    // Hero load-intro orchestrator
    //   nav fades in → orb grows in → orb pulse (+ dots burst) →
    //   circuit traces draw down from the orb and "power on" each
    //   block as the head reaches it → traces fade out. Clean hero.
    // Gated by html.hero-intro (set pre-paint, skipped for reduced motion).
    // The orb / fog hooks (window.lucraOrbIntro / lucraOrbPulse / lucraFogIntro)
    // are provided by the Orb island (Task 7) and Particles island (Task 8);
    // every call is optionally guarded so the cascade still runs without them.
    // ============================================================
    var root = document.documentElement;
    if (!root.classList.contains('hero-intro')) return;

    var hero = document.querySelector('.hero');
    if (!hero) { root.classList.remove('hero-intro'); return; }
    var heroEl = hero;

    // Ordered hero-copy targets (relative to .hero-inner) — lit radially by the
    // shockwave. The dashboard is intentionally excluded (stays put / on scroll).
    var SELECTORS = ['.hero-pill', 'h1', '.hero-sub', '.hero-ctas', '.hero-chrome-wrap'];
    var w = window as any;

    function revealAll() {
      var els = heroEl.querySelectorAll('.hero-inner > .reveal, .hero-chrome-wrap');
      for (var i = 0; i < els.length; i++) els[i].classList.add('lucra-lit');
    }

    // After the pulse, the copy simply rises + fades in, in order — a gentle
    // stagger radiating down from the orb. No flourishes.
    function cascadeReveal() {
      var els: Element[] = [];
      SELECTORS.forEach(function (sel) { var el = heroEl.querySelector(sel); if (el) els.push(el); });
      if (!els.length) { revealAll(); return; }
      els.forEach(function (el, i) {
        // Tapered cascade — first blocks lead, later ones follow faster.
        var d = i < 2 ? i * 90 : 180 + (i - 2) * 65;
        setTimeout(function () { el.classList.add('lucra-lit'); }, d);
      });
    }

    function run() {
      root.classList.add('nav-in');                                  // nav fades in
      setTimeout(function () { if (w.lucraOrbIntro) w.lucraOrbIntro(); }, 120);  // orb grows + pops in
      setTimeout(function () {                                       // a beat later — the pulse
        if (w.lucraOrbPulse) w.lucraOrbPulse();
        if (w.lucraFogIntro) w.lucraFogIntro();                     // dots burst in with the pulse
      }, 1020);
      setTimeout(cascadeReveal, 1180);                               // then the copy rises in
      setTimeout(revealAll, 2900);                                   // watchdog
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

  (function() {
    // Hero headline cursor spotlight — cyan peak in the accent gradient follows the pointer.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var h1 = document.querySelector('.hero h1') as HTMLElement | null;
    if (!h1) return;
    var h1El = h1;
    var raf = 0;
    var onMove = function(e: PointerEvent) {
      if (raf) return;
      raf = requestAnimationFrame(function() {
        raf = 0;
        var r = h1El.getBoundingClientRect();
        var x = ((e.clientX - r.left) / r.width) * 100;
        var y = ((e.clientY - r.top) / r.height) * 100;
        h1El.style.setProperty('--mx', Math.max(0, Math.min(100, x)) + '%');
        h1El.style.setProperty('--my', Math.max(0, Math.min(100, y)) + '%');
      });
    };
    h1El.addEventListener('pointermove', onMove);
  })();

  initController();

  initChat();

  initDashboard();

  initFiles();

  initDemoOrbs();
</script>

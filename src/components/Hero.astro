---
import { getStrings, type Lang } from '../i18n/utils';
import Icon from './Icon.astro';
import OrbIsland from './OrbIsland.astro';
import HeroParticles from './HeroParticles.astro';
import HeroBeams from './HeroBeams.astro';
import DashboardPanel from './demo/panels/DashboardPanel.astro';
import ChatPanel from './demo/panels/ChatPanel.astro';
import FilesPanel from './demo/panels/FilesPanel.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Arm the hero load-intro (orb wakes → pulse → traces wire up the content)
     before the hero paints, so nothing flashes. Skipped for reduced motion.
     Inlined (is:inline) so it runs pre-paint, matching the legacy <head> behaviour. -->
<script is:inline>
  document.documentElement.classList.add('reveal-ready');
  try {
    if (!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
      document.documentElement.classList.add('hero-intro');
    }
  } catch (e) {}
</script>

<section class="hero">
  <div class="hero-falling" aria-hidden="true"></div>
  <div class="hero-beams" aria-hidden="true"><span></span></div>
  <div class="hero-fade" aria-hidden="true"></div>
  <div class="container hero-inner">
    <span class="hero-orb reveal" id="hero-orb" aria-hidden="true"></span>
    <OrbIsland />
    <HeroParticles />
    <HeroBeams />
    <a class="hero-pill reveal" href="#funktioner">
      <span class="pill-badge">{s.heroPillBadge}</span>
      <span class="pill-text">
        <span class="pill-swap pill-default">{s.heroPillDefault}</span>
        <span class="pill-swap pill-alt" aria-hidden="true">{s.heroPillAlt}</span>
      </span>
      <span class="arrow-wrap" aria-hidden="true">
        <svg class="arrow-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        <svg class="arrow-in" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </span>
    </a>
    <h1 class="reveal delay-1" set:html={s.heroHeadline}></h1>
    <p class="hero-sub reveal delay-2">
      {s.heroSub}
    </p>
    <div class="hero-ctas reveal delay-2">
      <span class="cta-frame">
        <a class="btn btn-primary btn-lg" href="/signup">
          {s.heroCtaPrimary}
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </span>
      <a class="btn btn-ghost btn-lg" href="[CALENDLY_URL]">
        {s.heroCtaSecondary}
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Product chrome preview -->
  <div class="container hero-chrome-wrap reveal delay-3">
    <div class="demo-tabs" role="tablist" aria-label={s.heroDemoTablistLabel}>
      <span class="demo-tab-ind" aria-hidden="true"></span>
      <button class="demo-tab is-active" data-panel="chat" role="tab" type="button">
        <svg viewBox="0 0 19 19" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5.9125 15.6319C7.58251 16.4886 9.50357 16.7206 11.3295 16.2862C13.1555 15.8518 14.7662 14.7795 15.8715 13.2625C16.9768 11.7456 17.504 9.88375 17.358 8.01252C17.212 6.14129 16.4025 4.38373 15.0753 3.05655C13.7482 1.72937 11.9906 0.919847 10.1194 0.773866C8.24813 0.627885 6.38629 1.15504 4.86934 2.26034C3.3524 3.36564 2.28011 4.9764 1.84569 6.80235C1.41128 8.6283 1.64332 10.5494 2.5 12.2194L0.75 17.3819L5.9125 15.6319Z"/></svg>
        {s.heroTabChat}
      </button>
      <button class="demo-tab" data-panel="dashboard" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
        {s.heroTabDashboard}
      </button>
      <button class="demo-tab" data-panel="docs" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6C5.46957 2 4.96086 2.21071 4.58579 2.58579C4.21071 2.96086 4 3.46957 4 4V20C4 20.5304 4.21071 21.0391 4.58579 21.4142C4.96086 21.7893 5.46957 22 6 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V7.5L14.5 2Z"/><path d="M14 2V8H20"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        {s.heroTabDocs}
      </button>
      <button class="demo-tab" data-panel="companies" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/></svg>
        {s.heroTabCompanies}
      </button>
    </div>
    <a class="demo-cta" href="/signup">
      {s.heroDemoCtaPill}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
    <div class="demo-drift" aria-hidden="true">
      <span class="drift-card d1"></span>
      <span class="drift-card d2"></span>
      <span class="drift-card d3"></span>
      <span class="drift-card d4"></span>
      <span class="drift-card d5"></span>
    </div>
    <div class="browser-chrome">
      <div class="browser-bar" aria-hidden="true">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>

      <!-- Per-tab explainer callouts: arrowed, anchored to real elements, revealed
           one after another for the active panel (positioned + sequenced in JS). -->
      <div class="coach-layer" data-coach-group="chat" aria-hidden="true">
        <div class="coach" data-target=".chat-input" data-side="bottom"><p>{s.heroCoachChat1}</p></div>
      </div>
      <div class="coach-layer" data-coach-group="dashboard" aria-hidden="true">
        <div class="coach" data-target=".ai-insights .ai-title" data-side="bottom"><p>{s.heroCoachDashboard1}</p></div>
        <div class="coach" data-target=".metric-grid .metric" data-side="top"><p>{s.heroCoachDashboard2}</p></div>
      </div>
      <div class="coach-layer" data-coach-group="docs" aria-hidden="true">
        <div class="coach" data-target=".files-tabs" data-side="bottom"><p>{s.heroCoachDocs1}</p></div>
        <div class="coach" data-target=".files-list:not([hidden]) .files-row .fname" data-side="top"><p>{s.heroCoachDocs2}</p></div>
      </div>
      <div class="coach-layer" data-coach-group="companies" aria-hidden="true">
        <div class="coach" data-target=".co-row:not(.co-thead) .co-name" data-side="bottom"><p>{s.heroCoachCompanies1}</p></div>
      </div>

      <div class="product-shell">
      <div class="product-shell-inner">
        <aside class="product-sidebar">
          <div class="brand-row">
            <img src="/assets/logo.svg" alt="" width="22" height="20" />
            <span class="brand-word">Lucra</span>
          </div>

          <div class="sb-company">
            <span class="av">AA</span>
            <span class="nm">Alma AB</span>
            <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>

          <div class="sb-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            {s.heroDemoSearch}
          </div>

          <div class="sidebar-item active" data-panel="chat">
            <Icon name="square-pen" size={16} /> {s.heroDemoNewChat}
          </div>
          <div class="sidebar-item disabled">
            <Icon name="file-plus-2" size={16} /> {s.heroDemoMonthlyReport}
          </div>
          <div class="sidebar-item" data-panel="dashboard">
            <Icon name="layout-grid" size={16} /> {s.heroDemoNavDashboard}
          </div>
          <div class="sidebar-item" data-panel="docs">
            <Icon name="folder" size={16} /> {s.heroDemoNavFiles}
          </div>

          <div class="sb-history-head">
            <span>{s.heroDemoHistory}</span>
            <svg class="hist-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-history-date">{s.heroDemoHistoryToday}</div>
          <div class="sidebar-chat-row" data-hist-live data-default={s.heroDemoChatDefault} data-title={s.heroChatTitleGenerated} aria-hidden="true"></div>
          <div class="sidebar-chat-row">{s.heroDemoChatRecent1}</div>
          <div class="sb-history-date">{s.heroDemoHistoryYesterday}</div>
          <div class="sidebar-chat-row">{s.heroDemoChatRecent2}</div>
          <div class="sidebar-chat-row">{s.heroDemoChatRecent3}</div>

          <div class="sb-spacer"></div>

          <div class="sb-user">
            <span class="av">EK</span>
            <span class="meta">
              <span class="nm">Erik Karlsson</span>
              <span class="em">erik@almaab.se</span>
            </span>
            <svg class="logout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
          </div>
        </aside>

        <main class="product-main">
          <DashboardPanel lang={lang} />

          <ChatPanel lang={lang} />

          <FilesPanel lang={lang} />

          <!-- Panel: Companies (firm clients table) -->
          <div class="demo-panel" data-panel="companies">
            <div class="co-head">
              <h2 class="co-title">{s.heroCoTitle}</h2>
              <p class="co-sub">{s.heroCoSubtitle}</p>
            </div>
            <div class="co-table">
              <div class="co-row co-thead">
                <span>{s.heroCoColCompany}</span>
                <span>{s.heroCoColOwner}</span>
                <span>{s.heroCoColStatus}</span>
                <span>{s.heroCoColActivity}</span>
                <span></span>
              </div>
              <div class="co-row">
                <span class="cell-co"><span class="co-mark">AA</span><span class="co-meta"><span class="co-name">Alma AB</span><span class="co-reg">559123-4567</span></span></span>
                <span class="cell-owner"><span class="co-av">EK</span><span class="co-meta"><span class="co-oname">Erik Karlsson</span><span class="co-omail">erik@almaab.se</span></span></span>
                <span><span class="co-status connected">{s.heroCoConnected}</span></span>
                <span class="co-act">{s.heroCoAct1}</span>
                <span class="co-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
              </div>
              <div class="co-row">
                <span class="cell-co"><span class="co-mark">NS</span><span class="co-meta"><span class="co-name">Nordstream AB</span><span class="co-reg">556789-1234</span></span></span>
                <span class="cell-owner"><span class="co-av">SL</span><span class="co-meta"><span class="co-oname">Sofia Lind</span><span class="co-omail">sofia@nordstream.se</span></span></span>
                <span><span class="co-status connected">{s.heroCoConnected}</span></span>
                <span class="co-act">{s.heroCoAct2}</span>
                <span class="co-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
              </div>
              <div class="co-row">
                <span class="cell-co"><span class="co-mark">PB</span><span class="co-meta"><span class="co-name">Pixelbit Studio</span><span class="co-reg">559456-7890</span></span></span>
                <span class="cell-owner"><span class="co-av">JB</span><span class="co-meta"><span class="co-oname">Johan Berg</span><span class="co-omail">johan@pixelbit.se</span></span></span>
                <span><span class="co-status connected">{s.heroCoConnected}</span></span>
                <span class="co-act">{s.heroCoAct3}</span>
                <span class="co-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
              </div>
              <div class="co-row">
                <span class="cell-co"><span class="co-mark">KS</span><span class="co-meta"><span class="co-name">Klangstudio AB</span><span class="co-reg">556321-9876</span></span></span>
                <span class="cell-owner"><span class="co-av">MH</span><span class="co-meta"><span class="co-oname">Maria Holm</span><span class="co-omail">maria@klangstudio.se</span></span></span>
                <span><span class="co-status pending">{s.heroCoPending}</span></span>
                <span class="co-act">{s.heroCoAct4}</span>
                <span class="co-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
              </div>
              <div class="co-row">
                <span class="cell-co"><span class="co-mark">LK</span><span class="co-meta"><span class="co-name">Lundgren Konsult</span><span class="co-reg">556782-1140</span></span></span>
                <span class="cell-owner"><span class="co-av">EL</span><span class="co-meta"><span class="co-oname">Erik Lundgren</span><span class="co-omail">erik@lundgren.se</span></span></span>
                <span><span class="co-status connected">{s.heroCoConnected}</span></span>
                <span class="co-act">{s.heroCoAct5}</span>
                <span class="co-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
              </div>
            </div>
          </div>

        </main>
      </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  /* Bottom padding lets the mac window float free: its soft drop-shadow
     renders fully (instead of being sliced by overflow:hidden) and there's
     breathing room before the problem section. */
  padding: 140px 0 120px;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 0%, rgba(86,179,235,0.10), transparent 55%),
    linear-gradient(180deg, var(--bg-paper) 0%, var(--bg-paper) 100%);
  isolation: isolate;
}
/* Diagonal slate beams — echo the tailark "night-background" sweep, in Lucra slate */
.hero-beams {
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
  opacity: 0.7;
}
.hero-beams::before,
.hero-beams::after,
.hero-beams span {
  content: "";
  position: absolute;
  left: -120px;
  top: -180px;
  width: 560px;
  height: 1280px;
  border-radius: 999px;
  transform: rotate(-42deg);
  filter: blur(40px);
}
.hero-beams::before {
  background: radial-gradient(60% 60% at 50% 35%,
    rgba(61,80,109,0.16) 0%,
    rgba(74,107,149,0.08) 45%,
    transparent 80%);
}
.hero-beams::after {
  left: 60px;
  width: 220px;
  background: radial-gradient(50% 50% at 50% 50%,
    rgba(86,179,235,0.18) 0%,
    rgba(86,179,235,0.06) 50%,
    transparent 100%);
}
.hero-beams span {
  left: 140px;
  top: -200px;
  width: 220px;
  background: radial-gradient(50% 50% at 50% 50%,
    rgba(61,80,109,0.10) 0%,
    rgba(61,80,109,0.04) 60%,
    transparent 100%);
}
/* Animated canvas beams (HeroBeams island). Soft, blurred slate shafts that
   multiply onto the light page so they stay low-key. Once it mounts, the static
   blobs above are hidden (they remain the reduced-motion / no-JS fallback). */
.hero-beams__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  filter: blur(14px);
  mix-blend-mode: multiply;
}
.hero-beams.is-animated::before,
.hero-beams.is-animated::after,
.hero-beams.is-animated span { display: none; }
/* ----------------------------------------------------------------
   Hero dot field — the dotted "cloud" from Landing.html, refined.
   A slate dot grid that fades out toward the edges. The dots are
   "fog": JS paints them onto a <canvas> and the cursor wipes them
   away like clearing a misted window, with the trail slowly fogging
   back over a second or two. The CSS background below is the static
   fallback shown when JS / canvas is unavailable or motion is reduced.
   ---------------------------------------------------------------- */
.hero-falling {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
  background-image: radial-gradient(circle, rgba(61,80,109,0.20) 1px, transparent 1.6px);
  background-size: 24px 24px;
  /* Soft dotted cloud: visible in the upper-centre, faded at the edges. */
  -webkit-mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
          mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
}
.hero-falling__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
/* Soft halo + fade to bg behind the headline */
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: radial-gradient(125% 125% at 50% 95%, transparent 0%, var(--bg-paper) 75%);
  pointer-events: none;
}
.hero::after {
  content: "";
  position: absolute;
  top: 80px; left: 50%;
  width: 760px; height: 760px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(224,231,255,0.55) 0%, rgba(238,242,255,0.20) 40%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: -1;
  /* Soft light source that drifts slowly across the hero. */
  transform: translateX(-50%);
  animation: heroLightDrift 22s ease-in-out infinite alternate;
  will-change: transform;
}
@keyframes heroLightDrift {
  0%   { transform: translateX(-50%) translate(-300px, 18px); }
  100% { transform: translateX(-50%) translate(300px, -14px); }
}
@media (prefers-reduced-motion: reduce) {
  .hero::after { animation: none; transform: translateX(-50%); }
}
/* Bottom fade — washes any clipped hero effects (dot field, beams, light blob)
   to solid page-white before the hard section edge, so the hero blends
   seamlessly into the next (white) section instead of leaving a visible seam.
   Sits above the effects (z:0) but below the content/chrome (z:1). */
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 200px;
  z-index: 0;
  pointer-events: none;
  background: linear-gradient(to bottom, transparent, var(--bg-paper));
}
.hero-inner { position: relative; z-index: 1; text-align: center; }

/* WebGL orb — hero centrepiece, sits above the announcement pill */
.hero-orb {
  display: block;
  width: 76px;
  height: 76px;
  margin: 0 auto 24px;
  position: relative;
  pointer-events: auto;   /* clickable: tap the orb to wipe the hero clean */
  cursor: pointer;
}
@media (max-width: 720px) {
  .hero-orb { width: 62px; height: 62px; margin-bottom: 20px; }
}
.hero-orb canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}
/* The orb's click reaction is a liquid ripple driven inside its WebGL
   shader (see mountHeroOrb) — no CSS overlay. */

/* Announcement pill at the top of the hero */
.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0 auto 36px;
  padding: 5px 6px 5px 6px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: 0 1px 2px rgba(15,23,42,0.05), 0 4px 12px -6px rgba(15,23,42,0.08);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-600);
  line-height: 1;
  white-space: nowrap;
  transition: background .25s ease, box-shadow .25s ease, border-color .25s ease;
}
.hero-pill:hover {
  border-color: var(--slate-300);
  box-shadow: 0 6px 18px -6px rgba(15,23,42,0.14);
}
/* "Nyhet" badge — pinned to the left edge, framed in Lucra's brand gradient */
.hero-pill .pill-badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 999px;
  background: var(--brand-gradient);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1;
  box-shadow:
    0 2px 6px -2px rgba(61,80,109,0.45),
    inset 0 1px 0 rgba(255,255,255,0.18);
}
.hero-pill .pill-text {
  color: var(--brand-primary);
  font-weight: 600;
  position: relative;
  display: inline-block;
  overflow: hidden;
  vertical-align: middle;
  line-height: 1;
}
.hero-pill .pill-text .pill-swap {
  display: inline-block;
  will-change: transform, opacity;
}
.hero-pill .pill-text .pill-alt {
  position: absolute;
  inset: 0;
  white-space: nowrap;
}
.hero-pill .pill-text .pill-default {
  animation: pillSwapOut 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
.hero-pill .pill-text .pill-alt {
  animation: pillSwapIn 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
@keyframes pillSwapOut {
  0%, 45%   { transform: translateX(0);     opacity: 1; }
  50%, 95%  { transform: translateX(-110%); opacity: 0; }
  100%      { transform: translateX(0);     opacity: 1; }
}
@keyframes pillSwapIn {
  0%, 45%   { transform: translateX(110%);  opacity: 0; }
  50%, 95%  { transform: translateX(0);     opacity: 1; }
  100%      { transform: translateX(110%);  opacity: 0; }
}
@media (prefers-reduced-motion: reduce) {
  .hero-pill .pill-text .pill-default,
  .hero-pill .pill-text .pill-alt { animation: none; }
  .hero-pill .pill-text .pill-alt { opacity: 0; }
}
.hero-pill .arrow-wrap {
  background: var(--bg-app);
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  transition: background .35s ease;
}
.hero-pill:hover .arrow-wrap { background: var(--bg-active); }
.hero-pill .arrow-wrap svg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12px;
  height: 12px;
  color: var(--brand-primary);
  transform: translate(-50%, -50%);
  transition: transform .45s ease, opacity .3s ease;
}
.hero-pill .arrow-wrap svg.arrow-in {
  transform: translate(-180%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-out {
  transform: translate(80%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-in {
  transform: translate(-50%, -50%);
  opacity: 1;
}

.hero h1 {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(44px, 5.4vw, 70px);
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin: 0 auto 26px;
  padding-bottom: 0.12em;
  max-width: 960px;
  user-select: none;
  -webkit-user-select: none;
  -webkit-tap-highlight-color: transparent;
  cursor: default;
  background:
    radial-gradient(
      circle at var(--mx, 80%) var(--my, 50%),
      #56B3EB 0%,
      #4A6B95 30%,
      #3D506D 70%
    );
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  transition: --mx 600ms ease-out, --my 600ms ease-out;
}
@property --mx { syntax: '<percentage>'; inherits: true; initial-value: 80%; }
@property --my { syntax: '<percentage>'; inherits: true; initial-value: 50%; }
.hero-sub {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 18px;
  line-height: 1.6;
  color: var(--slate-500);
  max-width: 640px;
  margin: 0 auto 40px;
  text-wrap: pretty;
}
.hero-ctas {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 22px;
}
.hero-ctas .btn {
  font-family: var(--font-body);
  font-weight: 500;
}
/* Tailark-style frame around the primary CTA. On hover the headline's cyan
   races out from the top in BOTH directions and fills the ring fast, then
   snaps back the instant the pointer leaves. (--cta-fill 0→1 drives the arc.) */
@property --cta-fill { syntax: '<number>'; inherits: false; initial-value: 0; }
.cta-frame {
  position: relative;
  --cta-fill: 0;
  background:
    conic-gradient(from -90deg,
      #FFFFFF 0deg,
      #FFFFFF calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(360deg - var(--cta-fill) * 180deg),
      #FFFFFF calc(360deg - var(--cta-fill) * 180deg),
      #FFFFFF 360deg),
    linear-gradient(rgba(61,80,109,0.10), rgba(61,80,109,0.10));
  border: 1px solid rgba(61,80,109,0.14);
  border-radius: 16px;
  padding: 3px;
  display: inline-flex;
  isolation: isolate;
  /* retract is fast (base transition); fill on :hover is slightly longer */
  transition: --cta-fill .18s ease, box-shadow .25s ease, border-color .25s ease;
}
.cta-frame:hover {
  --cta-fill: 1;
  border-color: rgba(203,213,225,0.95);
  box-shadow: 0 6px 18px rgba(61,80,109,0.20), 0 0 0 1px rgba(255,255,255,0.5) inset;
  transition: --cta-fill .34s cubic-bezier(.3,.7,.25,1), box-shadow .25s ease, border-color .25s ease;
}
.cta-frame .btn {
  position: relative;
  z-index: 1;
  border-radius: 13px;
}

/* "Boka demo" — a soft secondary surface so it reads as a button, not a label. */
.hero-ctas .btn-ghost {
  height: 54px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  color: var(--brand-primary);
  box-shadow: 0 1px 2px rgba(15,23,42,0.05);
  overflow: hidden;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease;
}
.hero-ctas .btn-ghost::before {
  /* slate wash that wipes in from the left on hover */
  content: "";
  display: block;
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(90deg, var(--bg-active), rgba(86,179,235,0.10));
  transform: translateX(-101%);
  transition: transform .4s cubic-bezier(.4,0,.2,1);
  opacity: 1;
}
.hero-ctas .btn-ghost .arrow { width: 14px; height: 14px; transition: transform .25s ease; }
.hero-ctas .btn-ghost:hover {
  border-color: var(--brand-primary);
  transform: translateY(-2px);
  box-shadow: 0 12px 24px -10px rgba(61,80,109,0.35);
}
.hero-ctas .btn-ghost:hover::before { transform: translateX(0); }
.hero-ctas .btn-ghost:hover .arrow { transform: translateX(3px); }
@media (prefers-reduced-motion: reduce) {
  .cta-frame { transition: box-shadow .25s ease, border-color .25s ease; }
}
.hero-microcopy {
  font-size: 13px;
  color: var(--slate-400);
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
}
.hero-microcopy .sep {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--slate-300);
}
.hero-microcopy svg { width: 14px; height: 14px; }

/* ---------- Hero product chrome ---------- */
.hero-chrome-wrap {
  margin: 72px auto 0;
  padding: 0;
  position: relative;
  z-index: 1;
  /* Inside the demo window only, swap the brand typeface for the real app's
     fonts (Inter body / Plus Jakarta Sans headings) so it reads 1:1 with the
     product. Redefining the vars here re-points every var(--font-*) below. */
  --font-display: var(--demo-font-head);
  --font-body: var(--demo-font-body);
  font-family: var(--demo-font-body);
}
/* Crisp mac window — no top fade (GitBook-style). */
.product-shell {
  background: var(--bg-app);
  border-radius: var(--radius-shell);
  padding: 16px;
  box-shadow: var(--shadow-window);
  border: 1px solid rgba(226,232,240,.8);
}
.product-shell-inner {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 16px;
  min-height: 560px;
}
.product-sidebar {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.product-sidebar .brand-row {
  display: flex; align-items: center; gap: 10px;
  padding: 6px 8px 12px;
}
.product-sidebar .brand-word { font-size: 18px; }
/* Wordmark inside the demo sidebar — brand gradient (mirrors the nav brand). */
.brand-word {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 28px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
/* Company selector — circular gradient avatar + name + chevron */
.sb-company {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  border-radius: var(--radius-lg);
  background: var(--bg-app);
  margin-bottom: 10px;
}
.sb-company .av {
  width: 36px; height: 36px; flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #3D506D 0%, #4A5F7F 55%, #56B3EB 130%);
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 700; font-size: 12px;
  color: #fff;
}
.sb-company .nm { flex: 1; min-width: 0; font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--brand-primary); line-height: 1.2; }
.sb-company .chev { width: 16px; height: 16px; color: var(--slate-400); flex-shrink: 0; }
/* Search */
.sb-search {
  display: flex; align-items: center; gap: 8px;
  height: 36px; padding: 0 10px;
  background: var(--bg-app);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  color: var(--slate-400);
  font-size: 13px;
  margin-bottom: 8px;
}
.sb-search svg { width: 15px; height: 15px; flex-shrink: 0; }
/* Nav rows: New chat / Generate report / Dashboard / Files */
.sidebar-item {
  display: flex; align-items: center; gap: 10px;
  height: 38px;
  padding: 0 10px;
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--nav-icon-default);
  font-weight: 500;
  cursor: default;
}
.sidebar-item.active {
  background: var(--bg-active);
  color: var(--brand-primary);
  font-weight: 600;
}
.sidebar-item.disabled { color: var(--slate-300); }
.sidebar-item.disabled svg { opacity: .5; }
.sidebar-item svg { width: 16px; height: 16px; opacity: .8; }
.sidebar-item.active svg { opacity: 1; }
/* History */
.sb-history-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 10px 4px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--slate-400);
}
.sb-history-head .hist-chev { width: 14px; height: 14px; color: var(--slate-400); }
.sb-history-date {
  padding: 6px 10px 4px;
  font-family: var(--font-display);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--slate-300);
}
.sidebar-chat-row {
  font-size: 13px;
  padding: 7px 10px;
  color: var(--slate-600);
  border-radius: var(--radius-md);
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
}
/* Live "AI is naming this chat" row: collapsed until the chat opens it, then it
   slides in (as the default label), shimmers, and the generated title types in. */
.sidebar-chat-row[data-hist-live] { display: none; }
.sidebar-chat-row[data-hist-live].is-new {
  display: block;
  background: var(--bg-active);
  color: var(--brand-primary);
  font-weight: 600;
  animation: histRowIn .42s var(--ease-out-expo) both;
}
@keyframes histRowIn {
  from { opacity: 0; transform: translateY(-6px); max-height: 0; padding-top: 0; padding-bottom: 0; }
  to   { opacity: 1; transform: none; max-height: 40px; }
}
.sidebar-chat-row[data-hist-live].is-generating {
  background-image: linear-gradient(100deg, var(--bg-active) 0%, var(--bg-active) 35%, rgba(86,179,235,.22) 50%, var(--bg-active) 65%, var(--bg-active) 100%);
  background-size: 220% 100%;
  animation: histShimmer 1s linear infinite;
}
@keyframes histShimmer {
  from { background-position: 180% 0; }
  to   { background-position: -40% 0; }
}
@media (prefers-reduced-motion: reduce) {
  .sidebar-chat-row[data-hist-live].is-new { animation: none; }
  .sidebar-chat-row[data-hist-live].is-generating { animation: none; background-image: none; }
}
/* Push the user footer to the bottom */
.sb-spacer { flex: 1 1 auto; min-height: 10px; }
.sb-user {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 6px 2px;
  margin-top: 6px;
  border-top: 1px solid var(--border);
}
.sb-user .av {
  width: 30px; height: 30px; flex-shrink: 0;
  border-radius: 50%;
  background: var(--nav-icon-badge);
  color: #fff;
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 700; font-size: 11px;
}
.sb-user .meta { display: flex; flex-direction: column; gap: 1px; min-width: 0; flex: 1; }
.sb-user .nm { font-family: var(--font-display); font-size: 13px; font-weight: 600; color: var(--brand-primary); }
.sb-user .em { font-size: 11px; color: var(--slate-500); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.sb-user .logout { width: 16px; height: 16px; color: var(--slate-400); flex-shrink: 0; }
.product-main {
  background: var(--bg-paper);
  border-radius: var(--radius-card);
  padding: 22px 24px;
  overflow: hidden;
  position: relative;
}
/* ============================================================
   DEMO TABS (scroll-reveal, auto-rotate) + macOS browser chrome
   ============================================================ */
.hero-chrome-wrap { position: relative; }

/* Background drift — abstract, faded slate "app window" silhouettes that float
   slowly in the hero margins behind the demo window, giving the section depth and
   life (GitBook-style) without competing with the real product. Decorative only. */
.demo-drift {
  position: absolute;
  left: -34%; right: -34%; top: -7%; bottom: -7%;
  z-index: 0;
  pointer-events: none;
  /* Fade the centre (where the window sits) and the far edges so cards only
     whisper in the side margins. */
  -webkit-mask: radial-gradient(115% 92% at 50% 48%, transparent 30%, #000 64%, transparent 96%);
          mask: radial-gradient(115% 92% at 50% 48%, transparent 30%, #000 64%, transparent 96%);
}
.drift-card {
  position: absolute;
  width: 168px; height: 122px;
  border-radius: 14px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  box-shadow: 0 24px 60px -28px rgba(61,80,109,.30);
  opacity: .5;
  will-change: transform;
}
/* Abstract window header + content lines (slate placeholders, not real screens). */
.drift-card::before {
  content: ""; position: absolute; left: 12px; top: 12px; width: 34px; height: 7px;
  border-radius: 4px; background: var(--slate-200);
  box-shadow: 44px 0 0 -1px var(--slate-100), 78px 0 0 -1px var(--slate-100);
}
.drift-card::after {
  content: ""; position: absolute; left: 12px; right: 12px; top: 34px; height: 60px;
  border-radius: 8px;
  background:
    linear-gradient(var(--slate-100) 0 0) left 0 top 0 / 100% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 18px / 72% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 36px / 88% 8px no-repeat,
    linear-gradient(var(--slate-100) 0 0) left 0 top 54px / 60% 8px no-repeat;
}
.drift-card.d1 { left: 1%;  top: 16%; width: 156px; animation: driftA 26s ease-in-out infinite; }
.drift-card.d2 { left: 11%; top: 62%; width: 122px; opacity: .42; animation: driftC 31s ease-in-out infinite -5s; }
.drift-card.d3 { right: 2%; top: 12%; width: 172px; animation: driftB 24s ease-in-out infinite -2s; }
.drift-card.d4 { right: 9%; top: 60%; width: 128px; opacity: .42; animation: driftA 29s ease-in-out infinite -7s; }
.drift-card.d5 { left: 47%; top: -7%; width: 104px; opacity: .36; animation: driftB 34s ease-in-out infinite -11s; }
@keyframes driftA { 0%, 100% { transform: translateY(0) rotate(-3deg); } 50% { transform: translateY(-22px) rotate(-1.5deg); } }
@keyframes driftB { 0%, 100% { transform: translateY(0) rotate(3deg); } 50% { transform: translateY(-16px) rotate(4.5deg); } }
@keyframes driftC { 0%, 100% { transform: translate(0, 0) rotate(-2deg); } 50% { transform: translate(8px, -26px) rotate(-3.5deg); } }
@media (prefers-reduced-motion: reduce) {
  .demo-drift .drift-card { animation: none; }
}
@media (max-width: 960px) {
  .demo-drift { display: none; }
}

/* macOS window — clean slate canvas, traffic-light dots, soft deep shadow */
.browser-chrome {
  background: var(--bg-app);
  border: 1px solid rgba(226,232,240,.9);
  border-radius: var(--radius-shell);
  overflow: hidden;
  box-shadow: var(--shadow-window);
}
.browser-bar {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 17px 20px 13px;
  background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(255,255,255,0));
  border-bottom: 1px solid rgba(61,80,109,0.07);
}
.browser-bar .dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  display: inline-block;
  box-shadow: 0 0 0 0.5px rgba(0,0,0,0.06), inset 0 1px 1px rgba(255,255,255,0.45);
}
.browser-bar .dot.red    { background: #FF5F57; }
.browser-bar .dot.yellow { background: #FEBC2E; }
.browser-bar .dot.green  { background: #28C840; }
/* Product shell sits inside browser chrome — drop its standalone shadow */
.browser-chrome .product-shell {
  border: 0;
  border-radius: 0;
  box-shadow: none;
  padding: 0;
}
.browser-chrome .product-shell-inner {
  margin: 16px;
}
.demo-tabs {
  position: absolute;
  top: -22px;
  left: 50%;
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 5px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: 0 12px 32px -12px rgba(61,80,109,0.20), 0 2px 4px rgba(15,23,42,0.04);
  z-index: 12;
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, -18px);
  transition: opacity .45s ease, transform .55s var(--ease-out-expo);
}
.hero-chrome-wrap.tabs-visible .demo-tabs {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, 0);
}
.demo-tab {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 16px;
  border: 0;
  background: transparent;
  border-radius: 999px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-500);
  cursor: pointer;
  transition: color .42s cubic-bezier(.4,0,.2,1);
  white-space: nowrap;
}
.demo-tab svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  display: none;
}
.demo-tab.is-active svg { display: inline-block; }
.demo-tab:hover:not(.is-active) {
  color: var(--brand-primary);
  background: var(--bg-app);
}
.demo-tab.is-active {
  color: var(--white);
}
/* Active "bubble" — a single pill that flows from one tab into the next */
.demo-tab-ind {
  position: absolute;
  top: 5px;
  bottom: 5px;
  left: 0;
  width: 0;
  background: var(--brand-primary);
  border-radius: 999px;
  box-shadow: 0 2px 8px -2px rgba(61,80,109,.35);
  z-index: 0;
  pointer-events: none;
  opacity: 0;
  transition:
    left .5s cubic-bezier(.34,1.2,.32,1),
    width .5s cubic-bezier(.34,1.2,.32,1),
    opacity .3s ease;
}
.demo-tab-ind.ready { opacity: 1; }

/* Floating CTA pill — sits over the window's bottom edge (GitBook-style),
   appears with the tabs once the window is in view. */
.demo-cta {
  position: absolute;
  left: 50%;
  bottom: -19px;
  z-index: 13;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 11px 20px;
  background: var(--brand-gradient-2);
  color: #fff;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 14px;
  border-radius: 999px;
  box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 10px 24px -10px rgba(61,80,109,0.45), 0 4px 10px -6px rgba(15,23,42,0.25);
  opacity: 0;
  transform: translate(-50%, 10px);
  transition: opacity .5s ease, transform .5s ease, box-shadow .25s ease;
}
.hero-chrome-wrap.tabs-visible .demo-cta { opacity: 1; transform: translate(-50%, 0); }
.demo-cta svg { width: 16px; height: 16px; transition: transform .25s ease; }
.demo-cta:hover { box-shadow: 0 1px 0 rgba(255,255,255,0.14) inset, 0 16px 32px -10px rgba(61,80,109,0.50); }
.demo-cta:hover svg { transform: translateX(3px); }

/* Panel stack with cross-fade */
.product-main { position: relative; min-height: 620px; padding: 0; }
:global(.demo-panel) {
  position: absolute;
  inset: 22px 24px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(4px);
  transition:
    opacity .35s ease,
    transform .45s var(--ease-out-expo),
    visibility 0s linear .45s;
}
:global(.demo-panel.is-active) {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition: opacity .32s ease, transform .5s var(--ease-out-expo);
}
/* Active panel children rise in a short stagger after the surface fades, so a
   tab switch feels composed. Targets only direct block children — the chat
   panel's absolute scenes live one level deeper and stay untouched. */
:global(.demo-panel.is-active) > * { animation: panelChildIn .5s var(--ease-out-expo) both; }
:global(.demo-panel.is-active) > *:nth-child(2) { animation-delay: .05s; }
:global(.demo-panel.is-active) > *:nth-child(3) { animation-delay: .09s; }
:global(.demo-panel.is-active) > *:nth-child(n+4) { animation-delay: .14s; }
/* Dashboard & Files are tall, scrolling views (like the real app) — let the panel
   scroll internally with a slim, unobtrusive scrollbar. */
:global(.demo-panel[data-panel="dashboard"]),
:global(.demo-panel[data-panel="docs"]) {
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--slate-300) transparent;
}
:global(.demo-panel[data-panel="dashboard"])::-webkit-scrollbar,
:global(.demo-panel[data-panel="docs"])::-webkit-scrollbar { width: 6px; }
:global(.demo-panel[data-panel="dashboard"])::-webkit-scrollbar-thumb,
:global(.demo-panel[data-panel="docs"])::-webkit-scrollbar-thumb { background: var(--slate-300); border-radius: 999px; }

/* Per-tab explainer callouts — arrowed coach marks that point at real elements
   and reveal one after another for the active panel. The layer fills the (scaled)
   window so JS can position each pill in chrome-local coordinates. */
.coach-layer { position: absolute; inset: 0; z-index: 12; pointer-events: none; }
.coach {
  position: absolute;
  left: 0; top: 0;
  width: max-content; max-width: 232px;
  padding: 10px 14px;
  background: linear-gradient(150deg, var(--brand-primary-light), var(--brand-primary));

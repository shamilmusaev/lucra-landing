---
import { getStrings, type Lang } from '../i18n/utils';
import Icon from './Icon.astro';
import OrbIsland from './OrbIsland.astro';
import HeroParticles from './HeroParticles.astro';
import HeroBeams from './HeroBeams.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Arm the hero load-intro (orb wakes → pulse → traces wire up the content)
     before the hero paints, so nothing flashes. Skipped for reduced motion.
     Inlined (is:inline) so it runs pre-paint, matching the legacy <head> behaviour. -->
<script is:inline>
  document.documentElement.classList.add('reveal-ready');
  try {
    if (!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
      document.documentElement.classList.add('hero-intro');
    }
  } catch (e) {}
</script>

<section class="hero">
  <div class="hero-falling" aria-hidden="true"></div>
  <div class="hero-beams" aria-hidden="true"><span></span></div>
  <div class="hero-fade" aria-hidden="true"></div>
  <div class="container hero-inner">
    <span class="hero-orb reveal" id="hero-orb" aria-hidden="true"></span>
    <OrbIsland />
    <HeroParticles />
    <HeroBeams />
    <a class="hero-pill reveal" href="#funktioner">
      <span class="pill-badge">{s.heroPillBadge}</span>
      <span class="pill-text">
        <span class="pill-swap pill-default">{s.heroPillDefault}</span>
        <span class="pill-swap pill-alt" aria-hidden="true">{s.heroPillAlt}</span>
      </span>
      <span class="arrow-wrap" aria-hidden="true">
        <svg class="arrow-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        <svg class="arrow-in" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </span>
    </a>
    <h1 class="reveal delay-1" set:html={s.heroHeadline}></h1>
    <p class="hero-sub reveal delay-2">
      {s.heroSub}
    </p>
    <div class="hero-ctas reveal delay-2">
      <span class="cta-frame">
        <a class="btn btn-primary btn-lg" href="/signup">
          {s.heroCtaPrimary}
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </span>
      <a class="btn btn-ghost btn-lg" href="[CALENDLY_URL]">
        {s.heroCtaSecondary}
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Product chrome preview -->
  <div class="container hero-chrome-wrap reveal delay-3">
    <div class="demo-tabs" role="tablist" aria-label={s.heroDemoTablistLabel}>
      <span class="demo-tab-ind" aria-hidden="true"></span>
      <button class="demo-tab is-active" data-panel="chat" role="tab" type="button">
        <svg viewBox="0 0 19 19" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5.9125 15.6319C7.58251 16.4886 9.50357 16.7206 11.3295 16.2862C13.1555 15.8518 14.7662 14.7795 15.8715 13.2625C16.9768 11.7456 17.504 9.88375 17.358 8.01252C17.212 6.14129 16.4025 4.38373 15.0753 3.05655C13.7482 1.72937 11.9906 0.919847 10.1194 0.773866C8.24813 0.627885 6.38629 1.15504 4.86934 2.26034C3.3524 3.36564 2.28011 4.9764 1.84569 6.80235C1.41128 8.6283 1.64332 10.5494 2.5 12.2194L0.75 17.3819L5.9125 15.6319Z"/></svg>
        {s.heroTabChat}
      </button>
      <button class="demo-tab" data-panel="dashboard" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
        {s.heroTabDashboard}
      </button>
      <button class="demo-tab" data-panel="docs" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6C5.46957 2 4.96086 2.21071 4.58579 2.58579C4.21071 2.96086 4 3.46957 4 4V20C4 20.5304 4.21071 21.0391 4.58579 21.4142C4.96086 21.7893 5.46957 22 6 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V7.5L14.5 2Z"/><path d="M14 2V8H20"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        {s.heroTabDocs}
      </button>
      <button class="demo-tab" data-panel="companies" role="tab" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/></svg>
        {s.heroTabCompanies}
      </button>
    </div>
    <a class="demo-cta" href="/signup">
      {s.heroDemoCtaPill}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
    <div class="browser-chrome">
      <div class="browser-bar" aria-hidden="true">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>

      <!-- Per-tab explainer callouts — float in the window title bar, scaling with
           the window; shown for the active panel only (toggled by the orchestrator). -->
      <div class="coach is-shown" data-coach="chat"><svg class="coach-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6z"/></svg><p>{s.heroCoachChat}</p></div>
      <div class="coach" data-coach="dashboard"><svg class="coach-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6z"/></svg><p>{s.heroCoachDashboard}</p></div>
      <div class="coach" data-coach="docs"><svg class="coach-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6z"/></svg><p>{s.heroCoachDocs}</p></div>
      <div class="coach" data-coach="companies"><svg class="coach-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6z"/></svg><p>{s.heroCoachCompanies}</p></div>

      <div class="product-shell">
      <div class="product-shell-inner">
        <aside class="product-sidebar">
          <div class="brand-row">
            <img src="/assets/logo.svg" alt="" width="22" height="20" />
            <span class="brand-word">Lucra</span>
          </div>

          <div class="sb-company">
            <span class="av">AA</span>
            <span class="nm">Alma AB</span>
            <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>

          <div class="sb-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            {s.heroDemoSearch}
          </div>

          <div class="sidebar-item active" data-panel="chat">
            <Icon name="square-pen" size={16} /> {s.heroDemoNewChat}
          </div>
          <div class="sidebar-item disabled">
            <Icon name="file-plus-2" size={16} /> {s.heroDemoMonthlyReport}
          </div>
          <div class="sidebar-item" data-panel="dashboard">
            <Icon name="layout-grid" size={16} /> {s.heroDemoNavDashboard}
          </div>
          <div class="sidebar-item" data-panel="docs">
            <Icon name="folder" size={16} /> {s.heroDemoNavFiles}
          </div>

          <div class="sb-history-head">
            <span>{s.heroDemoHistory}</span>
            <svg class="hist-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-history-date">{s.heroDemoHistoryDate}</div>
          <div class="sidebar-chat-row">{s.heroDemoChat1}</div>
          <div class="sidebar-chat-row">{s.heroDemoChat2}</div>
          <div class="sidebar-chat-row">{s.heroDemoChat3}</div>

          <div class="sb-spacer"></div>

          <div class="sb-user">
            <span class="av">EK</span>
            <span class="meta">
              <span class="nm">Erik Karlsson</span>
              <span class="em">erik@almaab.se</span>
            </span>
            <svg class="logout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
          </div>
        </aside>

        <main class="product-main">
          <!-- Panel: Dashboard -->
          <div class="demo-panel" data-panel="dashboard">
            <div class="product-main-head">
              <div class="dash-head-left">
                <div class="dash-title">{s.heroDemoDashTitle}</div>
                <p class="dash-sub">{s.heroDemoDashSubtitle}</p>
              </div>
              <div class="dash-head-right">
                <div class="sync-chip">
                  <span class="pulse"></span>
                  {s.heroDemoSyncDashboard}
                </div>
                <div class="period-seg" aria-hidden="true">
                  <span class="period-opt">{s.heroDemoPeriodMonth}</span>
                  <span class="period-opt">{s.heroDemoPeriodQuarter}</span>
                  <span class="period-opt is-active">{s.heroDemoPeriodYear}</span>
                </div>
              </div>
            </div>

            <!-- AI Insights -->
            <div class="ai-insights">
              <div class="ai-head">
                <svg class="ai-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
                <span class="ai-orb" id="dash-insights-orb"></span>
                <span class="ai-titles">
                  <span class="ai-title">{s.heroDemoAiTitle}</span>
                  <span class="ai-sub">{s.heroDemoAiSubtitle}</span>
                </span>
              </div>
              <div class="ai-list">
                <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight1}></p></div>
                <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight2}></p></div>
                <div class="ai-item"><span class="ai-bullet"></span><p set:html={s.heroDemoAiInsight3}></p></div>
              </div>
            </div>

            <!-- Metric cards -->
            <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
              <linearGradient id="sparkFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#3D506D" stop-opacity="0.16"/><stop offset="100%" stop-color="#3D506D" stop-opacity="0"/></linearGradient>
            </defs></svg>
            <div class="metric-grid">
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricRevenue}</span>
                <div class="val"><span class="num" data-count="658">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+28 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 29.9 L 80 5 L 120 14.1 L 160 9.5 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 29.9 L 80 5 L 120 14.1 L 160 9.5 L 200 18.6"/></svg>
              </div>
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricCosts}</span>
                <div class="val"><span class="num" data-count="435">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+24 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 32.2 L 80 5 L 120 15.2 L 160 11.8 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 32.2 L 80 5 L 120 15.2 L 160 11.8 L 200 18.6"/></svg>
              </div>
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricNet}</span>
                <div class="val"><span class="num" data-count="223">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 25.4 L 80 5 L 120 11.8 L 160 5 L 200 18.6 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 25.4 L 80 5 L 120 11.8 L 160 5 L 200 18.6"/></svg>
              </div>
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricCashFlow}</span>
                <div class="val"><span class="num" data-count="200">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 30.5 L 80 5 L 120 13.5 L 160 5 L 200 22 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 30.5 L 80 5 L 120 13.5 L 160 5 L 200 22"/></svg>
              </div>
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricEbitda}</span>
                <div class="val"><span class="num" data-count="257">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+35 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 27.7 L 80 5 L 120 10.7 L 160 5 L 200 16.3 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 27.7 L 80 5 L 120 10.7 L 160 5 L 200 16.3"/></svg>
              </div>
              <div class="metric">
                <span class="eyebrow">{s.heroDemoMetricVat}</span>
                <div class="val"><span class="num" data-count="9">0</span><span class="suf">k</span><span class="cur">SEK</span></div>
                <div class="trend up"><svg class="ti" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+39 %<span class="lbl">{s.heroDemoMetricVsYear}</span></div>
                <svg class="spark" viewBox="0 0 200 44" preserveAspectRatio="none" aria-hidden="true"><path class="spark-area" d="M 0 39 L 40 39 L 80 5 L 120 5 L 160 5 L 200 39 L 200 44 L 0 44 Z"/><path class="spark-line" pathLength="1" vector-effect="non-scaling-stroke" d="M 0 39 L 40 39 L 80 5 L 120 5 L 160 5 L 200 39"/></svg>
              </div>
            </div>

            <!-- Income vs Expenses -->
            <div class="chart-card">
              <div class="chart-card-head">
                <h3>{s.heroDemoChartTitle}</h3>
                <div class="chart-legend">
                  <span class="leg-pill"><i class="dot-rev"></i>{s.heroDemoMetricRevenue}</span>
                  <span class="leg-pill"><i class="dot-exp"></i>{s.heroDemoMetricCosts}</span>
                </div>
              </div>
              <svg class="dash-chart" viewBox="0 0 660 244" role="img" aria-hidden="true">
                <defs>
                  <linearGradient id="chRev" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#3D506D" stop-opacity="0.14"/><stop offset="100%" stop-color="#3D506D" stop-opacity="0"/></linearGradient>
                  <linearGradient id="chExp" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#EF4444" stop-opacity="0.12"/><stop offset="100%" stop-color="#EF4444" stop-opacity="0"/></linearGradient>
                </defs>
                <line class="ch-grid" x1="46" x2="636" y1="212" y2="212"/>
                <text class="ch-ytick" x="36" y="215">0k</text>
                <line class="ch-grid" x1="46" x2="636" y1="145.3" y2="145.3"/>
                <text class="ch-ytick" x="36" y="148.3">50k</text>
                <line class="ch-grid" x1="46" x2="636" y1="78.7" y2="78.7"/>
                <text class="ch-ytick" x="36" y="81.7">100k</text>
                <line class="ch-grid" x1="46" x2="636" y1="12" y2="12"/>
                <text class="ch-ytick" x="36" y="15">150k</text>
                <path class="ch-area ch-area-exp" d="M 46 140 L 99.6 137.3 L 153.3 129.3 L 206.9 132 L 260.5 130.7 L 314.2 134.7 L 367.8 122.7 L 421.5 120 L 475.1 109.3 L 528.7 113.3 L 582.4 112 L 636 114.7 L 636 212 L 46 212 Z"/>
                <path class="ch-area ch-area-rev" d="M 46 106.7 L 99.6 102.7 L 153.3 90.7 L 206.9 94.7 L 260.5 92 L 314.2 97.3 L 367.8 77.3 L 421.5 72 L 475.1 57.3 L 528.7 62.7 L 582.4 60 L 636 65.3 L 636 212 L 46 212 Z"/>
                <path class="ch-line ch-line-exp" pathLength="1" d="M 46 140 L 99.6 137.3 L 153.3 129.3 L 206.9 132 L 260.5 130.7 L 314.2 134.7 L 367.8 122.7 L 421.5 120 L 475.1 109.3 L 528.7 113.3 L 582.4 112 L 636 114.7"/>
                <path class="ch-line ch-line-rev" pathLength="1" d="M 46 106.7 L 99.6 102.7 L 153.3 90.7 L 206.9 94.7 L 260.5 92 L 314.2 97.3 L 367.8 77.3 L 421.5 72 L 475.1 57.3 L 528.7 62.7 L 582.4 60 L 636 65.3"/>
                <circle class="ch-pt ch-pt-exp" cx="46" cy="140" r="3.5" style="--d:0.60s"/>
                <circle class="ch-pt ch-pt-exp" cx="99.6" cy="137.3" r="3.5" style="--d:0.65s"/>
                <circle class="ch-pt ch-pt-exp" cx="153.3" cy="129.3" r="3.5" style="--d:0.70s"/>
                <circle class="ch-pt ch-pt-exp" cx="206.9" cy="132" r="3.5" style="--d:0.75s"/>
                <circle class="ch-pt ch-pt-exp" cx="260.5" cy="130.7" r="3.5" style="--d:0.80s"/>
                <circle class="ch-pt ch-pt-exp" cx="314.2" cy="134.7" r="3.5" style="--d:0.85s"/>
                <circle class="ch-pt ch-pt-exp" cx="367.8" cy="122.7" r="3.5" style="--d:0.90s"/>
                <circle class="ch-pt ch-pt-exp" cx="421.5" cy="120" r="3.5" style="--d:0.95s"/>
                <circle class="ch-pt ch-pt-exp" cx="475.1" cy="109.3" r="3.5" style="--d:1.00s"/>
                <circle class="ch-pt ch-pt-exp" cx="528.7" cy="113.3" r="3.5" style="--d:1.05s"/>
                <circle class="ch-pt ch-pt-exp" cx="582.4" cy="112" r="3.5" style="--d:1.10s"/>
                <circle class="ch-pt ch-pt-exp" cx="636" cy="114.7" r="3.5" style="--d:1.15s"/>
                <circle class="ch-pt ch-pt-rev" cx="46" cy="106.7" r="3.5" style="--d:0.60s"/>
                <circle class="ch-pt ch-pt-rev" cx="99.6" cy="102.7" r="3.5" style="--d:0.65s"/>
                <circle class="ch-pt ch-pt-rev" cx="153.3" cy="90.7" r="3.5" style="--d:0.70s"/>
                <circle class="ch-pt ch-pt-rev" cx="206.9" cy="94.7" r="3.5" style="--d:0.75s"/>
                <circle class="ch-pt ch-pt-rev" cx="260.5" cy="92" r="3.5" style="--d:0.80s"/>
                <circle class="ch-pt ch-pt-rev" cx="314.2" cy="97.3" r="3.5" style="--d:0.85s"/>
                <circle class="ch-pt ch-pt-rev" cx="367.8" cy="77.3" r="3.5" style="--d:0.90s"/>
                <circle class="ch-pt ch-pt-rev" cx="421.5" cy="72" r="3.5" style="--d:0.95s"/>

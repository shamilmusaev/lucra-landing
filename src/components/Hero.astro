---
import { getStrings, type Lang } from '../i18n/utils';
import OrbIsland from './OrbIsland.astro';
import HeroParticles from './HeroParticles.astro';
import ProductDemo from './demo/ProductDemo.astro';
import { APP_URL, BOOK_DEMO_URL } from '../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<!-- Arm the hero load-intro (orb wakes → pulse → traces wire up the content)
     before the hero paints, so nothing flashes. Skipped for reduced motion.
     Inlined (is:inline) so it runs pre-paint, matching the legacy <head> behaviour. -->
<script is:inline>
  document.documentElement.classList.add('reveal-ready');
  try {
    // Skip the orb-synced intro for reduced-motion AND on touch devices: the orb
    // is gated off on phones, so the timeline would hold the hero copy hidden
    // while the demo (revealed immediately) shows first. On touch the copy is
    // visible up front (fast opacity reveal handles the rest).
    var coarse = window.matchMedia && window.matchMedia('(pointer: coarse)').matches;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce && !coarse) {
      document.documentElement.classList.add('hero-intro');
    }
  } catch (e) {}
</script>

<section class="hero">
  <div class="hero-falling" aria-hidden="true"></div>
  <div class="hero-fade" aria-hidden="true"></div>
  <div class="container hero-inner">
    <span class="hero-orb reveal" id="hero-orb" aria-hidden="true"></span>
    <OrbIsland />
    <HeroParticles />
    <a class="hero-pill reveal" href="#funktioner">
      <span class="pill-badge">{s.heroPillBadge}</span>
      <span class="pill-text">
        <span class="pill-swap pill-default">{s.heroPillDefault}</span>
        <span class="pill-swap pill-alt" aria-hidden="true">{s.heroPillAlt}</span>
      </span>
      <span class="arrow-wrap" aria-hidden="true">
        <svg class="arrow-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        <svg class="arrow-in" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </span>
    </a>
    <h1 class="reveal delay-1" set:html={s.heroHeadline}></h1>
    <p class="hero-sub reveal delay-2">
      {s.heroSub}
    </p>
    <div class="hero-ctas reveal delay-2">
      <span class="cta-frame">
        <a class="btn btn-primary btn-lg" href={APP_URL} target="_blank" rel="noopener">
          {s.heroCtaPrimary}
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </span>
      <a class="btn btn-ghost btn-lg" href={BOOK_DEMO_URL} data-calendly>
        {s.heroCtaSecondary}
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <ProductDemo lang={lang} />
</section>

<style>
.hero {
  /* Bottom padding lets the mac window float free: its soft drop-shadow
     renders fully (instead of being sliced by overflow:hidden) and there's
     breathing room before the problem section. */
  /* env() is 0 on desktop; on phones (viewport-fit=cover) it keeps content
     clear of the notch while the hero background fills the safe area behind it. */
  padding: calc(140px + env(safe-area-inset-top)) 0 120px;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 0%, rgba(86,179,235,0.10), transparent 55%),
    linear-gradient(180deg, var(--bg-paper) 0%, var(--bg-paper) 100%);
  isolation: isolate;
}
/* ----------------------------------------------------------------
   Hero dot field — the dotted "cloud" from Landing.html, refined.
   A slate dot grid that fades out toward the edges. The dots are
   "fog": JS paints them onto a <canvas> and the cursor wipes them
   away like clearing a misted window, with the trail slowly fogging
   back over a second or two. The CSS background below is the static
   fallback shown when JS / canvas is unavailable or motion is reduced.
   ---------------------------------------------------------------- */
.hero-falling {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
  background-image: radial-gradient(circle, rgba(61,80,109,0.20) 1px, transparent 1.6px);
  background-size: 24px 24px;
  /* Soft dotted cloud: visible in the upper-centre, faded at the edges. */
  -webkit-mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
          mask-image: radial-gradient(ellipse 74% 66% at 50% 30%, #000 0%, #000 40%, transparent 84%);
}
.hero-falling__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
/* Soft halo + fade to bg behind the headline */
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: radial-gradient(125% 125% at 50% 95%, transparent 0%, var(--bg-paper) 75%);
  pointer-events: none;
}
.hero::after {
  content: "";
  position: absolute;
  top: 80px; left: 50%;
  width: 760px; height: 760px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(224,231,255,0.55) 0%, rgba(238,242,255,0.20) 40%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: -1;
  /* Soft light source that drifts slowly across the hero. */
  transform: translateX(-50%);
  animation: heroLightDrift 22s ease-in-out infinite alternate;
  will-change: transform;
}
@keyframes heroLightDrift {
  0%   { transform: translateX(-50%) translate(-300px, 18px); }
  100% { transform: translateX(-50%) translate(300px, -14px); }
}
@media (prefers-reduced-motion: reduce) {
  .hero::after { animation: none; transform: translateX(-50%); }
}
/* Touch: drop the continuously-animating blur(80px) light blob — an off-thread
   paint that runs forever. The hero gradient + static halo carry the look. */
@media (hover: none) and (pointer: coarse) {
  .hero::after { display: none; }
}
/* Bottom fade — washes any clipped hero effects (dot field, light blob)
   to solid page-white before the hard section edge, so the hero blends
   seamlessly into the next (white) section instead of leaving a visible seam.
   Sits above the effects (z:0) but below the content/chrome (z:1). */
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 200px;
  z-index: 0;
  pointer-events: none;
  background: linear-gradient(to bottom, transparent, var(--bg-paper));
}
.hero-inner { position: relative; z-index: 1; text-align: center; }

/* WebGL orb — hero centrepiece, sits above the announcement pill */
.hero-orb {
  display: block;
  width: 76px;
  height: 76px;
  margin: 0 auto 24px;
  position: relative;
  pointer-events: auto;   /* clickable: tap the orb to wipe the hero clean */
  cursor: pointer;
}
@media (max-width: 720px) {
  .hero-orb { width: 62px; height: 62px; margin-bottom: 20px; }
}
.hero-orb canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}
/* The orb's click reaction is a liquid ripple driven inside its WebGL
   shader (see mountHeroOrb) — no CSS overlay. */

/* Announcement pill at the top of the hero */
.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0 auto 36px;
  padding: 5px 6px 5px 6px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  box-shadow: 0 1px 2px rgba(15,23,42,0.05), 0 4px 12px -6px rgba(15,23,42,0.08);
  font-size: 13px;
  font-weight: 500;
  color: var(--slate-600);
  line-height: 1;
  white-space: nowrap;
  transition: background .25s ease, box-shadow .25s ease, border-color .25s ease;
}
.hero-pill:hover {
  border-color: var(--slate-300);
  box-shadow: 0 6px 18px -6px rgba(15,23,42,0.14);
}
/* "Nyhet" badge — pinned to the left edge, framed in Lucra's brand gradient */
.hero-pill .pill-badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: var(--radius-pill);
  background: var(--brand-gradient);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1;
  box-shadow:
    0 2px 6px -2px rgba(61,80,109,0.45),
    inset 0 1px 0 rgba(255,255,255,0.18);
}
.hero-pill .pill-text {
  color: var(--brand-primary);
  font-weight: 600;
  position: relative;
  display: inline-block;
  overflow: hidden;
  vertical-align: middle;
  line-height: 1;
}
.hero-pill .pill-text .pill-swap {
  display: inline-block;
  will-change: transform, opacity;
}
.hero-pill .pill-text .pill-alt {
  position: absolute;
  inset: 0;
  white-space: nowrap;
}
.hero-pill .pill-text .pill-default {
  animation: pillSwapOut 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
.hero-pill .pill-text .pill-alt {
  animation: pillSwapIn 6s cubic-bezier(.4, 0, .2, 1) infinite;
}
@keyframes pillSwapOut {
  0%, 45%   { transform: translateX(0);     opacity: 1; }
  50%, 95%  { transform: translateX(-110%); opacity: 0; }
  100%      { transform: translateX(0);     opacity: 1; }
}
@keyframes pillSwapIn {
  0%, 45%   { transform: translateX(110%);  opacity: 0; }
  50%, 95%  { transform: translateX(0);     opacity: 1; }
  100%      { transform: translateX(110%);  opacity: 0; }
}
@media (prefers-reduced-motion: reduce) {
  .hero-pill .pill-text .pill-default,
  .hero-pill .pill-text .pill-alt { animation: none; }
  .hero-pill .pill-text .pill-alt { opacity: 0; }
}
.hero-pill .arrow-wrap {
  background: var(--bg-app);
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  transition: background .35s ease;
}
.hero-pill:hover .arrow-wrap { background: var(--bg-active); }
.hero-pill .arrow-wrap svg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12px;
  height: 12px;
  color: var(--brand-primary);
  transform: translate(-50%, -50%);
  transition: transform .45s ease, opacity .3s ease;
}
.hero-pill .arrow-wrap svg.arrow-in {
  transform: translate(-180%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-out {
  transform: translate(80%, -50%);
  opacity: 0;
}
.hero-pill:hover .arrow-wrap svg.arrow-in {
  transform: translate(-50%, -50%);
  opacity: 1;
}

.hero h1 {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(44px, 5.4vw, 70px);
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin: 0 auto 26px;
  padding-bottom: 0.12em;
  max-width: 960px;
  user-select: none;
  -webkit-user-select: none;
  -webkit-tap-highlight-color: transparent;
  cursor: default;
  background:
    radial-gradient(
      circle at var(--mx, 80%) var(--my, 50%),
      var(--brand-accent) 0%,
      #4A6B95 30%,
      var(--brand-primary) 70%
    );
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  transition: --mx 600ms ease-out, --my 600ms ease-out;
}
@property --mx { syntax: '<percentage>'; inherits: true; initial-value: 80%; }
@property --my { syntax: '<percentage>'; inherits: true; initial-value: 50%; }
.hero-sub {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 18px;
  line-height: 1.6;
  color: var(--slate-500);
  max-width: 640px;
  margin: 0 auto 40px;
  text-wrap: pretty;
}
.hero-ctas {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 22px;
}
.hero-ctas .btn {
  font-family: var(--font-body);
  font-weight: 500;
}
/* Tailark-style frame around the primary CTA. On hover the headline's cyan
   races out from the top in BOTH directions and fills the ring fast, then
   snaps back the instant the pointer leaves. (--cta-fill 0→1 drives the arc.) */
@property --cta-fill { syntax: '<number>'; inherits: false; initial-value: 0; }
.cta-frame {
  position: relative;
  --cta-fill: 0;
  background:
    conic-gradient(from -90deg,
      var(--white) 0deg,
      var(--white) calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(var(--cta-fill) * 180deg),
      rgba(255,255,255,0) calc(360deg - var(--cta-fill) * 180deg),
      var(--white) calc(360deg - var(--cta-fill) * 180deg),
      var(--white) 360deg),
    linear-gradient(rgba(61,80,109,0.10), rgba(61,80,109,0.10));
  border: 1px solid rgba(61,80,109,0.14);
  border-radius: 16px;
  padding: 3px;
  display: inline-flex;
  isolation: isolate;
  /* retract is fast (base transition); fill on :hover is slightly longer */
  transition: --cta-fill .18s ease, box-shadow .25s ease, border-color .25s ease;
}
.cta-frame:hover {
  --cta-fill: 1;
  border-color: rgba(203,213,225,0.95);
  box-shadow: 0 6px 18px rgba(61,80,109,0.20), 0 0 0 1px rgba(255,255,255,0.5) inset;
  transition: --cta-fill .34s cubic-bezier(.3,.7,.25,1), box-shadow .25s ease, border-color .25s ease;
}
.cta-frame .btn {
  position: relative;
  z-index: 1;
  border-radius: 13px;
}

/* "Boka demo" — a soft secondary surface so it reads as a button, not a label. */
.hero-ctas .btn-ghost {
  height: 54px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  color: var(--brand-primary);
  box-shadow: 0 1px 2px rgba(15,23,42,0.05);
  overflow: hidden;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease;
}
.hero-ctas .btn-ghost::before {
  /* slate wash that wipes in from the left on hover */
  content: "";
  display: block;
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(90deg, var(--bg-active), rgba(86,179,235,0.10));
  transform: translateX(-101%);
  transition: transform .4s cubic-bezier(.4,0,.2,1);
  opacity: 1;
}
.hero-ctas .btn-ghost .arrow { width: 14px; height: 14px; transition: transform .25s ease; }
.hero-ctas .btn-ghost:hover {
  border-color: var(--brand-primary);
  transform: translateY(-2px);
  box-shadow: 0 12px 24px -10px rgba(61,80,109,0.35);
}
.hero-ctas .btn-ghost:hover::before { transform: translateX(0); }
.hero-ctas .btn-ghost:hover .arrow { transform: translateX(3px); }
@media (prefers-reduced-motion: reduce) {
  .cta-frame { transition: box-shadow .25s ease, border-color .25s ease; }
}

/* ============================================================
   HERO LOAD-INTRO — the orb wakes, fires a "big-bang" burst, and
   the expanding shockwave lights up the hero copy radially.
   Scoped to .hero-inner copy only — the dashboard below is NOT part
   of the intro (it stays put, seen on scroll).
   Without JS / reduced motion the hero is simply visible.
   Rules keyed off html.hero-intro use :global() on the ancestor so the
   scoped child selectors still match (Nav established this convention).
   ============================================================ */
.hero .reveal { opacity: 1; }            /* fallback: always visible */

/* Armed hidden state — only when JS has set html.hero-intro. */
:global(html.hero-intro) .hero-inner > .reveal {
  opacity: 0;
  transform: translateY(20px) scale(.985);
  filter: blur(8px);
  transition:
    opacity .62s var(--ease-out-expo),
    transform .62s var(--ease-out-expo),
    filter .62s var(--ease-out-expo);
  will-change: opacity, transform, filter;
  /* Safety net: reveal even if the JS timeline never fires. */
  animation: heroIntroSafety 1ms linear 3.2s forwards;
}
/* The orb leads and fades in via its own shader (uIntro); keep its box steady. */
:global(html.hero-intro) #hero-orb {
  opacity: 1;
  transform: none;
  filter: none;
  animation: none;
}
/* Powered-on — JS adds .lucra-lit as the shockwave reaches each block. */
:global(html.hero-intro) .hero-inner > .reveal.lucra-lit {
  opacity: 1;
  transform: none;
  filter: blur(0);
}

@media (prefers-reduced-motion: reduce) {
  .typing-dot { animation: none; }
  .hero .reveal { opacity: 1; animation: none; }
}

/* ============================================================
   RESPONSIVE (hero subset)
   ============================================================ */
@media (max-width: 960px) {
  .hero { padding-top: calc(120px + env(safe-area-inset-top)); }
}
/* The hero orb never mounts below 720px (OrbIsland gate); drop its reserved
   space so the hero doesn't open with an empty gap above the pill. */
@media (max-width: 720px) {
  .hero-orb { display: none; }
}
/* Compact mobile hero: tighten every gap so the headline, sub, CTA AND the top
   of the demo window are all visible in the first viewport (no tall dead space
   before the demo). */
@media (max-width: 640px) {
  .hero {
    padding-top: calc(92px + env(safe-area-inset-top));
    padding-bottom: 48px;
    /* Lead the hero with the app-shell tone at the very top so the area behind
       the notch (which shares this background) matches the hero instead of being
       a white strip; fades to the usual white within the first 240px. */
    background:
      radial-gradient(circle at 50% 0%, rgba(86,179,235,0.10), transparent 55%),
      linear-gradient(180deg, var(--bg-app) 0%, var(--bg-paper) 240px);
  }
  .hero-pill { font-size: 12px; padding-left: 5px; margin-bottom: 18px; }
  .hero h1 { font-size: clamp(33px, 9vw, 44px); margin-bottom: 14px; }
  .hero-sub { font-size: 15px; margin-bottom: 22px; }
  .hero-ctas { margin-bottom: 0; }
  /* The nav already carries "Boka demo" on phones — one CTA is enough here. */
  .hero-ctas .btn-ghost { display: none; }
}
</style>

<script>
  (function() {
    // ============================================================
    // Hero load-intro orchestrator
    //   nav fades in → orb grows in → orb pulse (+ dots burst) →
    //   circuit traces draw down from the orb and "power on" each
    //   block as the head reaches it → traces fade out. Clean hero.
    // Gated by html.hero-intro (set pre-paint, skipped for reduced motion).
    // The orb / fog hooks (window.lucraOrbIntro / lucraOrbPulse / lucraFogIntro)
    // are provided by the Orb island and Particles island;
    // every call is optionally guarded so the cascade still runs without them.
    // ============================================================
    var root = document.documentElement;
    if (!root.classList.contains('hero-intro')) return;

    var hero = document.querySelector('.hero');
    if (!hero) { root.classList.remove('hero-intro'); return; }
    var heroEl = hero;

    // Ordered hero-copy targets (relative to .hero-inner) — lit radially by the
    // shockwave. The dashboard is intentionally excluded (stays put / on scroll).
    var SELECTORS = ['.hero-pill', 'h1', '.hero-sub', '.hero-ctas'];
    var w = window as any;

    function revealAll() {
      var els = heroEl.querySelectorAll('.hero-inner > .reveal');
      for (var i = 0; i < els.length; i++) els[i].classList.add('lucra-lit');
    }

    // After the pulse, the copy simply rises + fades in, in order — a gentle
    // stagger radiating down from the orb. No flourishes.
    function cascadeReveal() {
      var els: Element[] = [];
      SELECTORS.forEach(function (sel) { var el = heroEl.querySelector(sel); if (el) els.push(el); });
      if (!els.length) { revealAll(); return; }
      els.forEach(function (el, i) {
        // Tapered cascade — first blocks lead, later ones follow faster.
        var d = i < 2 ? i * 90 : 180 + (i - 2) * 65;
        setTimeout(function () { el.classList.add('lucra-lit'); }, d);
      });
    }

    function run() {
      root.classList.add('nav-in');                                  // nav fades in
      setTimeout(function () { if (w.lucraOrbIntro) w.lucraOrbIntro(); }, 120);  // orb grows + pops in
      setTimeout(function () {                                       // a beat later — the pulse
        if (w.lucraOrbPulse) w.lucraOrbPulse();
        if (w.lucraFogIntro) w.lucraFogIntro();                     // dots burst in with the pulse
      }, 1020);
      setTimeout(cascadeReveal, 1180);                               // then the copy rises in
      setTimeout(revealAll, 2900);                                   // watchdog
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

  (function() {
    // Hero headline cursor spotlight — cyan peak in the accent gradient follows the pointer.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var h1 = document.querySelector('.hero h1') as HTMLElement | null;
    if (!h1) return;
    var h1El = h1;
    var raf = 0;
    var onMove = function(e: PointerEvent) {
      if (raf) return;
      raf = requestAnimationFrame(function() {
        raf = 0;
        var r = h1El.getBoundingClientRect();
        var x = ((e.clientX - r.left) / r.width) * 100;
        var y = ((e.clientY - r.top) / r.height) * 100;
        h1El.style.setProperty('--mx', Math.max(0, Math.min(100, x)) + '%');
        h1El.style.setProperty('--my', Math.max(0, Math.min(100, y)) + '%');
      });
    };
    h1El.addEventListener('pointermove', onMove);
  })();
</script>

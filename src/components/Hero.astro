}
@keyframes blink {
  0%, 80%, 100% { opacity: .2; }
  40% { opacity: 1; }
}

/* ============================================================
   DEMO TABS (scroll-reveal, auto-rotate) + macOS browser chrome
   ============================================================ */
.hero-chrome-wrap { position: relative; }

/* macOS window — clean slate canvas, traffic-light dots, soft deep shadow */
.browser-chrome {
  background: var(--bg-app);
  border: 1px solid rgba(226,232,240,.9);
  border-radius: var(--radius-shell);
  overflow: hidden;
  box-shadow:
    0 1px 1px rgba(15,23,42,.04),
    0 30px 60px -20px rgba(61,80,109,.18),
    0 60px 120px -40px rgba(15,23,42,.18);
}
.browser-bar {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 17px 20px 13px;
  background: transparent;
}
.browser-bar .dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  display: inline-block;
  box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.12);
}
.browser-bar .dot.red    { background: #FF5F57; }
.browser-bar .dot.yellow { background: #FEBC2E; }
.browser-bar .dot.green  { background: #28C840; }
/* Product shell sits inside browser chrome — drop its standalone shadow */
.browser-chrome .product-shell {
  border: 0;
  border-radius: 0;
  box-shadow: none;
  padding: 0;
}
.browser-chrome .product-shell-inner {
  margin: 16px;
}
.demo-tabs {
  position: absolute;
  top: -22px;
  left: 50%;
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 5px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: 0 12px 32px -10px rgba(15,23,42,.18), 0 2px 4px rgba(15,23,42,.04);
  z-index: 12;

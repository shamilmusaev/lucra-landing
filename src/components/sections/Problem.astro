---
import { getStrings, type Lang } from '../../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<section id="problem">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-eyebrow">{s.problemEyebrow}</span>
      <h2 class="section-title">{s.problemTitle}</h2>
      <p class="section-sub">
        {s.problemSub}
      </p>
    </div>

    <div class="problem-grid">
      <!-- Card 1 — Osäkerhet -->
      <article class="problem-card reveal delay-1">
        <div class="problem-visual" aria-hidden="true">
          <img class="problem-shot" src="/assets/premium/problem-osakerhet.png" alt="" loading="lazy" decoding="async" />
        </div>
        <div class="problem-body">
          <span class="problem-eyebrow">{s.problemCard1Eyebrow}</span>
          <h3>{s.problemCard1Title}</h3>
          <p>{s.problemCard1Body}</p>
          <a class="problem-pill" href="#funktioner">
            {s.problemCard1Cta}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>

      <!-- Card 2 — Byrån -->
      <article class="problem-card reveal delay-2">
        <div class="problem-visual" aria-hidden="true">
          <img class="problem-shot" src="/assets/premium/problem-byran.png" alt="" loading="lazy" decoding="async" />
        </div>
        <div class="problem-body">
          <span class="problem-eyebrow">{s.problemCard2Eyebrow}</span>
          <h3>{s.problemCard2Title}</h3>
          <p>{s.problemCard2Body}</p>
          <a class="problem-pill" href="#funktioner">
            {s.problemCard2Cta}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>

      <!-- Card 3 — Tiden -->
      <article class="problem-card reveal delay-3">
        <div class="problem-visual" aria-hidden="true">
          <img class="problem-shot" src="/assets/premium/problem-tiden.png" alt="" loading="lazy" decoding="async" />
        </div>
        <div class="problem-body">
          <span class="problem-eyebrow">{s.problemCard3Eyebrow}</span>
          <h3>{s.problemCard3Title}</h3>
          <p>{s.problemCard3Body}</p>
          <a class="problem-pill" href="#funktioner">
            {s.problemCard3Cta}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
#problem {
  /* Hero already leaves generous space below the floating window, so trim the
     section's own top padding to keep the seam balanced rather than cavernous. */
  padding-top: 40px;
  background:
    radial-gradient(120% 80% at 50% 0%, rgba(86,179,235,0.06), transparent 60%),
    linear-gradient(180deg, #F8FAFC 0%, var(--bg-paper) 72%);
}
.problem-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.problem-card {
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow:
    0 1px 2px rgba(15,23,42,.04),
    0 14px 30px -20px rgba(61,80,109,.20);
  transition: border-color .3s ease, transform .3s ease, box-shadow .3s ease;
}
.problem-card:hover {
  border-color: var(--slate-300);
  transform: translateY(-6px);
  box-shadow:
    0 1px 2px rgba(15,23,42,.05),
    0 30px 60px -24px rgba(61,80,109,.32);
}
/* Visual zone — full-bleed generated product mockup */
.problem-visual {
  position: relative;
  aspect-ratio: 3 / 2;
  overflow: hidden;
  background:
    radial-gradient(circle at 30% 20%, rgba(86,179,235,0.10), transparent 60%),
    linear-gradient(180deg, var(--bg-app), #F8FAFC);
  border-bottom: 1px solid var(--border);
}
.problem-shot {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transform: scale(1.01);
  transition: transform .55s cubic-bezier(.4,0,.2,1);
}
.problem-card:hover .problem-shot { transform: scale(1.05); }
/* Soft fade so the mockup melts into the card body */
.problem-visual::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 80%, var(--bg-paper) 100%);
  pointer-events: none;
}
.problem-body {
  padding: 26px 26px 26px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}
.problem-eyebrow {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--brand-primary);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.problem-card h3 {
  font-family: 'General Sans', var(--font-display);
  font-size: 22px;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.25;
  color: var(--brand-primary);
  margin: 0;
}
.problem-card p {
  font-size: 14.5px;
  color: var(--slate-500);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}
.problem-pill {
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  background: var(--bg-app);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--brand-primary);
  margin-top: 8px;
  transition: background .2s ease, border-color .2s ease;
}
.problem-pill:hover {
  background: var(--bg-active);
  border-color: var(--slate-300);
}
.problem-pill svg { width: 12px; height: 12px; transition: transform .2s ease; }
.problem-pill:hover svg { transform: translateX(3px); }

@media (prefers-reduced-motion: reduce) {
  .problem-shot { transition: none; }
  .problem-card:hover .problem-shot { transform: scale(1.01); }
}
@media (max-width: 960px) {
  .problem-grid { grid-template-columns: 1fr; }
}
</style>

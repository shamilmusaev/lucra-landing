---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import ParticleField from '../ParticleField.astro';
import { BOOK_DEMO_URL } from '../../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

const pilotFeats = [
  s.priPilotFeat1,
  s.priPilotFeat2,
  s.priPilotFeat3,
  s.priPilotFeat4,
  s.priPilotFeat5,
  s.priPilotFeat6,
];
const partnerFeats = [
  s.priPartnerFeat1,
  s.priPartnerFeat2,
  s.priPartnerFeat3,
  s.priPartnerFeat4,
  s.priPartnerFeat5,
  s.priPartnerFeat6,
  s.priPartnerFeat7,
];
---

<section id="upplagg">
  <ParticleField
    mask="radial-gradient(ellipse 100% 80% at 50% 46%, #000 0%, #000 48%, transparent 90%)"
  />
  <div class="container">
    <div class="section-head center reveal">
      <h2 class="section-title">{s.priTitle}</h2>
      <p class="section-sub">{s.priSub}</p>
    </div>

    <!-- Phone-only segmented switch: one plan at a time (mirrors ForVem). JS arms
         data-up-active; without JS both plans stay visible and the switch hidden. -->
    <div class="up-switch">
      <button class="up-switch-btn is-active" type="button" aria-pressed="true" aria-controls="pilot" data-up-switch="0">{s.priPilotName}</button>
      <button class="up-switch-btn" type="button" aria-pressed="false" aria-controls="partner" data-up-switch="1">{s.priPartnerName}</button>
    </div>

    <div class="plans" data-scrollfx>
      <!-- Pilot — recommended, highlighted card -->
      <article id="pilot" class="plan plan-featured reveal">
        <div class="plan-tag"><span class="section-eyebrow">{s.priPilotBadge}</span></div>
        <h3 class="plan-name">{s.priPilotName}</h3>
        <p class="plan-desc">{s.priPilotDesc}</p>
        <span class="plan-incl">{s.priInclLabel}</span>
        <ul class="plan-feats">
          {pilotFeats.map((feat) => (
            <li>
              <span class="feat-ic" aria-hidden="true">
                <Icon name="check" />
              </span>
              <span>{feat}</span>
            </li>
          ))}
        </ul>
        <a class="btn btn-primary btn-lg plan-cta" href={BOOK_DEMO_URL} target="_blank" rel="noopener">
          {s.priPilotCta}
          <Icon name="arrow-right" class="arrow" />
        </a>
      </article>

      <!-- Partner -->
      <article id="partner" class="plan reveal delay-1">
        <div class="plan-tag"></div>
        <h3 class="plan-name">{s.priPartnerName}</h3>
        <p class="plan-desc">{s.priPartnerDesc}</p>
        <span class="plan-incl">{s.priInclLabel}</span>
        <ul class="plan-feats">
          {partnerFeats.map((feat) => (
            <li>
              <span class="feat-ic" aria-hidden="true">
                <Icon name="check" />
              </span>
              <span>{feat}</span>
            </li>
          ))}
        </ul>
        <a class="btn btn-outlined btn-lg plan-cta" href={BOOK_DEMO_URL} target="_blank" rel="noopener">
          {s.priPartnerCta}
          <Icon name="arrow-right" class="arrow" />
        </a>
      </article>
    </div>

    <p class="plan-footnote reveal delay-2">{s.priFootnote}</p>
  </div>
</section>

<style>
/* Clear the fixed nav when deep-linked from the Priser menu */
#pilot, #partner { scroll-margin-top: 96px; }
#upplagg {
  position: relative;
  background: var(--bg-paper);
  /* The cards spread out horizontally on scroll-in — clip the overhang so it
     never produces a horizontal scrollbar. */
  overflow-x: clip;
}
/* Content sits above the cursor-reactive dot field. */
#upplagg > .container { position: relative; z-index: 1; }

.section-head.center { margin-bottom: 56px; }

.plans {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  max-width: 1040px;
  margin: 0 auto;
  align-items: stretch;
}

/* ============================================================
   Plan card — single light surface; CTA pinned to the bottom so
   both cards' buttons align regardless of feature count.
   ============================================================ */
.plan {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 36px 34px;
  border-radius: var(--radius-card);
  /* Frosted glass: the cursor-reactive dot field stays visible through the card,
     softened — matches the comparison table in Jamforelse. */
  background: color-mix(in srgb, var(--bg-paper) 1%, transparent);
  -webkit-backdrop-filter: blur(6px);
          backdrop-filter: blur(2px);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-soft);
  transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
}
.plan:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-soft-hover);
}

/* Featured (Pilot): brand border + soft brand glow (no bright fill). */
.plan-featured {
  border-color: color-mix(in srgb, var(--brand-primary) 40%, transparent);
  box-shadow:
    var(--shadow-pop),
    0 40px 90px -52px color-mix(in srgb, var(--brand-primary) 45%, transparent);
}
.plan-featured:hover {
  box-shadow:
    var(--shadow-pop),
    0 56px 110px -52px color-mix(in srgb, var(--brand-primary) 52%, transparent);
}

/* Tag row — reserved on both cards so the plan names line up. */
.plan-tag { min-height: 30px; margin-bottom: 18px; }

/* "Rekommenderat" as a folder tab perched on the card's top-left corner — echoes
   the Siffror/Frågor tabs in För vem. The reserved .plan-tag height above keeps
   the Pilot/Partner names aligned; the tab itself is lifted onto the corner. */
.plan-featured { overflow: hidden; }
.plan-featured .plan-tag .section-eyebrow {
  position: absolute;
  top: 0;
  left: 0;
  margin: 0;
  border: 0;
  border-radius: var(--radius-card) 8px 8px 0;
  background: var(--brand-primary);
  color: var(--white);
  padding: 9px 18px;
}
.plan-featured .plan-tag .section-eyebrow::before { background: var(--white); }
.plan-name {
  font-family: var(--font-display);
  font-size: 32px;
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--brand-primary);
  margin: 0 0 12px;
}
.plan-desc {
  font-size: 15px;
  line-height: 1.62;
  color: var(--slate-500);
  margin: 0 0 24px;
  text-wrap: pretty;
}

/* Divider into "what's included". */
.plan-incl {
  display: block;
  padding-top: 22px;
  border-top: 1px solid var(--border);
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--slate-400);
  margin-bottom: 16px;
}
.plan-featured .plan-incl {
  border-top-color: color-mix(in srgb, var(--brand-primary) 14%, transparent);
}

.plan-feats {
  list-style: none;
  margin: 0 0 28px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 13px;
}
.plan-feats li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: var(--text-md);
  line-height: 1.45;
  color: var(--slate-600);
}

/* Ticks — muted slate-blue, consistent on both cards (no bright cyan). */
.feat-ic {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  margin-top: 1px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: color-mix(in srgb, var(--brand-primary) 9%, var(--bg-paper));
  color: var(--brand-primary);
}
.feat-ic svg { width: 12px; height: 12px; }
/* Featured ticks: solid brand fill — subtle emphasis, still muted. */
.plan-featured .feat-ic {
  background: var(--brand-primary);
  color: var(--white);
  box-shadow: inset 0 1px 0 color-mix(in srgb, var(--white) 22%, transparent);
}

/* CTA pinned to the bottom so both cards' buttons align. */
.plan-cta {
  margin-top: auto;
  width: 100%;
  height: 50px;
}

.plan-footnote {
  max-width: 640px;
  margin: 36px auto 0;
  text-align: center;
  font-size: var(--text-lg);
  line-height: 1.6;
  color: var(--slate-500);
  text-wrap: pretty;
  /* Contained bubble — paired with Jamforelse's .cmp-note so both closing notes
     read as the same kind of callout, not stray lines on the dot field. */
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
  padding: 20px 28px;
}

/* Section reveal: cards slide in from opposite sides (mirrors #for-vem). */
:global(html.reveal-ready) #upplagg .plan.reveal         { transform: translate(-32px, 18px); }
:global(html.reveal-ready) #upplagg .plan.reveal.delay-1 { transform: translate( 32px, 18px); }
:global(html.reveal-ready) #upplagg .plan.reveal.in-view { transform: none; }

/* ---- Scroll-linked signature: the two plans start spread wide apart and glide
   together as the section approaches centre. Driven by --p (ScrollFx) via the
   individual translate prop so it composes with reveal + hover. ----
   --q: 0 below the fold → 1 at centre (cards fully converged), then held. */
.plans { --q: clamp(0, calc(var(--p, 0.5) * 2), 1); }
.plans .plan-featured            { translate: calc(-80px * (1 - var(--q))) 0; will-change: translate; }
.plans .plan:not(.plan-featured) { translate: calc( 80px * (1 - var(--q))) 0; will-change: translate; }
@media (prefers-reduced-motion: reduce) {
  .plans .plan-featured,
  .plans .plan:not(.plan-featured) { translate: none; }
}

@media (max-width: 860px) {
  .plans { grid-template-columns: 1fr; }
  .plan { padding: 30px 26px; }
  .plan-name { font-size: 22px; }
  .plan:not(.plan-featured) .plan-tag { display: none; }
  /* Single column — horizontal convergence makes no sense, so hold the cards. */
  .plans .plan-featured,
  .plans .plan:not(.plan-featured) { translate: none; will-change: auto; }
  /* Clear paper bubble — mirrors the mobile .cmp-note in Jamforelse. slate-600
     (not the base slate-400) clears the 4.5:1 contrast floor at this size. */
  .plan-footnote {
    max-width: none;
    margin-top: 24px;
    padding: 16px 18px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    font-size: var(--text-sm);
    text-align: left;
    color: var(--slate-600);
  }
}

/* Touch: the dot field behind the cards is static (canvas off), so drop the
   per-element backdrop-filter and use a solid card surface. */
@media (hover: none) and (pointer: coarse) {
  .plan {
    background: var(--bg-paper);
    -webkit-backdrop-filter: none;
            backdrop-filter: none;
  }
}

/* Hidden on desktop; shown on phones once JS arms data-up-active. */
.up-switch { display: none; }

@media (max-width: 860px) {
  #upplagg[data-up-active] .up-switch {
    display: flex;
    gap: 4px;
    padding: 4px;
    margin: 0 auto 28px;
    background: var(--bg-app);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    width: fit-content;
  }
  .up-switch-btn {
    border: 0;
    background: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--slate-600);
    padding: 10px 18px;
    border-radius: var(--radius-pill);
  }
  .up-switch-btn.is-active {
    background: var(--bg-paper);
    color: var(--brand-primary);
    box-shadow: var(--shadow-sm);
  }
  /* One plan at a time. */
  #upplagg[data-up-active="0"] #partner { display: none; }
  #upplagg[data-up-active="1"] #pilot { display: none; }
}
</style>

<script>
  // Phone-only plan switch: arming data-up-active reveals the segmented control
  // and shows one plan at a time (see the ≤860px CSS). Priser-menu deep links
  // (#pilot / #partner) select the matching plan.
  const section = document.getElementById('upplagg');
  const buttons = section
    ? Array.from(section.querySelectorAll<HTMLButtonElement>('.up-switch-btn'))
    : [];
  const plans = ['pilot', 'partner'];
  if (section && buttons.length === plans.length) {
    const activate = (index: number): void => {
      section.dataset.upActive = String(index);
      buttons.forEach((button, buttonIndex) => {
        button.classList.toggle('is-active', buttonIndex === index);
        button.setAttribute('aria-pressed', buttonIndex === index ? 'true' : 'false');
      });
    };
    activate(0);
    buttons.forEach((button, index) => {
      button.addEventListener('click', () => activate(index));
    });
    const applyHash = (): void => {
      const index = plans.indexOf(location.hash.replace('#', ''));
      if (index < 0) return;
      activate(index);
      requestAnimationFrame(() => document.getElementById(plans[index])?.scrollIntoView());
    };
    window.addEventListener('hashchange', applyHash);
    if (location.hash) applyHash();
  }
</script>

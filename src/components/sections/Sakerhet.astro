---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<section id="sakerhet" class="tone-slate">
  <div class="container">
    <div class="security" data-scrollfx>
      <div class="sec-head reveal">
        <h2 class="section-title">{s.sakerhetTitle}</h2>
        <p class="section-sub">
          {s.sakerhetSub}
        </p>
      </div>
      <div class="sec-list">
        <div class="sec-item reveal">
          <div class="sec-icon">
            <Icon name="shield-check" />
          </div>
          <div>
            <h3>{s.sakerhetCard1Title}</h3>
            <p>{s.sakerhetCard1Body}</p>
          </div>
        </div>
        <div class="sec-item reveal delay-1">
          <div class="sec-icon">
            <Icon name="lock" />
          </div>
          <div>
            <h3>{s.sakerhetCard2Title}</h3>
            <p>{s.sakerhetCard2Body}</p>
          </div>
        </div>
        <div class="sec-item reveal delay-2">
          <div class="sec-icon">
            <Icon name="globe" />
          </div>
          <div>
            <h3>{s.sakerhetCard3Title}</h3>
            <p>{s.sakerhetCard3Body}</p>
          </div>
        </div>
        <div class="sec-item reveal delay-3">
          <div class="sec-icon">
            <Icon name="key-round" />
          </div>
          <div>
            <h3>{s.sakerhetCard4Title}</h3>
            <p>{s.sakerhetCard4Body}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.security {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 64px;
  align-items: start;
}

.sec-head {
  position: sticky;
  top: 120px;
}

.sec-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.sec-item {
  display: flex;
  align-items: flex-start;
  gap: 18px;
  padding: 22px 24px;
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
  transition: border-color .2s, transform .2s, box-shadow .2s;
}

.sec-item:hover {
  border-color: var(--slate-300);
  transform: translateY(-2px);
  box-shadow: var(--shadow-soft-hover);
}

.sec-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: linear-gradient(150deg, var(--white), var(--accent-light));
  border: 1px solid color-mix(in srgb, var(--brand-primary) 10%, transparent);
  box-shadow: 0 1px 2px rgba(15, 23, 42, .05), inset 0 1px 0 rgba(255, 255, 255, .7);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--brand-primary);
}

.sec-icon svg {
  width: 22px;
  height: 22px;
}

.sec-item h3 {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  /* Pin the old h4 line-height (global h3 is 1.3) so the tag swap to h3 for
     heading-order doesn't reflow these cards on desktop. */
  line-height: 1.4;
  color: var(--brand-primary);
  margin: 0 0 6px;
}

.sec-item p {
  font-size: 14px;
  color: var(--slate-500);
  margin: 0;
  line-height: 1.55;
}

/* ---- Scroll-linked signature: the sticky heading holds while the card list
   eases into focus — a gentle zoom (--q) plus a slow parallax drift (--r) that
   reads as depth against the pinned head. Driven by --p (ScrollFx). The effect
   lives on .sec-list (a sibling), never on an ancestor of the sticky head, so
   position: sticky stays intact. ---- */
.security {
  --q: clamp(0, calc(var(--p, 0.5) * 2), 1);
  --r: calc(var(--p, 0.5) - 0.5);
}
.security .sec-list {
  translate: 0 calc(-40px * var(--r));
  scale: calc(0.93 + 0.07 * var(--q));
  transform-origin: center top;
  will-change: translate, scale;
}
@media (prefers-reduced-motion: reduce) {
  .security .sec-list { translate: none; scale: none; }
}

@media (max-width: 960px) {
  .security {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .sec-head {
    position: static;
    top: auto;
  }
  /* No scroll-linked zoom/parallax on phones: mid-scroll the shrunken list
     reads as misaligned against the heading. (will-change already auto.) */
  .security .sec-list { translate: none; scale: none; will-change: auto; }
}

/* Phones: one compact row per card — icon and title share the first line and
   the body spans the full card width below (the anonymous text wrapper is
   flattened with display:contents so h3/p become grid items). Avoids both old
   failure modes: tall 1-col cards (body no longer sits beside the icon) and
   the cramped 2×2 grid. */
@media (max-width: 640px) {
  .sec-list { gap: 12px; }
  .sec-item {
    display: grid;
    grid-template-columns: 34px 1fr;
    column-gap: 12px;
    row-gap: 8px;
    align-items: center;
    padding: 18px 16px;
  }
  .sec-item > div:not(.sec-icon) { display: contents; }
  .sec-icon { width: 34px; height: 34px; border-radius: 10px; }
  .sec-icon svg { width: 18px; height: 18px; }
  .sec-item h3 { font-size: 15px; margin-bottom: 0; }
  .sec-item p { grid-column: 1 / -1; font-size: 13px; line-height: 1.5; }
}
</style>

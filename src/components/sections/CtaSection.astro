---
// CtaSection — the final call-to-action, now doubling as the contact section.
// Layers here:
//   • the shared dot-field (<ParticleField>) as a calm background fog,
//   • a small WebGL orb (`#cta-orb`) reusing the shared `mountOrb` module, and
//   • the contact form (Netlify) + a "book a demo" card that opens Calendly.
// Both graphics are lazy (IntersectionObserver + reduced-motion guarded).
// The form posts to the language-specific /tack confirmation page; Netlify
// detects it at deploy from the static HTML (no server runtime needed).
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import ParticleField from '../ParticleField.astro';
import CalendlyPopup from '../CalendlyPopup.astro';
import { CALENDLY_URL } from '../../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

// Netlify redirects here after a successful submit; keep it language-aware.
const tackPath = lang === 'en' ? '/en/tack' : '/tack';
---

<section class="cta-section">
  <div class="container">
    <div class="cta-panel tone-deep reveal">
      <ParticleField
        dotColor="255, 255, 255"
        dotAlpha={0.3}
      />
      <div class="cta-inner">
        <span class="cta-orb" id="cta-orb" aria-hidden="true"></span>
        <h2 class="section-title">{s.ctaTitle}</h2>
        <p class="section-sub">{s.ctaBody}</p>

        <div class="cta-grid">
          <!-- Contact form — outer shell + inner core (nested "machined" card) -->
          <div class="form-shell reveal delay-1">
            <form
              class="kontakt-form"
              name="kontakt"
              method="POST"
              action={tackPath}
              data-netlify="true"
              netlify-honeypot="bot-field"
            >
              <input type="hidden" name="form-name" value="kontakt" />
              <p class="hp" hidden>
                <label>Lämna detta fält tomt: <input name="bot-field" /></label>
              </p>

              <div class="field-row">
                <div class="field">
                  <label for="namn">{s.formName}</label>
                  <input id="namn" name="namn" type="text" required autocomplete="name" />
                </div>
                <div class="field">
                  <label for="epost">{s.formEmail}</label>
                  <input id="epost" name="epost" type="email" required autocomplete="email" />
                </div>
              </div>

              <div class="field-row">
                <div class="field">
                  <label for="foretag">{s.formCompany} <span class="opt">({s.formCompanyOptional})</span></label>
                  <input id="foretag" name="foretag" type="text" autocomplete="organization" />
                </div>
                <div class="field">
                  <label for="roll">{s.formRole}</label>
                  <div class="select-wrap">
                    <select id="roll" name="roll">
                      <option value={s.formRoleBusiness}>{s.formRoleBusiness}</option>
                      <option value={s.formRoleAgency}>{s.formRoleAgency}</option>
                    </select>
                    <Icon name="chevron-down" class="select-caret" size={16} stroke={1.7} />
                  </div>
                </div>
              </div>

              <div class="field">
                <label for="meddelande">{s.formMessage}</label>
                <textarea id="meddelande" name="meddelande" rows="4" required placeholder={s.formMessagePlaceholder}></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-lg form-submit">
                {s.formSubmit}
                <span class="btn-pip"><Icon name="arrow-right" size={15} /></span>
              </button>
            </form>
          </div>

          <!-- Book-a-demo card — opens Calendly popup on click -->
          <aside class="demo-shell reveal delay-2">
            <div class="demo-core">
              <h3 class="demo-title">{s.kontaktDemoTitle}</h3>
              <p class="demo-body">{s.kontaktDemoBody}</p>
              <a class="btn btn-outlined btn-lg demo-cta" href={CALENDLY_URL} data-calendly>
                {s.ctaBookDemo}
                <span class="btn-pip"><Icon name="arrow-right" size={15} /></span>
              </a>
              <a class="demo-secondary" href="https://app.staging.lucra-app.ai" target="_blank" rel="noopener">
                {s.ctaTryLucra}
                <Icon name="arrow-right" class="arrow" size={14} />
              </a>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <CalendlyPopup />
  </div>
</section>

<style>
  .cta-panel {
    border-radius: var(--radius-shell);
    padding: 80px 56px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-panel::before {
    content: "";
    position: absolute;
    top: -100px; right: -120px;
    width: 380px; height: 380px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--brand-accent) 18%, transparent);
    filter: blur(80px);
  }
  .cta-panel::after {
    content: "";
    position: absolute;
    bottom: -120px; left: -80px;
    width: 360px; height: 360px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--brand-primary) 60%, transparent);
    filter: blur(100px);
  }
  .cta-inner { position: relative; z-index: 1; }

  /* WebGL orb — CTA centrepiece (same shader as the hero orb). */
  .cta-orb {
    display: block;
    width: 108px;
    height: 108px;
    margin: 0 auto 24px;
    position: relative;
    pointer-events: auto;   /* clickable: tap to ripple */
    cursor: pointer;
  }
  .cta-orb canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* Centre the shared section title/sub inside the panel. */
  .cta-panel .section-title {
    margin: 0 auto 16px;
    max-width: 720px;
  }
  .cta-panel .section-sub {
    margin: 0 auto;
    max-width: 560px;
  }

  /* ---- Form + demo grid ---- */
  .cta-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 20px;
    align-items: stretch;
    text-align: left;
    max-width: 1000px;
    margin: 48px auto 0;
  }

  /* ---- Double-bezel: outer shell holds the machined inner core ---- */
  .form-shell,
  .demo-shell {
    padding: 8px;
    border-radius: calc(var(--radius-card) + 8px);
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .10);
  }

  .kontakt-form,
  .demo-core {
    border-radius: var(--radius-card);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .08);
  }

  .kontakt-form {
    background: rgba(255, 255, 255, .03);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .hp { position: absolute; left: -9999px; }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, .78);
  }
  .field .opt {
    font-weight: 400;
    color: rgba(255, 255, 255, .45);
    font-size: 12px;
  }
  .field input,
  .field textarea,
  .field select {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--white);
    background: rgba(255, 255, 255, .05);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1),
                box-shadow .25s cubic-bezier(.32, .72, 0, 1),
                background .25s cubic-bezier(.32, .72, 0, 1);
  }
  .field textarea { resize: vertical; min-height: 104px; line-height: 1.6; }
  .field input::placeholder,
  .field textarea::placeholder { color: rgba(255, 255, 255, .38); }
  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: none;
    background: rgba(255, 255, 255, .08);
    border-color: var(--brand-accent);
    box-shadow: 0 0 0 3px rgba(86, 179, 235, .22);
  }

  .select-wrap { position: relative; }
  .field select {
    appearance: none;
    padding-right: 40px;
    cursor: pointer;
    color: var(--white);
  }
  /* Native dropdown options render on an OS surface — keep them dark-on-light. */
  .field select option { color: var(--brand-primary-dark); }
  .select-caret {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, .55);
    pointer-events: none;
  }

  .form-submit { align-self: flex-start; margin-top: 4px; }

  /* ---- Button-in-button trailing icon (nested circular pip) ---- */
  .btn-pip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    margin-left: 2px;
    margin-right: -8px;
    border-radius: var(--radius-pill);
    transition: transform .35s cubic-bezier(.32, .72, 0, 1);
  }
  .form-submit .btn-pip { background: color-mix(in srgb, var(--brand-primary-dark) 14%, transparent); }
  .demo-cta .btn-pip { background: rgba(255, 255, 255, .10); }
  .btn:hover .btn-pip { transform: translateX(3px); }

  /* ---- Demo card ---- */
  .demo-core {
    background:
      radial-gradient(120% 90% at 15% 0%, rgba(86, 179, 235, .16), transparent 62%),
      rgba(255, 255, 255, .03);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
  }
  .demo-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 21px;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0;
  }
  .demo-body {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, .68);
    margin: 0 0 4px;
  }
  .demo-cta {
    align-self: flex-start;
    background: transparent;
    color: var(--white);
    border-color: rgba(255, 255, 255, .28);
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1),
                background .25s cubic-bezier(.32, .72, 0, 1);
  }
  .demo-cta:hover {
    border-color: rgba(255, 255, 255, .6);
    background: rgba(255, 255, 255, .06);
  }
  .demo-secondary {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, .62);
    transition: color .25s cubic-bezier(.32, .72, 0, 1);
  }
  .demo-secondary:hover { color: var(--white); }
  .demo-secondary .arrow { transition: transform .25s cubic-bezier(.32, .72, 0, 1); }
  .demo-secondary:hover .arrow { transform: translateX(3px); }

  @media (max-width: 880px) {
    .cta-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .cta-orb { width: 92px; height: 92px; }
  }
  @media (max-width: 560px) {
    .cta-panel { padding: 56px 24px; }
    .field-row { grid-template-columns: 1fr; }
    .kontakt-form,
    .demo-core { padding: 24px; }
  }
</style>

<script>
  // ── CTA WebGL orb (shared module; mounted with no global coupling) ──────────
  import { mountOrb } from '../../scripts/orb';

  // Lazy orb init — same pattern as the hero orb (OrbIsland), but with
  // { intro: false, registerGlobalPulse: false }: the CTA orb does NOT arm a
  // load-intro and does NOT register the global lucraOrbIntro/Pulse hooks. It
  // ripples on direct click only. IntersectionObserver (200px rootMargin)
  // defers mounting until the user scrolls near this far-down section.
  const orbEl = document.getElementById('cta-orb');
  if (orbEl && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ric: (cb: () => void) => void =
      (window as any).requestIdleCallback
        ? (cb) => (window as any).requestIdleCallback(cb)
        : (cb) => { setTimeout(cb, 1); };
    const start = (): void => ric(() => mountOrb('cta-orb', { intro: false, registerGlobalPulse: false }));
    const io = new IntersectionObserver((entries, obs) => {
      if (entries.some((entry) => entry.isIntersecting)) {
        obs.disconnect();
        start();
      }
    }, { rootMargin: '200px' });
    io.observe(orbEl);
  }
</script>

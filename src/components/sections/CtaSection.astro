---
// CtaSection — the final call-to-action, doubling as the contact section.
// Editorial split: left = "book a demo" lead (title, contact, Calendly CTA),
// right = the Netlify contact form. The dark panel scales up slightly as it
// scrolls into view (continuous scroll-zoom, mirroring the product demo feel).
// The form posts to the language-specific /tack confirmation page; Netlify
// detects it at deploy from the static HTML (no server runtime needed).
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import CalendlyPopup from '../CalendlyPopup.astro';
import { CALENDLY_URL, CONTACT_EMAIL } from '../../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

// Netlify redirects here after a successful submit; keep it language-aware.
const tackPath = lang === 'en' ? '/en/tack' : '/tack';
---

<section class="cta-section">
  <div class="container">
    <div class="cta-panel tone-deep">
      <div class="cta-grid">
        <!-- Lead: title + contact + book-a-demo (opens Calendly popup) -->
        <div class="cta-lead reveal">
          <h2 class="section-title">{s.ctaTitle}</h2>
          <p class="section-sub">{s.ctaBody}</p>

          <div class="lead-foot">
            <a class="lead-mail" href={`mailto:${CONTACT_EMAIL}`}>
              <Icon name="mail" size={16} stroke={1.7} />
              {CONTACT_EMAIL}
            </a>
            <div class="lead-demo">
              <p class="lead-demo-title">{s.kontaktDemoTitle}</p>
              <p class="lead-demo-body">{s.kontaktDemoBody}</p>
              <a class="btn btn-lg demo-cta" href={CALENDLY_URL} data-calendly>
                {s.ctaBookDemo}
                <span class="btn-pip"><Icon name="arrow-right" size={15} /></span>
              </a>
            </div>
            <a class="lead-secondary" href="https://app.staging.lucra-app.ai" target="_blank" rel="noopener">
              {s.ctaTryLucra}
              <Icon name="arrow-right" class="arrow" size={14} />
            </a>
          </div>
        </div>

        <!-- Contact form -->
        <form
          class="kontakt-form reveal delay-1"
          name="kontakt"
          method="POST"
          action={tackPath}
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="kontakt" />
          <p class="hp" hidden>
            <label>Lämna detta fält tomt: <input name="bot-field" /></label>
          </p>

          <fieldset class="chip-group">
            <legend>{s.formRole}</legend>
            <div class="chips">
              <label class="chip">
                <input type="radio" name="roll" value={s.formRoleBusiness} checked />
                <span>{s.formRoleBusiness}</span>
              </label>
              <label class="chip">
                <input type="radio" name="roll" value={s.formRoleAgency} />
                <span>{s.formRoleAgency}</span>
              </label>
            </div>
          </fieldset>

          <div class="field-row">
            <div class="field">
              <label for="namn">{s.formName} <span class="req">*</span></label>
              <input id="namn" name="namn" type="text" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="epost">{s.formEmail} <span class="req">*</span></label>
              <input id="epost" name="epost" type="email" required autocomplete="email" />
            </div>
          </div>

          <div class="field">
            <label for="foretag">{s.formCompany} <span class="opt">({s.formCompanyOptional})</span></label>
            <input id="foretag" name="foretag" type="text" autocomplete="organization" />
          </div>

          <div class="field">
            <label for="meddelande">{s.formMessage} <span class="req">*</span></label>
            <textarea id="meddelande" name="meddelande" rows="3" required placeholder={s.formMessagePlaceholder}></textarea>
          </div>

          <button type="submit" class="btn form-submit">
            {s.formSubmit}
            <span class="btn-pip"><Icon name="arrow-right" size={16} /></span>
          </button>
        </form>
      </div>
    </div>

    <CalendlyPopup />
  </div>
</section>

<style>
  .cta-panel {
    border-radius: var(--radius-shell);
    padding: 72px 64px;
    position: relative;
    overflow: hidden;
    transform-origin: center center;
  }
  /* Soft brand glow — bottom-left anchor + faint top-right, no harsh edges. */
  .cta-panel::before {
    content: "";
    position: absolute;
    bottom: -180px; left: -140px;
    width: 520px; height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle,
      color-mix(in srgb, var(--brand-accent) 22%, transparent),
      transparent 68%);
    filter: blur(60px);
    pointer-events: none;
  }
  .cta-panel::after {
    content: "";
    position: absolute;
    top: -160px; right: -120px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--brand-primary-light) 50%, transparent);
    filter: blur(110px);
    pointer-events: none;
  }

  .cta-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 72px;
    align-items: start;
  }

  /* ---- Left lead ---- */
  .cta-panel .section-title {
    margin: 0 0 18px;
    max-width: 460px;
    font-size: clamp(40px, 4.6vw, 56px);
  }
  .cta-panel .section-sub {
    margin: 0;
    max-width: 420px;
    color: rgba(255, 255, 255, .66);
  }
  .lead-foot {
    margin-top: 44px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .lead-mail {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--white);
    border-bottom: 1px solid rgba(255, 255, 255, .28);
    padding-bottom: 3px;
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1), color .25s cubic-bezier(.32, .72, 0, 1);
  }
  .lead-mail:hover { border-color: var(--brand-accent); }
  .lead-mail :global(svg) { color: rgba(255, 255, 255, .55); }

  .lead-demo { display: flex; flex-direction: column; gap: 4px; }
  .lead-demo-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--white);
    margin: 0;
  }
  .lead-demo-body {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, .6);
    margin: 0 0 12px;
    max-width: 340px;
  }
  .demo-cta {
    align-self: flex-start;
    background: rgba(255, 255, 255, .06);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, .22);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .08);
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1),
                background .25s cubic-bezier(.32, .72, 0, 1),
                transform .25s cubic-bezier(.32, .72, 0, 1);
  }
  .demo-cta:hover {
    border-color: rgba(255, 255, 255, .5);
    background: rgba(255, 255, 255, .1);
    transform: translateY(-1px);
  }
  .lead-secondary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, .6);
    transition: color .25s cubic-bezier(.32, .72, 0, 1);
  }
  .lead-secondary:hover { color: var(--white); }
  .lead-secondary .arrow { transition: transform .25s cubic-bezier(.32, .72, 0, 1); }
  .lead-secondary:hover .arrow { transform: translateX(3px); }

  /* ---- Button-in-button trailing icon (nested circular pip) ---- */
  .btn-pip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    margin-left: 2px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, .12);
    transition: transform .35s cubic-bezier(.32, .72, 0, 1);
  }
  .demo-cta .btn-pip { margin-right: -8px; }
  .btn:hover .btn-pip { transform: translateX(3px); }

  /* ---- Right form ---- */
  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .hp { position: absolute; left: -9999px; }

  /* Role chips (segmented pill selector) */
  .chip-group { border: 0; margin: 0; padding: 0; }
  .chip-group legend {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, .55);
    padding: 0;
    margin-bottom: 12px;
  }
  .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .chip { cursor: pointer; }
  .chip input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .chip span {
    display: inline-flex;
    align-items: center;
    padding: 9px 18px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, .16);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, .72);
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1),
                background .25s cubic-bezier(.32, .72, 0, 1),
                color .25s cubic-bezier(.32, .72, 0, 1);
  }
  .chip:hover span { border-color: rgba(255, 255, 255, .32); color: var(--white); }
  .chip:has(input:checked) span {
    background: var(--white);
    border-color: var(--white);
    color: var(--brand-primary-dark);
  }
  .chip input:focus-visible + span {
    outline: none;
    box-shadow: 0 0 0 3px rgba(86, 179, 235, .3);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, .55);
  }
  .field .opt { font-weight: 400; color: rgba(255, 255, 255, .4); font-size: 12px; }
  .field .req { color: var(--brand-accent); }

  /* Underline-only inputs — minimal editorial style. */
  .field input,
  .field textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--white);
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, .16);
    border-radius: 0;
    padding: 8px 0;
    transition: border-color .25s cubic-bezier(.32, .72, 0, 1);
  }
  .field textarea { resize: vertical; min-height: 64px; line-height: 1.6; }
  .field input::placeholder,
  .field textarea::placeholder { color: rgba(255, 255, 255, .34); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: var(--brand-accent);
  }

  /* Full-width white submit pill with nested arrow pip. */
  .form-submit {
    width: 100%;
    height: 56px;
    margin-top: 6px;
    border-radius: var(--radius-pill);
    background: var(--white);
    color: var(--brand-primary-dark);
    font-size: 15px;
    font-weight: 600;
    position: relative;
    transition: transform .25s cubic-bezier(.32, .72, 0, 1),
                box-shadow .25s cubic-bezier(.32, .72, 0, 1);
  }
  .form-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 30px -12px rgba(0, 0, 0, .5);
  }
  .form-submit .btn-pip {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: color-mix(in srgb, var(--brand-primary-dark) 12%, transparent);
  }
  .form-submit:hover .btn-pip { transform: translateY(-50%) translateX(3px); }

  @media (max-width: 900px) {
    .cta-grid { grid-template-columns: 1fr; gap: 48px; }
    .cta-panel .section-title,
    .cta-panel .section-sub,
    .lead-demo-body { max-width: none; }
  }
  @media (max-width: 560px) {
    .cta-panel { padding: 48px 24px; }
    .field-row { grid-template-columns: 1fr; gap: 26px; }
  }
</style>

<script>
  // ── Scroll-zoom — the panel scales 0.94 → 1 as it enters the viewport ───────
  // rAF loop runs only while the section is on screen (IntersectionObserver
  // gate), so there's no always-on scroll listener — plays nicely with Lenis.
  // Writes only `transform` (GPU-safe). Skipped under reduced-motion.
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const panel = document.querySelector('.cta-section .cta-panel') as HTMLElement | null;
    if (panel) {
      const MIN = 0.94;
      let active = false;

      const apply = (): void => {
        const rect = panel.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        let progress = (vh - rect.top) / (vh * 0.65);
        progress = Math.max(0, Math.min(1, progress));
        progress = 1 - (1 - progress) * (1 - progress); // easeOut
        const scale = MIN + (1 - MIN) * progress;
        panel.style.transform = `scale(${scale.toFixed(4)})`;
      };

      const loop = (): void => {
        if (!active) return;
        apply();
        requestAnimationFrame(loop);
      };

      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !active) {
            active = true;
            panel.style.willChange = 'transform';
            requestAnimationFrame(loop);
          } else if (!entry.isIntersecting) {
            active = false;
            panel.style.willChange = '';
          }
        });
      }, { rootMargin: '0px' });

      io.observe(panel);
      apply(); // set initial scale in case the section starts in view
    }
  }
</script>

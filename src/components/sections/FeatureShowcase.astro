---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

// Server-rendered fallback for the AI answer (no-JS / reduced motion shows the
// full sentence). «...» marks the stat that gets the streamed count-up.
const aiHtml = s.showcaseChatAi.replace(
  /«([^»]+)»/g,
  '<span class="cs-stat is-vis">$1</span>',
);

// Dashboard card visual — a Remotion-rendered loop video (built in remotion/,
// rendered per language). Poster is a settled frame for reduced motion / pre-play.
const dashVideo = lang === 'en' ? '/assets/dashboard-en.mp4' : '/assets/dashboard-sv.mp4';
const dashPoster = lang === 'en' ? '/assets/dashboard-en.jpg' : '/assets/dashboard-sv.jpg';
---

<section id="funktioner">
  <div class="container">
    <div class="showcase-head reveal">
      <div class="showcase-head-text">
        <span class="section-eyebrow">{s.showcaseEyebrow}</span>
        <h2 class="section-title">{s.showcaseTitle}</h2>
        <p class="section-sub">{s.showcaseSub}</p>
      </div>
      <div class="showcase-nav">
        <button class="showcase-arrow" data-prev type="button" aria-label={s.showcaseNavPrev}>
          <Icon name="arrow-left" />
        </button>
        <button class="showcase-arrow" data-next type="button" aria-label={s.showcaseNavNext}>
          <Icon name="arrow-right" />
        </button>
      </div>
    </div>

    <div class="showcase-viewport" data-viewport>
      <div class="showcase-track" data-track>
      <!-- Card 1 — AI chat. Visual on top (faithful chat surface with the real
           WebGL orb, self-playing on loop), copy below (GitBook layout). -->
      <article class="showcase-card reveal">
        <div
          class="showcase-visual"
          data-chat
          data-q={s.showcaseChatUser}
          data-a={s.showcaseChatAi}
          aria-hidden="true"
        >
          <span class="cs-glow cs-glow-a"></span>
          <span class="cs-glow cs-glow-b"></span>

          <div class="cs-stage">
            <div class="cs-feed" data-feed>
              <div class="cs-user" data-user>
                <span class="cs-utext">{s.showcaseChatUser}</span>
                <span class="cs-time cs-time-user">09:24</span>
              </div>
              <div class="cs-ai" data-ai>
                <span class="cs-orb" id="feature-chat-orb"></span>
                <div class="cs-bubble">
                  <span class="cs-think" data-think><i></i><i></i><i></i></span><span class="cs-text" data-text set:html={aiHtml}></span>
                  <span class="cs-foot" data-foot>
                    <span class="cs-time">09:24</span>
                    <Icon name="copy" class="cs-copy" />
                  </span>
                </div>
              </div>
            </div>

            <div class="cs-input">
              <span class="cs-clip">
                <Icon name="paperclip" />
              </span>
              <span class="cs-input-text" data-input data-ph={s.showcaseChatPlaceholder}></span><span class="cs-caret" data-caret></span>
              <span class="cs-send" data-send>
                <Icon name="arrow-up" />
              </span>
            </div>
          </div>
        </div>

        <div class="showcase-body">
          <h3>{s.showcaseCard1Title}</h3>
          <p>{s.showcaseCard1Body}</p>
          <a class="showcase-pill" href="#funktioner">
            {s.showcaseCard1Pill}
            <Icon name="arrow-right" />
          </a>
        </div>
      </article>

      <!-- Card 2 — Dashboard. Visual is a Remotion-rendered loop video, lazily
           played only while in view; poster covers reduced motion / pre-play. -->
      <article class="showcase-card reveal delay-1">
        <div class="showcase-visual showcase-visual-video">
          <video
            class="cs-video"
            data-video
            preload="none"
            muted
            loop
            playsinline
            poster={dashPoster}
            aria-label={s.showcaseCard2VideoAlt}
          >
            <source src={dashVideo} type="video/mp4" />
          </video>
        </div>
        <div class="showcase-body">
          <h3>{s.showcaseCard2Title}</h3>
          <p>{s.showcaseCard2Body}</p>
          <a class="showcase-pill" href="#funktioner">
            {s.showcaseCard2Pill}
            <Icon name="arrow-right" />
          </a>
        </div>
      </article>

      <!-- Card 3 — Documents. Scan-line sweeps the top row, the status cycles
           Läser → AI föreslår → Bokfört on a CSS loop. -->
      <article class="showcase-card reveal delay-2">
        <div class="showcase-visual showcase-visual-doc">
          <span class="cs-glow cs-glow-a"></span>
          <div class="sc-panel doc-panel">
            <div class="doc-head">
              <span class="doc-title">{s.showcaseDocPanelTitle}</span>
              <span class="doc-aichip">AI</span>
            </div>
            <div class="doc-row doc-row-active">
              <span class="doc-ic doc-ic-pdf">PDF</span>
              <span class="doc-name">{s.showcaseDocFile1}</span>
              <span class="doc-states">
                <span class="doc-state doc-state-read">{s.showcaseDocReading}</span>
                <span class="doc-state doc-state-suggest">{s.showcaseDocSuggest}</span>
                <span class="doc-state doc-state-posted">
                  <Icon name="check" />
                  {s.showcaseDocPosted}
                </span>
              </span>
              <span class="doc-scan"></span>
            </div>
            <div class="doc-row">
              <span class="doc-ic doc-ic-jpg">JPG</span>
              <span class="doc-name">{s.showcaseDocFile2}</span>
              <span class="doc-badge">{s.showcaseDocPosted}</span>
            </div>
            <div class="doc-row">
              <span class="doc-ic doc-ic-doc">DOC</span>
              <span class="doc-name">{s.showcaseDocFile3}</span>
              <span class="doc-badge">{s.showcaseDocPosted}</span>
            </div>
          </div>
        </div>
        <div class="showcase-body">
          <h3>{s.showcaseCard3Title}</h3>
          <p>{s.showcaseCard3Body}</p>
          <a class="showcase-pill" href="#funktioner">
            {s.showcaseCard3Pill}
            <Icon name="arrow-right" />
          </a>
        </div>
      </article>

      <!-- Card 4 — Fortnox sync. A pulse travels Fortnox → Lucra on a CSS loop. -->
      <article class="showcase-card reveal delay-3">
        <div class="showcase-visual showcase-visual-sync">
          <span class="cs-glow cs-glow-a"></span>
          <div class="sc-panel sync-panel">
            <div class="sync-rail">
              <span class="sync-node sync-node-fortnox">Fortnox</span>
              <span class="sync-line"><span class="sync-pulse"></span></span>
              <span class="sync-node sync-node-lucra"><span class="sync-orb"></span></span>
            </div>
            <div class="sync-status">
              <Icon name="check" />
              {s.showcaseSyncLine}
            </div>
            <div class="sync-items">
              <span class="sync-item">{s.showcaseSyncItem1}</span>
              <span class="sync-item">{s.showcaseSyncItem2}</span>
              <span class="sync-item">{s.showcaseSyncItem3}</span>
            </div>
          </div>
        </div>
        <div class="showcase-body">
          <h3>{s.showcaseCard4Title}</h3>
          <p>{s.showcaseCard4Body}</p>
          <a class="showcase-pill" href="#integrationer">
            {s.showcaseCard4Pill}
            <Icon name="arrow-right" />
          </a>
        </div>
      </article>

      <!-- Card 5 — Multi-company. The active highlight glides between companies. -->
      <article class="showcase-card reveal delay-3">
        <div class="showcase-visual showcase-visual-co">
          <span class="cs-glow cs-glow-a"></span>
          <div class="sc-panel co-panel">
            <div class="co-search">
              <Icon name="search" />
              <span>{s.showcaseCoSearch}</span>
            </div>
            <div class="co-list" data-co-list>
              <div class="co-row is-active">
                <span class="co-bar"></span>
                <span class="co-av">NB</span>
                <span class="co-name">Nordiska Bygg AB</span>
              </div>
              <div class="co-row">
                <span class="co-bar"></span>
                <span class="co-av">AT</span>
                <span class="co-name">Aurora Tech AB</span>
              </div>
              <div class="co-row">
                <span class="co-bar"></span>
                <span class="co-av">VK</span>
                <span class="co-name">Vasa Konsult AB</span>
              </div>
              <div class="co-row">
                <span class="co-bar"></span>
                <span class="co-av">SV</span>
                <span class="co-name">Stockholm Ventures AB</span>
              </div>
            </div>
            <div class="co-divider"></div>
            <div class="co-manage">
              <Icon name="settings" />
              <span>{s.showcaseCoManage}</span>
            </div>
          </div>
        </div>
        <div class="showcase-body">
          <h3>{s.showcaseCard5Title}</h3>
          <p>{s.showcaseCard5Body}</p>
          <a class="showcase-pill" href="#for-vem">
            {s.showcaseCard5Pill}
            <Icon name="arrow-right" />
          </a>
        </div>
      </article>
      </div>
    </div>
  </div>
</section>

<style>
  #funktioner {
    padding-top: 80px;
  }

  /* ---- Header: title/sub on the left, carousel arrows on the right ---- */
  .showcase-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 48px;
  }
  .showcase-head-text { max-width: 720px; }
  .showcase-nav {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }
  .showcase-arrow {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--bg-paper);
    color: var(--brand-primary);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease, opacity 0.2s ease;
  }
  .showcase-arrow svg { width: 20px; height: 20px; }
  .showcase-arrow:hover { background: var(--bg-active); border-color: var(--slate-300); }
  .showcase-arrow:active { transform: scale(0.94); }
  .showcase-arrow:disabled { opacity: 0.35; cursor: default; pointer-events: none; }

  /* ---- Viewport: native scroll-snap track, bleeds to the container edges ---- */
  .showcase-viewport {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 16px 0 24px;
    cursor: grab;
  }
  .showcase-viewport::-webkit-scrollbar { display: none; }
  .showcase-viewport.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
    scroll-behavior: auto;
    user-select: none;
  }
  .showcase-viewport.is-dragging * { pointer-events: none; }
  .showcase-track {
    display: flex;
    gap: 24px;
  }

  .showcase-card {
    flex: 0 0 calc((100% - 48px) / 3);
    min-width: 0;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 1023px) {
    .showcase-card { flex-basis: calc((100% - 24px) / 2); }
  }
  @media (max-width: 639px) {
    .showcase-head { flex-direction: column; align-items: flex-start; gap: 24px; }
    .showcase-card { flex-basis: 86%; }
  }

  /* ---- Visual zone: faithful chat surface ---- */
  .showcase-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 90% at 50% 0%, rgba(86, 179, 235, 0.08), transparent 60%),
      linear-gradient(180deg, var(--bg-app), #f8fafc);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 18px 40px -26px rgba(61, 80, 109, 0.28);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .showcase-card:hover .showcase-visual {
    transform: translateY(-6px);
    border-color: var(--slate-300);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.05),
      0 34px 64px -30px rgba(61, 80, 109, 0.36);
  }

  /* ---- Section entrance signature — when the section scrolls into view the
     cards rise + scale in with a smooth left-to-right cascade. One-shot, driven
     by the shared .reveal IntersectionObserver (so it's reliable under Lenis and
     never depends on live scroll position). #funktioner id wins over the generic
     .reveal rules in global.css. ---- */
  :global(html.reveal-ready) #funktioner .showcase-card.reveal {
    transform: translateY(46px) scale(0.97);
    filter: blur(7px);
    transition:
      opacity 0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      filter 0.75s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  :global(html.reveal-ready) #funktioner .showcase-card.reveal.in-view {
    transform: none;
    filter: blur(0);
  }
  /* Even 5-step cascade (the markup only carries delay-1..3). */
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(2) { transition-delay: 0.08s; }
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(3) { transition-delay: 0.16s; }
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(4) { transition-delay: 0.24s; }
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(5) { transition-delay: 0.32s; }
  /* Soft blue glow blobs — faithful to the product welcome screen. */
  .cs-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(46px);
    pointer-events: none;
  }
  .cs-glow-a {
    top: -14%;
    left: 40%;
    width: 56%;
    height: 56%;
    background: rgba(86, 179, 235, 0.22);
  }
  .cs-glow-b {
    bottom: -10%;
    left: 6%;
    width: 42%;
    height: 42%;
    background: rgba(59, 130, 246, 0.14);
  }

  /* Dashboard card — Remotion loop video floats as a centred window on the
     gradient backdrop (the visual is portrait, so full-bleed would crop it). */
  .cs-video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    height: auto;
    display: block;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.1);
  }

  /* Floating app-window fragment that holds the conversation. */
  .cs-stage {
    position: absolute;
    inset: 22px 22px 0;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
    padding: 16px 16px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
  }
  .cs-feed {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 14px;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* User bubble — faithful to ChatMessageBubble (brand fill, right aligned). */
  .cs-user {
    align-self: flex-end;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    max-width: 78%;
    background: var(--brand-primary);
    color: #fff;
    font-size: 13px;
    line-height: 1.5;
    padding: 9px 13px;
    border-radius: 16px 16px 4px 16px;
  }
  .cs-time {
    font-size: 11px;
    color: var(--slate-400);
    line-height: 1.4;
  }
  .cs-time-user { color: rgba(255, 255, 255, 0.7); }

  /* AI row — real orb avatar + white bubble with cyan left rule. */
  .cs-ai {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    max-width: 92%;
  }
  .cs-orb {
    position: relative;
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    margin-top: 2px;
    border-radius: 50%;
    /* Fallback ring orb (reduced motion / no WebGL) — a hollow glowing ring,
       matching the real WebGL orb's shape. The mounted canvas covers this when
       the real orb initialises. */
    background: transparent;
    box-shadow:
      inset 0 0 0 3px rgba(86, 179, 235, 0.55),
      inset 2px -2px 4px rgba(61, 80, 109, 0.35),
      0 0 10px rgba(86, 179, 235, 0.4);
  }
  .cs-orb :global(canvas) {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
  }
  .cs-bubble {
    position: relative;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-left: 3px solid var(--brand-primary-light);
    border-radius: 0 12px 12px 12px;
    box-shadow: 0 2px 4px rgba(15, 23, 42, 0.05);
    padding: 9px 12px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--slate-600);
    min-height: 18px;
  }
  /* Bubble footer — timestamp + copy affordance (faithful to the product). */
  .cs-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 6px;
  }
  .cs-copy {
    width: 13px;
    height: 13px;
    color: var(--slate-400);
  }

  /* Thinking dots — hidden by default (the static fallback shows the answer). */
  .cs-think {
    display: none;
    align-items: center;
    gap: 3px;
    height: 14px;
  }
  .cs-think i {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--slate-400);
    animation: csThink 1s ease-in-out infinite;
  }
  .cs-think i:nth-child(2) { animation-delay: 0.15s; }
  .cs-think i:nth-child(3) { animation-delay: 0.3s; }
  @keyframes csThink {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-2px); }
  }

  /* Highlighted stat — brand chip. */
  .cs-stat {
    color: var(--brand-primary);
    font-family: var(--font-display);
    font-weight: 700;
    background: var(--bg-active);
    border-radius: 6px;
    padding: 0 5px;
    white-space: nowrap;
  }

  /* Input pill — faithful to WelcomeInputCard. */
  .cs-input {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 -2px;
    padding: 8px 8px 8px 10px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    box-shadow: 0 -6px 20px rgba(15, 23, 42, 0.03);
  }
  .cs-clip {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--bg-app);
    color: var(--slate-400);
  }
  .cs-clip svg { width: 15px; height: 15px; }
  .cs-input-text {
    flex: 1;
    min-width: 0;
    font-size: 13px;
    line-height: 1.4;
    color: var(--slate-600);
    white-space: nowrap;
    overflow: hidden;
  }
  .cs-input-text:empty::before {
    content: attr(data-ph);
    color: var(--slate-300);
  }
  .cs-caret {
    display: none;
    width: 1.5px;
    height: 15px;
    margin-left: -6px;
    background: var(--brand-primary);
  }
  .cs-send {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--bg-app);
    color: var(--slate-400);
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .cs-send svg { width: 15px; height: 15px; }
  .cs-send.is-active {
    background: var(--brand-primary);
    color: #fff;
    transform: scale(1.04);
  }

  /* ---- Live (animated) states — only when JS takes over and motion is OK ---- */
  .showcase-visual.is-live .cs-caret { display: inline-block; animation: csBlink 1.1s steps(1) infinite; }
  @keyframes csBlink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  .showcase-visual.is-live .cs-user,
  .showcase-visual.is-live .cs-ai {
    opacity: 0;
    transform: translateY(8px);
  }
  .showcase-visual.is-live .cs-user { transform: translateY(8px) scale(0.98); }
  .showcase-visual.is-live .cs-user.vis,
  .showcase-visual.is-live .cs-ai.vis {
    opacity: 1;
    transform: none;
    transition: opacity 0.26s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.34s cubic-bezier(0.34, 1.3, 0.5, 1);
  }
  /* Word-by-word reveal for the streamed answer. */
  .cs-w { opacity: 0; transform: translateY(4px); display: inline; }
  .cs-w.vis { opacity: 1; transform: none; transition: opacity 0.2s ease-out, transform 0.2s ease-out; }
  .cs-stat.cs-w { transform: translateY(4px) scale(0.9); }
  .cs-stat.cs-w.vis { transition: opacity 0.22s ease-out, transform 0.36s cubic-bezier(0.34, 1.3, 0.5, 1); }

  /* ---- Card copy — sits below the visual card on the page background ---- */
  .showcase-body {
    padding: 22px 4px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .showcase-pill {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-primary);
    margin-top: 4px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .showcase-pill:hover { background: var(--bg-active); border-color: var(--slate-300); }
  .showcase-pill svg { width: 13px; height: 13px; transition: transform 0.2s ease; }
  .showcase-pill:hover svg { transform: translateX(3px); }
  .showcase-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--brand-primary);
    margin: 0;
  }
  .showcase-card p {
    font-size: 14.5px;
    color: var(--slate-500);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  /* ---- Shared floating panel (documents / sync / companies cards) ---- */
  .sc-panel {
    position: absolute;
    inset: 22px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);

  }
</style>

<script>
  import { mountOrb } from '../../scripts/orb';

  // Self-playing AI chat for the showcase card. The question types into the
  // input, lifts into a user bubble, the orb "thinks", then the answer streams
  // word-by-word and lands on the highlighted stat — looping while in view.
  // The real WebGL orb is mounted once (motion allowed + in view). Reduced
  // motion leaves the static server-rendered exchange and never mounts the orb.
  (function () {
    const root = document.querySelector('[data-chat]') as HTMLElement | null;
    if (!root) return;
    const feed = root.querySelector('[data-feed]') as HTMLElement | null;
    const userEl = root.querySelector('[data-user]') as HTMLElement | null;
    const aiEl = root.querySelector('[data-ai]') as HTMLElement | null;
    const thinkEl = root.querySelector('[data-think]') as HTMLElement | null;
    const textEl = root.querySelector('[data-text]') as HTMLElement | null;
    const footEl = root.querySelector('[data-foot]') as HTMLElement | null;
    const inputEl = root.querySelector('[data-input]') as HTMLElement | null;
    const sendEl = root.querySelector('[data-send]') as HTMLElement | null;
    if (!feed || !userEl || !aiEl || !thinkEl || !textEl || !footEl || !inputEl || !sendEl) return;

    const question = root.dataset.q ?? '';
    const answer = root.dataset.a ?? '';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !question || !answer) return; // keep the static fallback

    const sleep = (ms: number): Promise<void> => new Promise((r) => setTimeout(r, ms));
    let seq = 0; // epoch — bumped to cancel in-flight playback (pause / restart)
    let running = false;
    let mounted = false;

    // Split the answer into reveal units; «...» becomes one highlighted stat.
    function units(text: string): { text: string; stat: boolean }[] {
      const out: { text: string; stat: boolean }[] = [];
      const re = /«([^»]+)»/g;
      let last = 0;
      let match: RegExpExecArray | null;
      const pushWords = (str: string): void => {
        str.split(/\s+/).filter(Boolean).forEach((word) => out.push({ text: word, stat: false }));
      };
      while ((match = re.exec(text))) {
        if (match.index > last) pushWords(text.slice(last, match.index));
        out.push({ text: match[1], stat: true });
        last = match.index + match[0].length;
      }
      if (last < text.length) pushWords(text.slice(last));
      return out;
    }

    function countUp(el: HTMLElement, text: string): void {
      const parts = text.match(/^(\D*)(\d+)(.*)$/);
      if (!parts) { el.textContent = text; return; }
      const prefix = parts[1];
      const target = parseInt(parts[2], 10);
      const suffix = parts[3];
      const duration = 520;
      const t0 = performance.now();
      const tick = (now: number): void => {
        const progress = Math.min(1, (now - t0) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = prefix + Math.round(target * eased) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = text;
      };
      requestAnimationFrame(tick);
    }

    async function typeQuestion(my: number): Promise<void> {
      for (let index = 1; index <= question.length; index++) {
        if (my !== seq) return;
        inputEl!.textContent = question.slice(0, index);
        await sleep(34);
      }
    }

    async function stream(my: number): Promise<void> {
      textEl!.innerHTML = '';
      for (const unit of units(answer)) {
        if (my !== seq) return;
        const span = document.createElement('span');
        span.className = unit.stat ? 'cs-w cs-stat' : 'cs-w';
        span.textContent = unit.stat ? unit.text : unit.text + ' ';
        textEl!.appendChild(span);
        requestAnimationFrame(() => requestAnimationFrame(() => span.classList.add('vis')));
        if (unit.stat) countUp(span, unit.text);
        await sleep(36);
      }
    }

    async function cycle(my: number): Promise<void> {
      // Reset to an empty surface.
      userEl!.classList.remove('vis');
      aiEl!.classList.remove('vis');
      sendEl!.classList.remove('is-active');
      thinkEl!.style.display = 'none';
      footEl!.style.display = 'none';
      textEl!.innerHTML = '';
      inputEl!.textContent = '';
      await sleep(440);
      if (my !== seq) return;

      // Type the question, then "send".
      await typeQuestion(my);
      if (my !== seq) return;
      sendEl!.classList.add('is-active');
      await sleep(420);
      if (my !== seq) return;

      inputEl!.textContent = '';
      sendEl!.classList.remove('is-active');
      userEl!.classList.add('vis');
      await sleep(560);
      if (my !== seq) return;

      // AI thinks, then streams the answer.
      aiEl!.classList.add('vis');
      thinkEl!.style.display = 'inline-flex';
      await sleep(820);
      if (my !== seq) return;
      thinkEl!.style.display = 'none';
      await stream(my);
      if (my !== seq) return;
      footEl!.style.display = 'flex';
    }

    async function run(my: number): Promise<void> {
      while (my === seq) {
        await cycle(my);
        if (my !== seq) return;
        await sleep(2600); // hold the completed exchange
      }
    }

    function resume(): void {
      if (running) return;
      running = true;
      const my = ++seq;
      run(my).finally(() => { if (my === seq) running = false; });
    }
    function pause(): void {
      seq++;
      running = false;
    }

    function ensureOrb(): void {
      if (mounted) return;
      mounted = true;
      const ric: (cb: () => void) => void = (window as any).requestIdleCallback
        ? (cb) => (window as any).requestIdleCallback(cb)
        : (cb) => { setTimeout(cb, 1); };
      ric(() => mountOrb('feature-chat-orb', {}));
    }

    const io = new IntersectionObserver((entries) => {
      const visible = entries.some((entry) => entry.isIntersecting);
      if (visible) {
        root.classList.add('is-live');
        ensureOrb();
        resume();
      } else {
        pause();
      }
    }, { threshold: 0.35 });
    io.observe(root);
  })();
</script>

<script>
  // Dashboard card — play the loop video only while it is on screen (saves CPU
  // when scrolled away). Reduced motion leaves the poster frame, never autoplays.
  (function () {
    const video = document.querySelector('[data-video]') as HTMLVideoElement | null;
    if (!video) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          void video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { threshold: 0.3 });
    io.observe(video);
  })();
</script>

<script>
  // Run the CSS loop animations (documents / sync / companies) only while the
  // section is on screen, so they don't burn frames when scrolled away.
  (function () {
    const section = document.getElementById('funktioner');
    if (!section) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        section.classList.toggle('is-onscreen', entry.isIntersecting);
      });
    }, { rootMargin: '0px 0px -10% 0px' });
    io.observe(section);
  })();
</script>

<script>
  // Multi-company card — glide the active selection through the list while in
  // view, mimicking switching companies. Reduced motion keeps the first active.
  (function () {
    const list = document.querySelector('[data-co-list]') as HTMLElement | null;
    if (!list) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const rows = Array.from(list.querySelectorAll('.co-row'));
    if (rows.length < 2) return;
    let index = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    function step(): void {
      index = (index + 1) % rows.length;
      rows.forEach((row, i) => row.classList.toggle('is-active', i === index));
    }
    const io = new IntersectionObserver((entries) => {
      const visible = entries.some((entry) => entry.isIntersecting);
      if (visible && timer === null) {
        timer = setInterval(step, 1800);
      } else if (!visible && timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    }, { threshold: 0.3 });
    io.observe(list);
  })();
</script>

<script>
  // Showcase carousel — the prev/next arrows slide the native scroll-snap track
  // one card at a time (smooth via CSS scroll-behavior). Touch swipe works
  // natively; the arrows disable at each end. No-JS leaves a scrollable track.
  (function () {
    const viewport = document.querySelector('[data-viewport]') as HTMLElement | null;
    const track = document.querySelector('[data-track]') as HTMLElement | null;
    const prev = document.querySelector('[data-prev]') as HTMLButtonElement | null;
    const next = document.querySelector('[data-next]') as HTMLButtonElement | null;
    if (!viewport || !track || !prev || !next) return;

    function step(): number {
      const card = track!.querySelector('.showcase-card') as HTMLElement | null;
      if (!card) return viewport!.clientWidth;
      const gap = parseFloat(getComputedStyle(track!).columnGap || '0') || 0;
      return card.offsetWidth + gap;
    }

    function update(): void {
      const max = viewport!.scrollWidth - viewport!.clientWidth - 1;
      prev!.disabled = viewport!.scrollLeft <= 0;
      next!.disabled = viewport!.scrollLeft >= max;
    }

    prev.addEventListener('click', () => viewport!.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => viewport!.scrollBy({ left: step(), behavior: 'smooth' }));
    viewport.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);

    // Drag-to-scroll with mouse / pen. Touch and horizontal trackpad/wheel
    // scrolling are handled natively by the scroll container.
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;

    viewport.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'touch') return; // touch scrolls natively
      dragging = true;
      moved = false;
      startX = e.clientX;
      startScroll = viewport!.scrollLeft;
      viewport!.setPointerCapture(e.pointerId);
      viewport!.classList.add('is-dragging');
    });
    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 3) moved = true;
      viewport!.scrollLeft = startScroll - dx;
    });
    function endDrag(e: PointerEvent): void {
      if (!dragging) return;
      dragging = false;
      viewport!.classList.remove('is-dragging');
      try { viewport!.releasePointerCapture(e.pointerId); } catch { /* already released */ }
      // Settle on the nearest card (mandatory snap re-applies once the class drops).
      const s = step();
      viewport!.scrollTo({ left: Math.round(viewport!.scrollLeft / s) * s, behavior: 'smooth' });
    }
    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);
    // Swallow the click that fires right after a drag.
    viewport.addEventListener('click', (e) => {
      if (moved) { e.preventDefault(); e.stopPropagation(); }
    }, true);
    viewport.addEventListener('dragstart', (e) => e.preventDefault());

    update();
  })();
</script>

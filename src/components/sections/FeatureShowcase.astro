---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

// Each card is a Remotion-rendered 4:5 loop video (built in remotion/, rendered
// per language into public/assets/). The poster is a settled frame shown before
// play and under reduced motion. Videos fill the visual box edge-to-edge.
const video = (id: string): string => `/assets/feature-${id}-${lang}.mp4`;
const poster = (id: string): string => `/assets/feature-${id}-${lang}.jpg`;

const cards = [
  { id: 'chat', title: s.showcaseCard1Title, body: s.showcaseCard1Body, pill: s.showcaseCard1Pill, alt: s.showcaseCard1Alt, href: '#funktioner' },
  { id: 'dashboard', title: s.showcaseCard2Title, body: s.showcaseCard2Body, pill: s.showcaseCard2Pill, alt: s.showcaseCard2Alt, href: '#funktioner' },
  { id: 'documents', title: s.showcaseCard3Title, body: s.showcaseCard3Body, pill: s.showcaseCard3Pill, alt: s.showcaseCard3Alt, href: '#funktioner' },
  { id: 'integrations', title: s.showcaseCard4Title, body: s.showcaseCard4Body, pill: s.showcaseCard4Pill, alt: s.showcaseCard4Alt, href: '#integrationer' },
];
---

<section id="funktioner">
  <div class="container">
    <div class="showcase-head reveal">
      <div class="showcase-head-text">
        <h2 class="section-title">{s.showcaseTitle}</h2>
        <p class="section-sub">{s.showcaseSub}</p>
      </div>
      <div class="showcase-nav">
        <button class="showcase-arrow" data-prev type="button" aria-label={s.showcaseNavPrev}>
          <Icon name="arrow-left" />
        </button>
        <button class="showcase-arrow" data-next type="button" aria-label={s.showcaseNavNext}>
          <Icon name="arrow-right" />
        </button>
      </div>
    </div>

    <div class="showcase-viewport" data-viewport>
      <div class="showcase-track" data-track>
        {cards.map((card) => (
          <article class="showcase-card reveal">
            <div class="showcase-visual">
              <video
                class="cs-video-full"
                data-video
                preload="none"
                muted
                loop
                playsinline
                poster={poster(card.id)}
                aria-label={card.alt}
              >
                <source src={video(card.id)} type="video/mp4" />
              </video>
            </div>
            <div class="showcase-body">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              <a class="showcase-pill" href={card.href}>
                {card.pill}
                <Icon name="arrow-right" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #funktioner {
    padding-top: 80px;
  }

  /* ---- Header: title/sub on the left, carousel arrows on the right ---- */
  .showcase-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 48px;
  }
  .showcase-head-text { max-width: 720px; }
  .showcase-nav {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }
  .showcase-arrow {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--bg-paper);
    color: var(--brand-primary);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease, opacity 0.2s ease;
  }
  .showcase-arrow svg { width: 20px; height: 20px; }
  .showcase-arrow:hover { background: var(--bg-active); border-color: var(--slate-300); }
  .showcase-arrow:active { transform: scale(0.94); }
  .showcase-arrow:disabled { opacity: 0.35; cursor: default; pointer-events: none; }

  /* ---- Viewport: native scroll-snap track, bleeds to the container edges ---- */
  .showcase-viewport {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 16px 0 24px;
    cursor: grab;
  }
  .showcase-viewport::-webkit-scrollbar { display: none; }
  .showcase-viewport.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
    scroll-behavior: auto;
    user-select: none;
  }
  .showcase-viewport.is-dragging * { pointer-events: none; }
  .showcase-track {
    display: flex;
    gap: 24px;
  }

  .showcase-card {
    flex: 0 0 calc((100% - 48px) / 3);
    min-width: 0;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  /* On wide screens cap the card width so three-up cards don't grow huge (and
     tall) — the next card peeks in, signalling the track scrolls. */
  @media (min-width: 1024px) {
    .showcase-card { max-width: 440px; }
  }
  @media (max-width: 1023px) {
    .showcase-card { flex-basis: calc((100% - 24px) / 2); }
  }
  @media (max-width: 639px) {
    .showcase-head { flex-direction: column; align-items: flex-start; gap: 24px; }
    .showcase-card { flex-basis: 86%; }
  }

  /* ---- Visual zone: full-bleed 4:5 loop video ---- */
  .showcase-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 90% at 50% 0%, rgba(86, 179, 235, 0.08), transparent 60%),
      linear-gradient(180deg, var(--bg-app), var(--slate-50));
    box-shadow: var(--shadow-soft);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .showcase-card:hover .showcase-visual {
    transform: translateY(-6px);
    border-color: var(--slate-300);
    box-shadow: var(--shadow-soft-hover);
  }
  /* The video matches the 4:5 box exactly, so cover fills it without cropping. */
  .cs-video-full {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---- Section entrance signature — when the section scrolls into view the
     cards rise + scale in with a smooth left-to-right cascade. One-shot, driven
     by the shared .reveal IntersectionObserver (so it's reliable under Lenis and
     never depends on live scroll position). #funktioner id wins over the generic
     .reveal rules in global.css. ---- */
  :global(html.reveal-ready) #funktioner .showcase-card.reveal {
    transform: translateY(46px) scale(0.97);
    filter: blur(7px);
    transition:
      opacity 0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1),
      filter 0.75s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  :global(html.reveal-ready) #funktioner .showcase-card.reveal.in-view {
    transform: none;
    filter: blur(0);
  }
  /* Even cascade across the six cards. */
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(2) { transition-delay: 0.07s; }
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(3) { transition-delay: 0.14s; }
  :global(html.reveal-ready) #funktioner .showcase-card:nth-child(4) { transition-delay: 0.21s; }

  /* ---- Card copy — sits below the visual card on the page background ---- */
  .showcase-body {
    padding: 22px 4px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .showcase-pill {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-primary);
    margin-top: 4px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .showcase-pill:hover { background: var(--bg-active); border-color: var(--slate-300); }
  .showcase-pill svg { width: 13px; height: 13px; transition: transform 0.2s ease; }
  .showcase-pill:hover svg { transform: translateX(3px); }
  .showcase-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--brand-primary);
    margin: 0;
  }
  .showcase-card p {
    font-size: var(--text-md);
    color: var(--slate-500);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-card { transition: none; }
    /* Entrance signature off — shared reveal already shows everything. */
    :global(html.reveal-ready) #funktioner .showcase-card.reveal {
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  // Play each loop video only while it is on screen (saves CPU when scrolled
  // away). Reduced motion leaves the poster frame and never autoplays.
  (function () {
    const videos = Array.from(
      document.querySelectorAll('#funktioner [data-video]'),
    ) as HTMLVideoElement[];
    if (videos.length === 0) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            void video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.3 },
    );
    videos.forEach((video) => io.observe(video));
  })();
</script>

<script>
  // Showcase carousel — the prev/next arrows slide the native scroll-snap track
  // one card at a time (smooth via CSS scroll-behavior). Touch swipe works
  // natively; the arrows disable at each end. No-JS leaves a scrollable track.
  (function () {
    const viewport = document.querySelector('[data-viewport]') as HTMLElement | null;
    const track = document.querySelector('[data-track]') as HTMLElement | null;
    const prev = document.querySelector('[data-prev]') as HTMLButtonElement | null;
    const next = document.querySelector('[data-next]') as HTMLButtonElement | null;
    if (!viewport || !track || !prev || !next) return;

    function step(): number {
      const card = track!.querySelector('.showcase-card') as HTMLElement | null;
      if (!card) return viewport!.clientWidth;
      const gap = parseFloat(getComputedStyle(track!).columnGap || '0') || 0;
      return card.offsetWidth + gap;
    }

    function update(): void {
      const max = viewport!.scrollWidth - viewport!.clientWidth - 1;
      prev!.disabled = viewport!.scrollLeft <= 0;
      next!.disabled = viewport!.scrollLeft >= max;
    }

    prev.addEventListener('click', () => viewport!.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => viewport!.scrollBy({ left: step(), behavior: 'smooth' }));
    viewport.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);

    // Drag-to-scroll with mouse / pen. Touch and horizontal trackpad/wheel
    // scrolling are handled natively by the scroll container.
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;

    viewport.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'touch') return; // touch scrolls natively
      dragging = true;
      moved = false;
      startX = e.clientX;
      startScroll = viewport!.scrollLeft;
      viewport!.setPointerCapture(e.pointerId);
      viewport!.classList.add('is-dragging');
    });
    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 3) moved = true;
      viewport!.scrollLeft = startScroll - dx;
    });
    function endDrag(e: PointerEvent): void {
      if (!dragging) return;
      dragging = false;
      viewport!.classList.remove('is-dragging');
      try { viewport!.releasePointerCapture(e.pointerId); } catch { /* already released */ }
      // Settle on the nearest card (mandatory snap re-applies once the class drops).
      const s = step();
      viewport!.scrollTo({ left: Math.round(viewport!.scrollLeft / s) * s, behavior: 'smooth' });
    }
    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);
    // Swallow the click that fires right after a drag.
    viewport.addEventListener('click', (e) => {
      if (moved) { e.preventDefault(); e.stopPropagation(); }
    }, true);
    viewport.addEventListener('dragstart', (e) => e.preventDefault());

    update();
  })();
</script>

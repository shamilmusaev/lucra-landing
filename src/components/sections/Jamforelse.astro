---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import ParticleField from '../ParticleField.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

const rows = [
  { label: s.cmpRow1Label, lucra: s.cmpRow1Lucra, genai: s.cmpRow1GenAi, status: s.cmpRow1Status },
  { label: s.cmpRow2Label, lucra: s.cmpRow2Lucra, genai: s.cmpRow2GenAi, status: s.cmpRow2Status },
  { label: s.cmpRow3Label, lucra: s.cmpRow3Lucra, genai: s.cmpRow3GenAi, status: s.cmpRow3Status },
  { label: s.cmpRow4Label, lucra: s.cmpRow4Lucra, genai: s.cmpRow4GenAi, status: s.cmpRow4Status },
  { label: s.cmpRow5Label, lucra: s.cmpRow5Lucra, genai: s.cmpRow5GenAi, status: s.cmpRow5Status },
  { label: s.cmpRow6Label, lucra: s.cmpRow6Lucra, genai: s.cmpRow6GenAi, status: s.cmpRow6Status },
  { label: s.cmpRow7Label, lucra: s.cmpRow7Lucra, genai: s.cmpRow7GenAi, status: s.cmpRow7Status },
];
const competitors = [
  { key: 'genai' as const, name: s.cmpColGenAi },
  { key: 'status' as const, name: s.cmpColStatus },
];
// Explicit row tracks: header + one per row. The solid Lucra panel spans
// grid-row 1 / -1; without declared tracks that -1 only reaches the first
// explicit line (the header), collapsing the panel. Declaring every track
// lets it cover all rows.
const gridRows = `auto repeat(${rows.length}, auto)`;
---

<section id="jamforelse" class="tone-slate">
  <ParticleField
    mask="radial-gradient(ellipse 100% 76% at 50% 42%, #000 0%, #000 46%, transparent 90%)"
  />
  <div class="container">
    <div class="section-head center reveal">
      <h2 class="section-title">{s.cmpTitle}</h2>
    </div>

    <div class="cmp reveal delay-1" data-scrollfx>
      <div class="cmp-grid" style={`grid-template-rows:${gridRows}`}>
        <!-- Highlighted Lucra column: a solid brand surface spanning every row,
             overhanging the top to carry the white logo. -->
        <div class="cmp-panel" aria-hidden="true"></div>

        <!-- Header row -->
        <div class="cmp-cell cmp-head c1" style="grid-row:1"></div>
        <div class="cmp-cell cmp-head cmp-head-lucra c2" style="grid-row:1">
          <img class="cmp-lucra-logo" src="/assets/logo.svg" alt="Lucra" width="30" height="28" />
          <span class="cmp-lucra-word">{s.cmpColLucra}</span>
        </div>
        {competitors.map((comp, i) => (
          <div class={`cmp-cell cmp-head c${i + 3}`} style="grid-row:1">{comp.name}</div>
        ))}

        <!-- Rows. The per-criterion wrapper is display:contents on desktop (the
             cells stay direct grid items) and becomes a self-contained card in
             the stacked phone layout. -->
        {rows.map((row, i) => (
          <div class="cmp-rowgroup">
            <div class:list={['cmp-cell', 'cmp-label', 'c1', i === 0 && 'is-first']} style={`grid-row:${i + 2}`}>
              {row.label}
            </div>
            <div class="cmp-cell cmp-lucra c2" style={`grid-row:${i + 2}`}>
              <span class="cmp-tag">{s.cmpColLucra}</span>
              <span class="cmp-val">
                <span class="cmp-mark cmp-check"><Icon name="check" size={16} stroke={2.4} /></span>
                <span>{row.lucra}</span>
              </span>
            </div>
            {competitors.map((comp, ci) => (
              <div class={`cmp-cell cmp-comp c${ci + 3}`} style={`grid-row:${i + 2}`}>
                <span class="cmp-tag">{comp.name}</span>
                <span class="cmp-val">
                  <span class="cmp-mark cmp-dash" aria-hidden="true"></span>
                  <span>{row[comp.key]}</span>
                </span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <p class="cmp-note reveal delay-2">{s.cmpNote}</p>
  </div>
</section>

<style>
#jamforelse {
  position: relative;
}
/* Content sits above the cursor-reactive dot field. */
#jamforelse > .container { position: relative; z-index: 1; }

.section-head.center { margin-bottom: 56px; }

.cmp-note {
  max-width: 760px;
  margin: 36px auto 0;
  text-align: center;
  font-size: var(--text-lg);
  line-height: 1.62;
  color: var(--slate-600);
  text-wrap: pretty;
  /* Contained bubble — a single light surface so the closing note reads as an
     intentional callout, not a stray line floating on the dot field. */
  background: var(--bg-paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
  padding: 20px 28px;
}

.cmp {
  max-width: 1280px;
  /* Top room so the Lucra panel can overhang above the table. */
  margin: 40px auto 0;
  position: relative;
}

.cmp-grid {
  display: grid;
  grid-template-columns: minmax(150px, 1.05fr) 1.22fr repeat(2, 1fr);
  position: relative;
  border: 1px solid var(--border);
  border-radius: var(--radius-shell);
  /* Frosted surface: the table reads as a card floating over the dot field —
     the cursor-reactive dots stay visible through it, softened. */
  background: color-mix(in srgb, var(--bg-paper) 42%, transparent);
  -webkit-backdrop-filter: blur(7px);
          backdrop-filter: blur(7px);
  box-shadow: 0 30px 70px -46px color-mix(in srgb, var(--brand-primary) 42%, transparent);
}

/* ============================================================
   Highlighted Lucra column — solid brand surface, white content
   ============================================================ */
.cmp-panel {
  grid-column: 2;
  grid-row: 1 / -1;
  margin-top: -34px;
  border-radius: var(--radius-shell);
  background:
    linear-gradient(
      180deg,
      color-mix(in srgb, var(--brand-primary) 90%, white) 0%,
      var(--brand-primary) 42%,
      color-mix(in srgb, var(--brand-primary) 84%, black) 100%
    );
  box-shadow:
    var(--shadow-pop),
    0 40px 90px -52px color-mix(in srgb, var(--brand-primary) 60%, transparent),
    inset 0 1px 0 color-mix(in srgb, var(--white) 16%, transparent);
  z-index: 0;
  transition:
    transform .6s cubic-bezier(.32, .72, 0, 1),
    box-shadow .6s cubic-bezier(.32, .72, 0, 1);
}
.cmp:hover .cmp-panel {
  transform: translateY(-4px);
  box-shadow:
    var(--shadow-pop),
    0 56px 110px -52px color-mix(in srgb, var(--brand-primary) 70%, transparent);
}

/* ============================================================
   Cells
   ============================================================ */
.cmp-cell {
  position: relative;
  z-index: 1;
  padding: 18px 24px;
  font-size: var(--text-md);
  line-height: 1.5;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
}
.cmp-cell.c1 { grid-column: 1; }
.cmp-cell.c2 { grid-column: 2; }
.cmp-cell.c3 { grid-column: 3; }
.cmp-cell.c4 { grid-column: 4; }

/* Criterion wrapper is layout-transparent on desktop — the cells inside stay
   direct grid items of .cmp-grid. */
.cmp-rowgroup { display: contents; }

/* The per-cell column tag only shows in the mobile stacked layout. */
.cmp-tag { display: none; }

/* Value row: leading good/bad mark + the statement. */
.cmp-val {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
/* Marks sit in a line-height-tall flex box so the glyph centres on the first
   text line and stays aligned whether the value wraps to one line or several. */
.cmp-mark {
  flex-shrink: 0;
  height: 1.5em;
  display: flex;
  align-items: center;
}
/* Lucra — white check (no heavy badge). */
.cmp-check { width: 16px; color: var(--white); }
.cmp-check :global(svg) { width: 16px; height: 16px; opacity: 0.92; }
/* Competitors — muted dash (reads as "lacking", quiet). */
.cmp-dash { width: 11px; }
.cmp-dash::before {
  content: "";
  display: block;
  width: 11px;
  height: 2px;
  border-radius: 2px;
  background: var(--slate-300);
}

/* Row dividers: hairline for the outer columns, soft white inside the panel. */
.cmp-cell:not(.cmp-head):not(.cmp-lucra) { border-top: 1px solid var(--border); }
.cmp-lucra:not(.is-first) { border-top: 1px solid color-mix(in srgb, var(--white) 14%, transparent); }
/* Faint vertical separator between the competitor columns. */
.cmp-cell.c4 { border-left: 1px solid color-mix(in srgb, var(--border) 65%, transparent); }

/* ---- Headers ---- */
.cmp-head {
  justify-content: flex-end;
  padding-top: 10px;
  padding-bottom: 20px;
  border-top: none;
}
.cmp-head.c3, .cmp-head.c4 {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--slate-400);
}
.cmp-head-lucra {
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 7px;
  padding-top: 0;
  padding-bottom: 20px;
}
.cmp-lucra-logo {
  width: 30px;
  height: 28px;
  display: block;
  /* Render the slate logo in white on the brand surface. */
  filter: brightness(0) invert(1);
  margin-top: -18px;
}
.cmp-lucra-word {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--white);
}

/* ---- Row label column ---- */
.cmp-label {
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--brand-primary);
}

/* ---- Values ---- */
.cmp-lucra { color: var(--white); font-weight: 500; }
.cmp-comp { color: var(--slate-500); }

/* ============================================================
   Mobile: one solid card per criterion — label header, the Lucra
   value as a brand row, competitors beneath with their column
   name as a tag. Contained surfaces instead of text floating
   over the dot field.
   ============================================================ */
@media (max-width: 880px) {
  /* Drop the desktop "table lays flat" 3D tilt; extra top room so the Lucra
     panel's overhang clears the section title (the panel pulls up 34px). */
  .cmp { margin-top: 64px; rotate: none; scale: none; translate: none; }
  #jamforelse .section-head.center { margin-bottom: 32px; }
  /* Clear paper bubble — same surface vocabulary as the criterion cards so the
     closing note reads as part of the set, not faint text on the dot field. */
  .cmp-note {
    margin-top: 24px;
    max-width: none;
    padding: 16px 18px;
    background: var(--bg-paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    font-size: var(--text-sm);
    line-height: 1.6;
    text-align: left;
  }

  /* Two-column comparison: ChatGPT (left, plain) vs Lucra (right, highlighted —
     the brand panel overhangs the top to carry the logo). The criterion-label
     column and the "Manuellt idag" column are dropped on phones. */
  .cmp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    background: var(--bg-paper);
    -webkit-backdrop-filter: none;
            backdrop-filter: none;
    box-shadow: var(--shadow-soft);
  }
  /* Dropped pieces. */
  .cmp-cell.c1, .cmp-head.c1,
  .cmp-cell.c4, .cmp-head.c4 { display: none; }
  /* Remap to two columns: ChatGPT → left, Lucra → right. */
  .cmp-cell.c3 { grid-column: 1; }
  .cmp-cell.c2 { grid-column: 2; }
  /* Re-show the brand panel as the continuous Lucra column. */
  .cmp-panel { display: block; border-radius: var(--radius-card); }

  /* Compact cells; plain text (drop the ✓/— marks and per-cell tags). */
  .cmp-cell { padding: 14px 15px; font-size: var(--text-sm); gap: 0; }
  .cmp-mark, .cmp-tag { display: none; }
  .cmp-val { display: block; }
  .cmp-comp .cmp-val { color: var(--slate-500); }

  /* Column headers at the top of each column. */
  .cmp-head { display: flex; }
  .cmp-head.c3 { justify-content: flex-start; align-items: flex-end; padding: 14px 15px; }
  .cmp-head-lucra { padding-bottom: 16px; }
  .cmp-lucra-logo { width: 26px; height: 24px; margin-top: -16px; }
  .cmp-lucra-word { font-size: 16px; }
}

/* ---- Scroll-linked signature: the comparison table lays flat — it enters with
   a slight backward tilt + scale and straightens as it reaches centre, like a
   card set down in front of you. Driven by --p (ScrollFx) via individual
   rotate/scale props (parent supplies the perspective), composing with reveal.
   --q: 0 below the fold → 1 at centre, then held. ---- */
#jamforelse .container { perspective: 1400px; }
.cmp {
  --q: clamp(0, calc(var(--p, 0.5) * 2), 1);
  --r: calc(var(--p, 0.5) - 0.5);
  rotate: x calc(9deg * (1 - var(--q)));
  scale: calc(0.88 + 0.12 * var(--q));
  translate: 0 calc(-30px * var(--r));
  will-change: rotate, scale, translate;
}

@media (prefers-reduced-motion: reduce) {
  .cmp-panel { transition: none; }
  .cmp:hover .cmp-panel { transform: none; }
  .cmp { rotate: none; scale: none; translate: none; }
}

/* No 3D entrance on phones: the tilt reads as jank mid-scroll and shifts the
   tall stacked list. Must follow the tilt rules above to win the cascade. */
@media (max-width: 880px) {
  #jamforelse .container { perspective: none; }
  .cmp { rotate: none; scale: none; translate: none; will-change: auto; }
}
</style>

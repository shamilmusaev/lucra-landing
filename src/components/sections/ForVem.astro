---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
import { CONTACT_MAILTO } from '../../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

const foretagareCards = [
  { icon: 'trending-up', tab: s.forVemCard1Tab, today: s.forVemCard1Today, lucra: s.forVemCard1Lucra },
  { icon: 'message-circle', tab: s.forVemCard2Tab, today: s.forVemCard2Today, lucra: s.forVemCard2Lucra },
  { icon: 'target', tab: s.forVemCard3Tab, today: s.forVemCard3Today, lucra: s.forVemCard3Lucra },
];
const byraCards = [
  { icon: 'building-2', tab: s.forVemCard5Tab, today: s.forVemCard5Today, lucra: s.forVemCard5Lucra },
  { icon: 'clock', tab: s.forVemCard6Tab, today: s.forVemCard6Today, lucra: s.forVemCard6Lucra },
  { icon: 'shield-check', tab: s.forVemCard7Tab, today: s.forVemCard7Today, lucra: s.forVemCard7Lucra },
];
const groups = [
  { id: 'for-foretagare', label: s.forVemGroupForetagare, cards: foretagareCards },
  { id: 'for-byra', label: s.forVemGroupByra, cards: byraCards },
];
---

<section id="for-vem">
  <div class="container fv-layout">
    <aside class="fv-aside reveal">
      <h2 class="section-title">{s.forVemTitle}</h2>
      <p class="section-sub">{s.forVemSub}</p>
      <a class="btn btn-primary btn-lg fv-cta" href={CONTACT_MAILTO}>{s.forVemCta}</a>
    </aside>

    <!-- Phone-only segmented switch: one audience at a time instead of the
         full stacked list (revealed by JS via data-fv-active; without JS both
         groups stay visible and the switch stays hidden). -->
    <div class="fv-switch">
      {groups.map((group, index) => (
        <button
          class:list={['fv-switch-btn', index === 0 && 'is-active']}
          type="button"
          aria-pressed={index === 0 ? 'true' : 'false'}
          aria-controls={group.id}
          data-fv-switch={index}
        >{group.label}</button>
      ))}
    </div>

    <div class="fv-groups">
      {groups.map((group) => (
        <div class="fv-group" id={group.id}>
          <span class="section-eyebrow fv-grouplabel reveal">{group.label}</span>
          <div class="fv-stack">
            {group.cards.map((card, index) => (
              <article class="fv-card" style={`--i:${index}`}>
                <span class="fv-tab">
                  <Icon name={card.icon} size={15} stroke={2} />
                  {card.tab}
                </span>
                <div class="fv-body">
                  <div class="fv-block fv-block-today">
                    <span class="fv-blocklabel fv-today-label">{s.forVemTodayLabel}</span>
                    <p class="fv-text fv-today">{card.today}</p>
                  </div>
                  <div class="fv-block fv-block-lucra">
                    <span class="fv-blocklabel fv-lucra-label">
                      {s.forVemLucraLabel}
                      <img class="fv-lucra-logo" src="/assets/logo.svg" alt="" width="11" height="10" aria-hidden="true" />
                    </span>
                    <p class="fv-text fv-lucra">{card.lucra}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* Clear the fixed nav when deep-linked from the Lösningar menu (matches the
   .fv-card pin offset) */
#for-foretagare, #for-byra { scroll-margin-top: 120px; }
.fv-layout {
  display: grid;
  /* Columns sized to content and centered, so leftover space sits at the
     edges instead of as a big gap between the cards and the text */
  grid-template-columns: minmax(0, 500px) minmax(0, 430px);
  justify-content: center;
  gap: clamp(40px, 5vw, 96px);
  align-items: start;
}

/* Left column: two audience groups stacked vertically */
.fv-groups {
  order: 1;
  display: flex;
  flex-direction: column;
  /* Generous gap so the first group's last card unpins before the next label */
  gap: clamp(56px, 8vw, 120px);
}

.fv-group {
  display: flex;
  flex-direction: column;
}

/* Audience label sits in normal flow above its stack (scrolls, not pinned) */
.fv-grouplabel {
  align-self: flex-start;
  margin-bottom: 24px;
}

/* Right column pins while the card stack scrolls past */
.fv-aside {
  order: 2;
  position: sticky;
  top: 120px;
  align-self: start;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.fv-aside .section-title,
.fv-aside .section-sub {
  margin-bottom: 0;
}

.fv-cta {
  align-self: flex-start;
  margin-top: 6px;
}

/* Card stack — pure-CSS sticky stacking */
.fv-stack {
  display: flex;
  flex-direction: column;
  gap: clamp(28px, 4vw, 56px);
}

.fv-card {
  position: sticky;
  /* All cards pin at the same height; tabs fan out sideways like a drawer */
  top: 120px;
  /* Shrinks toward its top edge as the next card covers it (recede-into-depth) */
  transform-origin: center top;
  will-change: transform;
  /* Tight, soft shadow traces the tab + body silhouette as one folder shape */
  filter: drop-shadow(0 6px 14px rgba(15, 23, 42, .07));
}

/* Narrow folder tab with soft flared base corners (browser-tab technique) */
.fv-tab {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  width: fit-content;
  /* Each tab steps right by index so the back tabs stay visible, not buried */
  margin-left: calc(14px + var(--i) * clamp(76px, 18%, 100px));
  padding: 8px 16px;
  background: var(--bg-paper);
  border-radius: 12px 12px 0 0;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.005em;
  color: var(--brand-primary);
}

.fv-tab svg {
  width: 15px;
  height: 15px;
  color: var(--brand-accent);
  flex-shrink: 0;
}

.fv-tab::before,
.fv-tab::after {
  content: "";
  position: absolute;
  bottom: 0;
  width: 12px;
  height: 12px;
  background: var(--bg-paper);
}

.fv-tab::before {
  left: -12px;
  -webkit-mask: radial-gradient(circle at top left, transparent 12px, #000 12.5px);
          mask: radial-gradient(circle at top left, transparent 12px, #000 12.5px);
}

.fv-tab::after {
  right: -12px;
  -webkit-mask: radial-gradient(circle at top right, transparent 12px, #000 12.5px);
          mask: radial-gradient(circle at top right, transparent 12px, #000 12.5px);
}

.fv-body {
  background: var(--bg-paper);
  border-radius: var(--radius-card);
  /* overlap the tab by 1px so the two white shapes read as one */
  margin-top: -1px;
  padding: 36px 32px 40px;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.fv-block {
  border-left: 2px solid var(--slate-300);
  padding-left: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.fv-block-lucra {
  border-left-color: var(--brand-primary);
}

.fv-blocklabel {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* slate-500 (not 400) clears the 4.5:1 contrast floor for this small label. */
.fv-today-label { color: var(--slate-500); }
.fv-lucra-label {
  color: var(--brand-primary);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.fv-lucra-logo { width: 11px; height: 10px; display: block; }

.fv-text {
  margin: 0;
  font-size: 15px;
  line-height: 1.6;
}

.fv-today { color: var(--slate-500); }
.fv-lucra { color: var(--fg-primary); }

/* ---- Scroll-linked side-swap: while the "För företagare" cards scroll past,
   the heading sits on the right; as the "För redovisningsbyråer" group arrives,
   the heading glides to the left and that group's cards take the right side.
   --swap (0→1, transition progress) and --swapx (px distance between the two
   columns) are set from JS; translate is the individual prop so it composes with
   reveal + the sticky pin. ---- */
.fv-aside { translate: calc(var(--swapx, 0px) * -1 * var(--swap, 0)) 0; }
/* The group travels its own (possibly clamped) distance: the card column is
   wider than the aside column, so the full --swapx would push it past the
   viewport edge on ~960–1240px screens (horizontal page scroll). */
.fv-groups .fv-group:nth-child(2) {
  translate: calc(var(--swapx-group, 0px) * var(--swap, 0)) 0;
  will-change: translate;
}

/* Hidden on desktop; shown on phones once JS arms data-fv-active. */
.fv-switch { display: none; }

@media (max-width: 860px) {
  .fv-layout { grid-template-columns: 1fr; }
  /* Restore source order: heading first, switch, grouped cards below */
  .fv-aside { order: 0; position: static; }
  .fv-groups { order: 2; gap: clamp(40px, 9vw, 64px); }
  /* Keep the sticky stack so the active group's cards overlap as you scroll
     (like desktop) — pure CSS, no rAF. The JS scale-recede is desktop-only. */
  .fv-card { position: sticky; top: 76px; will-change: auto; }
  .fv-tab { margin-left: clamp(16px, 5vw, 28px); }
  /* Single column — no side-swap. */
  .fv-aside,
  .fv-groups .fv-group:nth-child(2) { translate: none; will-change: auto; }

  #for-vem[data-fv-active] .fv-switch {
    display: flex;
    order: 1;
    gap: 4px;
    padding: 4px;
    margin-top: 28px;
    background: var(--bg-app);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    width: fit-content;
  }
  .fv-switch-btn {
    border: 0;
    background: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    /* slate-600 clears 4.5:1 on the tinted switch track. */
    color: var(--slate-600);
    padding: 10px 16px;
    border-radius: var(--radius-pill);
  }
  .fv-switch-btn.is-active {
    background: var(--bg-paper);
    color: var(--brand-primary);
    box-shadow: var(--shadow-sm);
  }
  /* One audience at a time; the eyebrow duplicates the active button label. */
  #for-vem[data-fv-active] .fv-grouplabel { display: none; }
  #for-vem[data-fv-active="0"] .fv-groups .fv-group:nth-child(2) { display: none; }
  #for-vem[data-fv-active="1"] .fv-groups .fv-group:nth-child(1) { display: none; }
}

/* No scroll-driven overlap when motion is reduced — plain stacked list */
@media (prefers-reduced-motion: reduce) {
  .fv-aside { position: static; }
  .fv-card { position: static; }
  .fv-aside,
  .fv-groups .fv-group:nth-child(2) { translate: none; }
}
</style>

<script>
  // As each card pins, the next one rising over it makes it shrink + dim —
  // the covered card recedes into depth while the new one lays on top.
  const section = document.getElementById('for-vem');
  // Each group is its own stack; the recede effect must stay within a stack so
  // the last företagare card doesn't react to the first byrå card across the gap.
  const stacks = section
    ? Array.from(section.querySelectorAll<HTMLElement>('.fv-stack')).map((stack) =>
        Array.from(stack.querySelectorAll<HTMLElement>('.fv-card')),
      )
    : [];
  const allCards = stacks.flat();
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Touch keeps the CSS sticky overlap but skips the JS scale-recede + side-swap
  // (no scroll-rAF on phones — perf).
  const coarse = window.matchMedia('(pointer: coarse)').matches;

  // Side-swap targets: the sticky heading and the second audience group trade
  // sides as the second group scrolls in (see the --swap/--swapx CSS).
  const aside = section?.querySelector<HTMLElement>('.fv-aside') ?? null;
  const groups = section?.querySelector<HTMLElement>('.fv-groups') ?? null;
  const secondGroup = section
    ? section.querySelectorAll<HTMLElement>('.fv-group')[1] ?? null
    : null;

  if (allCards.length > 1 && !reduce && !coarse) {
    const PIN = 120; // must match .fv-card top
    const COVER = 440; // distance over which the previous card recedes
    let active = false;
    let ticking = false;

    const frame = (): void => {
      ticking = false;
      // Only run the stack effect while cards are actually sticky (desktop)
      if (window.getComputedStyle(allCards[0]).position !== 'sticky') {
        allCards.forEach((card) => {
          card.style.transform = '';
        });
        section?.style.removeProperty('--swap');
        section?.style.removeProperty('--swapx');
        section?.style.removeProperty('--swapx-group');
        if (aside) aside.style.opacity = '';
        if (secondGroup) secondGroup.style.opacity = '';
        return;
      }
      // Side-swap: progress runs 0→1 as the second group rises from the lower
      // viewport toward the pin line; --swapx is the layout gap between the two
      // columns (offsetLeft is unaffected by our own translate).
      if (section && aside && groups && secondGroup) {
        const swapx = aside.offsetLeft - groups.offsetLeft;
        section.style.setProperty('--swapx', `${swapx}px`);
        // Cap the group's travel so its right edge stays inside the viewport
        // (.fv-groups is never translated, so its rect is the resting column).
        const maxSwapx =
          document.documentElement.clientWidth -
          groups.getBoundingClientRect().left -
          secondGroup.offsetWidth;
        section.style.setProperty('--swapx-group', `${Math.min(swapx, maxSwapx)}px`);
        const vh = window.innerHeight;
        const secondTop = secondGroup.getBoundingClientRect().top;
        // Start the swap only after the first group's last card has settled at
        // the pin line; finish it as the second group's first card pins.
        const swap = Math.min(1, Math.max(0, (vh * 0.44 - secondTop) / (vh * 0.36)));
        section.style.setProperty('--swap', swap.toFixed(4));
        // Cross-dissolve the moving blocks so they never visibly overlap the
        // pinned cards mid-swap (fully transparent at the halfway point).
        const fade = Math.abs(swap * 2 - 1);
        aside.style.opacity = fade.toFixed(4);
        secondGroup.style.opacity = fade.toFixed(4);
      }
      for (const cards of stacks) {
        for (let index = 0; index < cards.length; index++) {
          const next = cards[index + 1];
          let progress = 0;
          if (next) {
            const nextTop = next.getBoundingClientRect().top;
            progress = Math.min(1, Math.max(0, 1 - (nextTop - PIN) / COVER));
          }
          const scale = 1 - progress * 0.05;
          const lift = -progress * 14;
          cards[index].style.transform = `translateY(${lift}px) scale(${scale})`;
        }
      }
    };

    const onScroll = (): void => {
      if (active && !ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };

    const io = new IntersectionObserver(
      (entries) => {
        active = entries[0].isIntersecting;
        if (active) frame();
      },
      { rootMargin: '120px' },
    );
    io.observe(section!);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    frame();
  }

  // Phone-only audience switch: arming data-fv-active reveals the segmented
  // control and collapses the list to one group (see the ≤860px CSS). Deep
  // links from the Lösningar menu must still land on their group.
  const switchButtons = section
    ? Array.from(section.querySelectorAll<HTMLButtonElement>('.fv-switch-btn'))
    : [];
  const groupElements = section
    ? Array.from(section.querySelectorAll<HTMLElement>('.fv-group'))
    : [];
  if (section && switchButtons.length === groupElements.length && switchButtons.length > 0) {
    const activate = (index: number): void => {
      section.dataset.fvActive = String(index);
      switchButtons.forEach((button, buttonIndex) => {
        button.classList.toggle('is-active', buttonIndex === index);
        button.setAttribute('aria-pressed', buttonIndex === index ? 'true' : 'false');
      });
    };
    activate(0);
    switchButtons.forEach((button, index) => {
      button.addEventListener('click', () => activate(index));
    });
    const applyHash = (): void => {
      const index = groupElements.findIndex((group) => `#${group.id}` === location.hash);
      if (index < 0) return;
      activate(index);
      requestAnimationFrame(() => groupElements[index]?.scrollIntoView());
    };
    window.addEventListener('hashchange', applyHash);
    if (location.hash) applyHash();
  }
</script>

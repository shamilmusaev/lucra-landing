---
import { getStrings, type Lang } from '../../i18n/utils';
import Icon from '../Icon.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);

const foretagareCards = [
  { icon: 'trending-up', tab: s.forVemCard1Tab, today: s.forVemCard1Today, lucra: s.forVemCard1Lucra },
  { icon: 'message-circle', tab: s.forVemCard2Tab, today: s.forVemCard2Today, lucra: s.forVemCard2Lucra },
  { icon: 'target', tab: s.forVemCard3Tab, today: s.forVemCard3Today, lucra: s.forVemCard3Lucra },
  { icon: 'calendar-clock', tab: s.forVemCard4Tab, today: s.forVemCard4Today, lucra: s.forVemCard4Lucra },
];
const byraCards = [
  { icon: 'building-2', tab: s.forVemCard5Tab, today: s.forVemCard5Today, lucra: s.forVemCard5Lucra },
  { icon: 'clock', tab: s.forVemCard6Tab, today: s.forVemCard6Today, lucra: s.forVemCard6Lucra },
  { icon: 'shield-check', tab: s.forVemCard7Tab, today: s.forVemCard7Today, lucra: s.forVemCard7Lucra },
];
const groups = [
  { label: s.forVemGroupForetagare, cards: foretagareCards },
  { label: s.forVemGroupByra, cards: byraCards },
];
---

<section id="for-vem">
  <div class="container fv-layout">
    <aside class="fv-aside reveal">
      <h2 class="section-title">{s.forVemTitle}</h2>
      <p class="section-sub">{s.forVemSub}</p>
      <a class="btn btn-primary btn-lg fv-cta" href="[CALENDLY_URL]">{s.forVemCta}</a>
    </aside>

    <div class="fv-groups">
      {groups.map((group) => (
        <div class="fv-group">
          <span class="section-eyebrow fv-grouplabel reveal">{group.label}</span>
          <div class="fv-stack">
            {group.cards.map((card, index) => (
              <article class="fv-card" style={`--i:${index}`}>
                <span class="fv-tab">
                  <Icon name={card.icon} size={15} stroke={2} />
                  {card.tab}
                </span>
                <div class="fv-body">
                  <div class="fv-block fv-block-today">
                    <span class="fv-blocklabel fv-today-label">{s.forVemTodayLabel}</span>
                    <p class="fv-text fv-today">{card.today}</p>
                  </div>
                  <div class="fv-block fv-block-lucra">
                    <span class="fv-blocklabel fv-lucra-label">{s.forVemLucraLabel}</span>
                    <p class="fv-text fv-lucra">{card.lucra}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.fv-layout {
  display: grid;
  /* Columns sized to content and centered, so leftover space sits at the
     edges instead of as a big gap between the cards and the text */
  grid-template-columns: minmax(0, 500px) minmax(0, 430px);
  justify-content: center;
  gap: clamp(40px, 5vw, 96px);
  align-items: start;
}

/* Left column: two audience groups stacked vertically */
.fv-groups {
  order: 1;
  display: flex;
  flex-direction: column;
  /* Generous gap so the first group's last card unpins before the next label */
  gap: clamp(56px, 8vw, 120px);
}

.fv-group {
  display: flex;
  flex-direction: column;
}

/* Audience label sits in normal flow above its stack (scrolls, not pinned) */
.fv-grouplabel {
  align-self: flex-start;
  margin-bottom: 24px;
}

/* Right column pins while the card stack scrolls past */
.fv-aside {
  order: 2;
  position: sticky;
  top: 120px;
  align-self: start;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.fv-aside .section-title,
.fv-aside .section-sub {
  margin-bottom: 0;
}

.fv-cta {
  align-self: flex-start;
  margin-top: 6px;
}

/* Card stack — pure-CSS sticky stacking */
.fv-stack {
  display: flex;
  flex-direction: column;
  gap: clamp(28px, 4vw, 56px);
}

.fv-card {
  position: sticky;
  /* All cards pin at the same height; tabs fan out sideways like a drawer */
  top: 120px;
  /* Shrinks toward its top edge as the next card covers it (recede-into-depth) */
  transform-origin: center top;
  will-change: transform;
  /* Tight, soft shadow traces the tab + body silhouette as one folder shape */
  filter: drop-shadow(0 6px 14px rgba(15, 23, 42, .07));
}

/* Narrow folder tab with soft flared base corners (browser-tab technique) */
.fv-tab {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  width: fit-content;
  /* Each tab steps right by index so the back tabs stay visible, not buried.
     Base inset clears the body's rounded top-left corner (radius + 12px flare
     width) so the first tab's flared base sits on the flat edge, not over the
     corner cut-out where it would tear. */
  margin-left: calc(var(--radius-card) + 12px + var(--i) * clamp(76px, 18%, 100px));
  padding: 8px 16px;
  background: var(--bg-paper);
  border-radius: 12px 12px 0 0;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.005em;
  color: var(--brand-primary);
}

.fv-tab svg {
  width: 15px;
  height: 15px;
  color: var(--brand-accent);
  flex-shrink: 0;
}

.fv-tab::before,
.fv-tab::after {
  content: "";
  position: absolute;
  bottom: 0;
  width: 12px;
  height: 12px;
  background: var(--bg-paper);
}

.fv-tab::before {
  left: -12px;
  -webkit-mask: radial-gradient(circle at top left, transparent 12px, #000 12.5px);
          mask: radial-gradient(circle at top left, transparent 12px, #000 12.5px);
}

.fv-tab::after {
  right: -12px;
  -webkit-mask: radial-gradient(circle at top right, transparent 12px, #000 12.5px);
          mask: radial-gradient(circle at top right, transparent 12px, #000 12.5px);
}

.fv-body {
  background: var(--bg-paper);
  border-radius: var(--radius-card);
  /* overlap the tab by 1px so the two white shapes read as one */
  margin-top: -1px;
  padding: 36px 32px 40px;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.fv-block {
  border-left: 2px solid var(--slate-300);
  padding-left: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.fv-block-lucra {
  border-left-color: var(--brand-primary);
}

.fv-blocklabel {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.fv-today-label { color: var(--slate-400); }
.fv-lucra-label { color: var(--brand-primary); }

.fv-text {
  margin: 0;
  font-size: 15px;
  line-height: 1.6;
}

.fv-today { color: var(--slate-500); }
.fv-lucra { color: var(--fg-primary); }

@media (max-width: 860px) {
  .fv-layout { grid-template-columns: 1fr; }
  /* Restore source order: heading first, grouped cards below */
  .fv-aside { order: 0; position: static; }
  .fv-groups { order: 1; gap: clamp(40px, 9vw, 64px); }
  .fv-card { position: static; }
  /* Single column, no fan: fixed inset that still clears the rounded corner. */
  .fv-tab { margin-left: calc(var(--radius-card) + 12px); }
}

/* No scroll-driven overlap when motion is reduced — plain stacked list */
@media (prefers-reduced-motion: reduce) {
  .fv-aside { position: static; }
  .fv-card { position: static; }
}
</style>

<script>
  // As each card pins, the next one rising over it makes it shrink + dim —
  // the covered card recedes into depth while the new one lays on top.
  const section = document.getElementById('for-vem');
  // Each group is its own stack; the recede effect must stay within a stack so
  // the last företagare card doesn't react to the first byrå card across the gap.
  const stacks = section
    ? Array.from(section.querySelectorAll<HTMLElement>('.fv-stack')).map((stack) =>
        Array.from(stack.querySelectorAll<HTMLElement>('.fv-card')),
      )
    : [];
  const allCards = stacks.flat();
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (allCards.length > 1 && !reduce) {
    const PIN = 120; // must match .fv-card top
    const COVER = 440; // distance over which the previous card recedes
    let active = false;
    let ticking = false;

    const frame = (): void => {
      ticking = false;
      // Only run the stack effect while cards are actually sticky (desktop)
      if (window.getComputedStyle(allCards[0]).position !== 'sticky') {
        allCards.forEach((card) => {
          card.style.transform = '';
        });
        return;
      }
      for (const cards of stacks) {
        for (let index = 0; index < cards.length; index++) {
          const next = cards[index + 1];
          let progress = 0;
          if (next) {
            const nextTop = next.getBoundingClientRect().top;
            progress = Math.min(1, Math.max(0, 1 - (nextTop - PIN) / COVER));
          }
          const scale = 1 - progress * 0.05;
          const lift = -progress * 14;
          cards[index].style.transform = `translateY(${lift}px) scale(${scale})`;
        }
      }
    };

    const onScroll = (): void => {
      if (active && !ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };

    const io = new IntersectionObserver(
      (entries) => {
        active = entries[0].isIntersecting;
        if (active) frame();
      },
      { rootMargin: '120px' },
    );
    io.observe(section!);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    frame();
  }
</script>

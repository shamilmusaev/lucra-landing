---
// Footer — ported from index.html lines 3984–4049.
// Language switch converted from JS-toggled buttons to route-based anchors:
//   SV → href="/"   (root route)
//   EN → href="/en/" (English route)
// The current language is marked active via `aria-current="page"` and `.is-active`.
// No lang-toggle JS is used — routing handles language selection.
import { getStrings, type Lang } from '../i18n/utils';
import { APP_LOGIN_URL, BOOK_DEMO_URL } from '../config';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
// Legal / homepage-section links must resolve from any route (incl. /privacy,
// /terms, 404), so prefix targets with the active language.
const enPrefix = lang === 'en' ? '/en' : '';
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <a href={`${enPrefix}/`} class="brand">
          <img src="/assets/logo.svg" alt="Lucra" width="26" height="24" />
          <span class="brand-word">Lucra</span>
        </a>
        <p>{s.footerTagline}</p>
      </div>
      <div class="footer-col">
        <h2>{s.footerColProduct}</h2>
        <ul>
          <li><a href={`${enPrefix}/#funktioner`}>{s.footerLinkFeatures}</a></li>
          <li><a href={`${enPrefix}/#jamforelse`}>{s.footerLinkCompare}</a></li>
          <li><a href={`${enPrefix}/#upplagg`}>{s.footerLinkPricing}</a></li>
          <li><a href={`${enPrefix}/#sakerhet`}>{s.footerLinkSecurity}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h2>{s.footerColCompany}</h2>
        <ul>
          <li><a href={BOOK_DEMO_URL} data-calendly target="_blank" rel="noopener">{s.footerLinkBookDemo}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h2>{s.footerColLegal}</h2>
        <ul>
          <li><a href={`${enPrefix}/privacy/`}>{s.footerLinkPrivacy}</a></li>
          <li><a href={`${enPrefix}/terms/`}>{s.footerLinkTerms}</a></li>
          <li><a href={`${enPrefix}/#sakerhet`}>{s.footerLinkSecurityPage}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h2>{s.footerColAccount}</h2>
        <ul>
          <li><a href={APP_LOGIN_URL}>{s.footerLinkLogin}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bar">
      <div class="copy">{s.footerCopy}</div>
      <div class="footer-end">
        <div class="lang-switch" role="group" aria-label="Språk / Language">
          <a
            href="/"
            class:list={['lang-opt', { 'is-active': lang === 'sv' }]}
            aria-current={lang === 'sv' ? 'page' : undefined}
          >SV</a>
          <a
            href="/en/"
            class:list={['lang-opt', { 'is-active': lang === 'en' }]}
            aria-current={lang === 'en' ? 'page' : undefined}
          >EN</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    background:
      radial-gradient(120% 80% at 50% 0%,
        color-mix(in srgb, var(--brand-primary) 5%, transparent), transparent 60%),
      var(--bg-app);
    /* env() is 0 on desktop; keeps the footer clear of the home indicator on
       phones (viewport-fit=cover). */
    padding: 72px 0 calc(36px + env(safe-area-inset-bottom));
    border-top: 1px solid color-mix(in srgb, var(--brand-primary) 14%, var(--border));
  }
  /* Full-width brand accent rule on the top divider, with a soft highlight
     that sweeps slate→cyan across it — grounds the footer and adds life. */
  footer::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      transparent 28%,
      var(--brand-primary) 40%,
      var(--brand-accent) 50%,
      var(--brand-primary) 60%,
      transparent 72%,
      transparent 100%
    );
    background-size: 200% 100%;
    background-repeat: no-repeat;
    animation: footerAccentSweep 7s ease-in-out infinite;
  }
  @keyframes footerAccentSweep {
    0%   { background-position: 130% 0; }
    100% { background-position: -30% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    footer::before {
      animation: none;
      /* Static subtle accent at the left when motion is reduced. */
      background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent), transparent 60%);
    }
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  /* Logo + wordmark on one row (Nav's .brand styles are scoped, re-declare here). */
  .footer-about .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  /* Footer wordmark — brand gradient (the Nav's is scoped, so re-declare here). */
  .footer-about .brand-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.02em;
    background: var(--brand-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .footer-about p {
    font-size: 13px;
    color: var(--slate-600);
    line-height: 1.6;
    margin: 16px 0 0;
    max-width: 280px;
  }
  /* h2 for correct heading order (these follow the page's section h2s); the
     small-label look is purely visual. */
  .footer-col h2 {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    /* Match the old h5's inherited 1.5 (global h2 is 1.3) so the heading-order
       tag swap doesn't reflow the footer. */
    line-height: 1.5;
    color: var(--brand-primary);
    margin: 0 0 16px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    display: inline-block;
    font-size: 13px;
    color: var(--slate-600);
    transition: color .2s ease, transform .2s ease;
  }
  .footer-col a:hover {
    color: var(--brand-primary);
    transform: translateX(3px);
  }
  .footer-bar {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-bar .copy {
    font-size: 12px;
    color: var(--slate-400);
  }
  .footer-end {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  /* ---- Language switch (base) ---- */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: var(--bg-paper);
  }
  .lang-opt {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--slate-500);
    padding: 5px 11px;
    border: 0;
    background: transparent;
    border-radius: var(--radius-pill);
    cursor: pointer;
    line-height: 1;
    text-decoration: none;
    transition: color .2s ease, background .2s ease;
  }
  .lang-opt:hover { color: var(--brand-primary); }
  /* Active state — mirrors legacy aria-pressed="true" styling */
  .lang-opt.is-active,
  .lang-opt[aria-current="page"] {
    background: var(--brand-primary);
    color: var(--white);
  }

  /* ---- Language switch — footer context (slightly smaller) ---- */
  .footer-end .lang-switch { padding: 2px; }
  .footer-end .lang-opt { padding: 5px 10px; }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 32px; }
    .footer-grid .footer-col:last-child {
      grid-column: 2 / span 3;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
    .footer-grid .footer-col:last-child h2 { grid-column: 1 / -1; }
  }
  @media (max-width: 960px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-grid .footer-col:last-child {
      grid-column: auto;
      display: flex;
      flex-direction: column;
    }
    /* Comfortable tap targets on touch: links get height, the lang pills grow. */
    .footer-col a { display: flex; align-items: center; min-height: 40px; }
    .footer-end .lang-opt { padding: 9px 16px; }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>

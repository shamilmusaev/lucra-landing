---
// Footer — ported from index.html lines 3984–4049.
// Language switch converted from JS-toggled buttons to route-based anchors:
//   SV → href="/"   (root route)
//   EN → href="/en/" (English route)
// The current language is marked active via `aria-current="page"` and `.is-active`.
// No lang-toggle JS is used — routing handles language selection.
import { getStrings, type Lang } from '../i18n/utils';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <a href="/" class="brand">
          <img src="/assets/logo.svg" alt="Lucra" width="26" height="24" />
          <span class="brand-word">Lucra</span>
        </a>
        <p>{s.footerTagline}</p>
      </div>
      <div class="footer-col">
        <h5>{s.footerColProduct}</h5>
        <ul>
          <li><a href="#funktioner">{s.footerLinkFeatures}</a></li>
          <li><a href="#sa-funkar-det">{s.footerLinkHowItWorks}</a></li>
          <li><a href="#integrationer">{s.footerLinkIntegrations}</a></li>
          <li><a href="#sakerhet">{s.footerLinkSecurity}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{s.footerColCompany}</h5>
        <ul>
          <li><a href="/about">{s.footerLinkAbout}</a></li>
          <li><a href="/contact">{s.footerLinkContact}</a></li>
          <li><a href="/careers">{s.footerLinkCareers}</a></li>
          <li><a href="[CALENDLY_URL]">{s.footerLinkBookDemo}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{s.footerColLegal}</h5>
        <ul>
          <li><a href="/privacy">{s.footerLinkPrivacy}</a></li>
          <li><a href="/terms">{s.footerLinkTerms}</a></li>
          <li><a href="/dpa">{s.footerLinkDpa}</a></li>
          <li><a href="/security">{s.footerLinkSecurityPage}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{s.footerColAccount}</h5>
        <ul>
          <li><a href="/login">{s.footerLinkLogin}</a></li>
          <li><a href="/signup">{s.footerLinkSignup}</a></li>
          <li><a href="mailto:[KONTAKT_EMAIL]">[kontakt&#64;lucra.ai]</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bar">
      <div class="copy">{s.footerCopy}</div>
      <div class="footer-end">
        <div class="lang-switch" role="group" aria-label="Språk / Language">
          <a
            href="/"
            class:list={['lang-opt', { 'is-active': lang === 'sv' }]}
            aria-current={lang === 'sv' ? 'page' : undefined}
          >SV</a>
          <a
            href="/en/"
            class:list={['lang-opt', { 'is-active': lang === 'en' }]}
            aria-current={lang === 'en' ? 'page' : undefined}
          >EN</a>
        </div>
        <div class="social-row">
          <a href="[LINKEDIN_URL]" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.5c0-1.3-.02-3-1.83-3-1.84 0-2.12 1.43-2.12 2.9V21h-4V9z"/></svg>
          </a>
          <a href="[X_URL]" aria-label="X">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21l-6.45 7.37L22.5 22h-6.84l-4.78-6.27L5.2 22H2.45l6.9-7.89L1.5 2h6.99l4.32 5.71L18.244 2zm-1.2 18h1.65L7.06 4H5.3l11.744 16z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    background:
      radial-gradient(120% 80% at 50% 0%,
        color-mix(in srgb, var(--brand-primary) 5%, transparent), transparent 60%),
      var(--bg-app);
    padding: 72px 0 36px;
    border-top: 1px solid color-mix(in srgb, var(--brand-primary) 14%, var(--border));
  }
  /* Thin brand accent rule sitting on the top divider — grounds the footer. */
  footer::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 180px;
    height: 2px;
    background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent), transparent);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  /* Logo + wordmark on one row (Nav's .brand styles are scoped, re-declare here). */
  .footer-about .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  /* Footer wordmark — brand gradient (the Nav's is scoped, so re-declare here). */
  .footer-about .brand-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.02em;
    background: var(--brand-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .footer-about p {
    font-size: 13px;
    color: var(--slate-600);
    line-height: 1.6;
    margin: 16px 0 0;
    max-width: 280px;
  }
  .footer-col h5 {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
    margin: 0 0 16px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    display: inline-block;
    font-size: 13px;
    color: var(--slate-600);
    transition: color .2s ease, transform .2s ease;
  }
  .footer-col a:hover {
    color: var(--brand-primary);
    transform: translateX(3px);
  }
  .footer-bar {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-bar .copy {
    font-size: 12px;
    color: var(--slate-400);
  }
  .footer-end {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  /* ---- Language switch (base) ---- */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-paper);
  }
  .lang-opt {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--slate-500);
    padding: 5px 11px;
    border: 0;
    background: transparent;
    border-radius: 999px;
    cursor: pointer;
    line-height: 1;
    text-decoration: none;
    transition: color .2s ease, background .2s ease;
  }
  .lang-opt:hover { color: var(--brand-primary); }
  /* Active state — mirrors legacy aria-pressed="true" styling */
  .lang-opt.is-active,
  .lang-opt[aria-current="page"] {
    background: var(--brand-primary);
    color: var(--white);
  }

  /* ---- Language switch — footer context (slightly smaller) ---- */
  .footer-end .lang-switch { padding: 2px; }
  .footer-end .lang-opt { padding: 5px 10px; }

  /* ---- Social icons ---- */
  .social-row {
    display: flex;
    gap: 8px;
  }
  .social-row a {
    width: 34px; height: 34px;
    border-radius: var(--radius-md);
    background: var(--bg-paper);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--slate-500);
    transition: color .2s, border-color .2s, background .2s, transform .2s;
  }
  .social-row a:hover {
    color: var(--white);
    background: var(--brand-primary);
    border-color: var(--brand-primary);
    transform: translateY(-2px);
  }
  .social-row svg { width: 16px; height: 16px; }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 32px; }
    .footer-grid .footer-col:last-child {
      grid-column: 2 / span 3;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
    .footer-grid .footer-col:last-child h5 { grid-column: 1 / -1; }
  }
  @media (max-width: 960px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-grid .footer-col:last-child {
      grid-column: auto;
      display: flex;
      flex-direction: column;
    }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>

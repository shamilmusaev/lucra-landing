<script>
  import Lenis from '@studio-freight/lenis';

  // Skip smooth-scroll entirely for reduced-motion users — native scroll, no rAF.
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const lenis = new Lenis({
      duration: 0.9,   // snappier inertia (was 1.2 — long tail read as "not fast")
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });

    let rafId = 0;
    function raf(time: number) {
      lenis.raf(time);
      rafId = requestAnimationFrame(raf);
    }
    rafId = requestAnimationFrame(raf);

    // Stop the rAF loop while the tab is backgrounded; resume on return.
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
      } else if (!rafId) {
        rafId = requestAnimationFrame(raf);
      }
    });

    (window as any).lenis = lenis;
  }
</script>

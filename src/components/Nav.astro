---
import { getStrings, type Lang } from '../i18n/utils';
import { APP_LOGIN_URL, CONTACT_MAILTO } from '../config';
import Icon from './Icon.astro';
const { lang } = Astro.props as { lang: Lang };
const s = getStrings(lang);
// Section anchors must resolve from any route (incl. /privacy, /terms, 404),
// so prefix with the active language home: sv → /#id, en → /en/#id.
const enPrefix = lang === 'en' ? '/en' : '';
---

<nav class="nav" id="nav">
  <div class="container nav-inner">
    <a href={`${enPrefix}/`} class="brand" aria-label="Lucra">
      <img src="/assets/logo.svg" alt="Lucra" width="38" height="36" />
      <span class="brand-word">Lucra</span>
    </a>
    <div class="nav-center">
    <div class="nav-links">
      <span class="nav-pill" aria-hidden="true"></span>

      <!-- PRODUKT — mega-menu (real section anchors) -->
      <div class="nav-item has-mega" data-menu="produkt">
        <button class="nav-link nav-trigger" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="mega-produkt">
          {s.navProduct}
          <svg class="nav-caret" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg>
        </button>
        <div class="nav-dropdown nav-mega" id="mega-produkt" role="region" aria-label={s.navProduct}>
          <div class="mega-inner">
            <div class="mega-col">
              <span class="mega-label">{s.navProductFeaturesLabel}</span>
              <a class="mega-row" href={`${enPrefix}/#funktioner`}>
                <span class="mega-row-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg></span>
                <span class="mega-row-tx">
                  <span class="mega-row-t">{s.navProductFeaturesTitle}</span>
                  <span class="mega-row-d">{s.navProductFeaturesDesc}</span>
                </span>
              </a>
              <a class="mega-row" href={`${enPrefix}/#jamforelse`}>
                <span class="mega-row-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 3v18"/></svg></span>
                <span class="mega-row-tx">
                  <span class="mega-row-t">{s.navProductCompareTitle}</span>
                  <span class="mega-row-d">{s.navProductCompareDesc}</span>
                </span>
              </a>
              <a class="mega-row" href={`${enPrefix}/#sakerhet`}>
                <span class="mega-row-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg></span>
                <span class="mega-row-tx">
                  <span class="mega-row-t">{s.navProductSecurityTitle}</span>
                  <span class="mega-row-d">{s.navProductSecurityDesc}</span>
                </span>
              </a>
              <a class="mega-row" href={`${enPrefix}/#upplagg`}>
                <span class="mega-row-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg></span>
                <span class="mega-row-tx">
                  <span class="mega-row-t">{s.navProductPricingTitle}</span>
                  <span class="mega-row-d">{s.navProductPricingDesc}</span>
                </span>
              </a>
            </div>
            <a class="mega-promo" href={`${enPrefix}/#for-vem`}>
              <span class="mega-promo-badge" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg></span>
              <span class="mega-promo-eyebrow">{s.navPromoEyebrow}</span>
              <span class="mega-promo-title">{s.navPromoTitle}</span>
              <span class="mega-promo-desc">{s.navPromoDesc}</span>
              <span class="mega-promo-link">{s.navPromoLink}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <!-- LÖSNINGAR — audiences (real För vem anchors) -->
      <div class="nav-item has-menu" data-menu="losningar">
        <button class="nav-link nav-trigger" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="menu-losningar">
          {s.navSolutions}
          <svg class="nav-caret" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg>
        </button>
        <div class="nav-dropdown" id="menu-losningar" role="region" aria-label={s.navSolutions}>
          <div class="menu-inner">
            <a class="mega-row" href={`${enPrefix}/#for-foretagare`}>
              <span class="mega-row-ic"><Icon name="briefcase" /></span>
              <span class="mega-row-tx">
                <span class="mega-row-t">{s.navSolutionsCompanyTitle}</span>
                <span class="mega-row-d">{s.navSolutionsCompanyDesc}</span>
              </span>
            </a>
            <a class="mega-row" href={`${enPrefix}/#for-byra`}>
              <span class="mega-row-ic"><Icon name="building-2" /></span>
              <span class="mega-row-tx">
                <span class="mega-row-t">{s.navSolutionsAgencyTitle}</span>
                <span class="mega-row-d">{s.navSolutionsAgencyDesc}</span>
              </span>
            </a>
          </div>
        </div>
      </div>

      <!-- PRISER — plans (real Upplägg anchors) -->
      <div class="nav-item has-menu" data-menu="priser">
        <button class="nav-link nav-trigger" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="menu-priser">
          {s.navPricing}
          <svg class="nav-caret" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg>
        </button>
        <div class="nav-dropdown" id="menu-priser" role="region" aria-label={s.navPricing}>
          <div class="menu-inner">
            <a class="mega-row" href={`${enPrefix}/#pilot`}>
              <span class="mega-row-ic"><Icon name="rocket" /></span>
              <span class="mega-row-tx">
                <span class="mega-row-t">{s.navPricingPilotTitle}</span>
                <span class="mega-row-d">{s.navPricingPilotDesc}</span>
              </span>
            </a>
            <a class="mega-row" href={`${enPrefix}/#partner`}>
              <span class="mega-row-ic"><Icon name="handshake" /></span>
              <span class="mega-row-tx">
                <span class="mega-row-t">{s.navPricingPartnerTitle}</span>
                <span class="mega-row-d">{s.navPricingPartnerDesc}</span>
              </span>
            </a>
          </div>
        </div>
      </div>

    </div>
    </div>
    <div class="nav-right">
      <a class="btn btn-ghost" href={APP_LOGIN_URL}>{s.navLogin}</a>
      <a class="btn btn-primary" href={CONTACT_MAILTO}>
        {s.navBookDemo}
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</nav>

<style>
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 10px 16px 0;
  pointer-events: none;
}
.nav-inner {
  pointer-events: auto;
  position: relative;
  width: 100%;
  /* Brand + actions sit in the side columns; the wider this cap, the further
     they spread from the centered links — so it scales with the viewport and
     keeps pushing toward the edges on larger screens. */
  max-width: clamp(1200px, 94vw, 1800px);
  margin: 0 auto;
  padding: 14px 28px;
  height: 64px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  border-radius: 20px;
  border: 1px solid transparent;
  background: transparent;
  transition: max-width .35s ease, background .35s ease, border-color .35s ease,
              backdrop-filter .35s ease, box-shadow .35s ease, padding .35s ease;
}
.nav.scrolled .nav-inner {
  max-width: 880px;
  background: rgba(255,255,255,0.72);
  border-color: var(--border);
  backdrop-filter: blur(18px) saturate(180%);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
  box-shadow: 0 6px 24px -10px rgba(15,23,42,0.18);
  padding: 10px 20px;
}
.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  grid-column: 1;
  justify-self: start;
  /* Optical lift: the 26px wordmark + upward triangle share the nav's centre-line with
     14px links, so their baseline reads low. A 2px lift aligns them to the eye. */
  transform: translateY(-2px);
}
.brand-word {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 28px;
  letter-spacing: -0.02em;
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.nav-center {
  grid-column: 2;
  display: flex;
  align-items: center;
  gap: 56px;
}
.nav-links {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4px;
}
.nav-link {
  position: relative;
  z-index: 1;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--slate-600);
  font-weight: 500;
  padding: 8px 16px;
  border-radius: var(--radius-pill);
  white-space: nowrap;
  transition: color .2s ease;
  cursor: pointer;
}
.nav-pill {
  position: absolute;
  top: 50%;
  left: 0;
  width: 0;
  height: 36px;
  background: var(--bg-active);
  border-radius: var(--radius-pill);
  z-index: 0;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-50%);
  transition:
    opacity .22s ease,
    left .38s cubic-bezier(.4, 0, .2, 1),
    width .38s cubic-bezier(.4, 0, .2, 1);
}
.nav-links.has-pill .nav-pill { opacity: 1; }
.nav .btn {
  font-family: var(--font-body);
  font-weight: 500;
}
.nav-right .btn-ghost {
  transition: opacity .25s ease, transform .25s ease, margin .25s ease;
}
.nav.scrolled .nav-right .btn-ghost {
  opacity: 0;
  transform: translateX(8px);
  margin-right: -64px;
  pointer-events: none;
}
.nav-link:hover { color: var(--brand-primary); }
.nav-right { display: flex; align-items: center; gap: 12px; grid-column: 3; justify-self: end; }

/* ---------- Mega-menu dropdowns ---------- */
.nav-item { position: relative; display: flex; align-items: center; }
.nav-trigger {
  background: none; border: 0; cursor: pointer;
  display: inline-flex; align-items: center; gap: 5px;
}
.nav-caret {
  width: 13px; height: 13px;
  stroke: currentColor; stroke-width: 1.7; fill: none;
  stroke-linecap: round; stroke-linejoin: round;
  opacity: .5; transition: transform .22s ease, opacity .2s ease;
}
.nav-item.is-open .nav-caret { transform: rotate(180deg); opacity: .8; }
.nav-item.is-open .nav-link { color: var(--brand-primary); }

/* Panel shell — anchored under its trigger. Animated transform lives ONLY here
   (a leaf, never an ancestor of .nav-inner) so the nav glassmorphism stays intact. */
.nav-dropdown {
  position: absolute;
  top: calc(100% + 14px);
  left: 50%;
  z-index: 60;
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translate(-50%, -6px);
  transition: opacity .2s ease, transform .22s cubic-bezier(.4,0,.2,1), visibility 0s linear .22s;
}
.nav-item.is-open .nav-dropdown {
  opacity: 1; visibility: visible; pointer-events: auto;
  transform: translate(-50%, 0);
  transition: opacity .2s ease, transform .22s cubic-bezier(.4,0,.2,1), visibility 0s;
}
/* Invisible hover bridge across the 14px gap so the pointer never hits dead air. */
.nav-dropdown::before { content: ""; position: absolute; left: 0; right: 0; top: -16px; height: 16px; }

.mega-inner {
  background: rgba(255,255,255,0.94);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
          backdrop-filter: blur(18px) saturate(180%);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-pop);
  padding: 12px;
}
.nav-mega .mega-inner {
  display: grid;
  grid-template-columns: minmax(300px, 1fr) 186px;
  gap: 12px;
  width: 552px;
  max-width: calc(100vw - 32px);
}
/* Simple single-column dropdown (Lösningar, Priser) — same shell as the mega
   panel, reusing .mega-row for the items. */
.menu-inner {
  background: rgba(255,255,255,0.94);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
          backdrop-filter: blur(18px) saturate(180%);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-pop);
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 1px;
  width: 312px;
  max-width: calc(100vw - 32px);
}
.mega-col { display: flex; flex-direction: column; gap: 1px; }

.mega-row {
  display: flex; align-items: center; gap: 11px;
  padding: 9px 10px;
  border-radius: var(--radius-lg);
  transition: background .15s ease;
}
.mega-row:hover { background: var(--accent-light); }
.mega-row-ic {
  width: 34px; height: 34px; flex: none;
  border-radius: 10px;
  background: linear-gradient(150deg, var(--white), var(--accent-light));
  border: 1px solid rgba(61,80,109,.10);
  box-shadow: 0 1px 2px rgba(15,23,42,.05), inset 0 1px 0 rgba(255,255,255,.7);
  color: var(--brand-primary);
  display: inline-flex; align-items: center; justify-content: center;
  transition: background .18s ease, border-color .18s ease, color .18s ease, transform .18s ease;
}
.mega-row-ic svg { width: 18px; height: 18px; }
.mega-row:hover .mega-row-ic {
  background: linear-gradient(150deg, var(--white), var(--accent-light));
  border-color: rgba(61,80,109,.16);
  transform: translateY(-1px);
}
.mega-row-tx { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.mega-row-t { font-family: var(--font-display); font-size: 13.5px; font-weight: 500; color: var(--brand-primary); }
.mega-row-d { font-size: 12px; color: var(--slate-500); line-height: 1.4; }
.mega-label {
  font-family: var(--font-display);
  font-size: 10.5px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .09em;
  color: var(--slate-400);
  padding: 2px 10px 6px;
}

.mega-promo {
  --mx: 78%; --my: 12%;
  position: relative;
  background:
    linear-gradient(150deg, #44587A 0%, var(--brand-primary) 45%, #2E3E57 100%);
  color: var(--white);
  border-radius: var(--radius-lg);
  padding: 16px;
  display: flex; flex-direction: column; gap: 5px;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.14), 0 12px 30px -16px rgba(15,23,42,.55);
}
.mega-promo::after {
  content: ""; position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(280px 220px at var(--mx) var(--my), rgba(167,216,244,.55), rgba(86,179,235,.16) 38%, transparent 72%);
  transition: background .08s linear;
}
/* faint specular edge that also tracks the cursor */
.mega-promo::before {
  content: ""; position: absolute; inset: 0; pointer-events: none; border-radius: inherit;
  background: radial-gradient(120px 120px at var(--mx) var(--my), rgba(255,255,255,.16), transparent 60%);
  mix-blend-mode: screen;
}
.mega-promo > * { position: relative; z-index: 1; }
.mega-promo-badge {
  width: 38px; height: 38px; border-radius: 11px;
  background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.20);
  display: inline-flex; align-items: center; justify-content: center;
  margin-bottom: 3px;
}
.mega-promo-badge svg { width: 19px; height: 19px; opacity: .95; }
.mega-promo-eyebrow { font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; opacity: .78; }
.mega-promo-title { font-family: var(--font-display); font-weight: 700; font-size: 15.5px; line-height: 1.25; }
.mega-promo-desc { font-size: 12px; line-height: 1.45; opacity: .76; }
.mega-promo-link { margin-top: auto; padding-top: 10px; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; }
.mega-promo-link svg { width: 15px; height: 15px; transition: transform .25s ease; }
.mega-promo:hover .mega-promo-link svg { transform: translateX(4px); }

@media (prefers-reduced-motion: reduce) {
  .nav-dropdown, .nav-caret, .mega-promo-link svg { transition: none; }
}

/* Nav fades in with the intro. */
:global(html.hero-intro) .nav { opacity: 0; transition: opacity .8s ease; }
:global(html.hero-intro.nav-in) .nav { opacity: 1; }

/* ---------- Responsive ---------- */
@media (max-width: 960px) {
  .nav-inner { display: flex; justify-content: space-between; }
  .nav-center { gap: 0; }
  .nav-links { display: none; }
}
/* Below ~480px the brand + both buttons don't fit: the login link collides
   with the wordmark and "Boka demo" spills past the pill. Login stays
   reachable via the footer (Konto). The tighter paddings + smaller wordmark
   keep the brand from being flex-shrunk (clipped) at 320px. */
@media (max-width: 480px) {
  .nav-right .btn-ghost { display: none; }
  .nav-inner { padding: 10px 16px; }
  .brand { flex-shrink: 0; }
  .brand-word { font-size: 24px; }
}
</style>

<script>
  (function() {
    // Sticky nav border on scroll
    var nav = document.getElementById('nav');
    if (!nav) return;
    var navEl = nav;
    var onScroll = function() {
      if (window.scrollY > 50) navEl.classList.add('scrolled');
      else navEl.classList.remove('scrolled');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

  (function() {
    // Magic-pill nav hover — pill slides smoothly between links.
    var navLinks = document.querySelector('.nav-links');
    if (!navLinks) return;
    var links = navLinks.querySelectorAll('.nav-link');
    var pill = navLinks.querySelector('.nav-pill') as HTMLElement | null;
    if (!pill || !links.length) return;
    var pillEl = pill;
    var linksEl = navLinks as HTMLElement;
    var movePillTo = function(link: Element) {
      var lr = link.getBoundingClientRect();
      var pr = linksEl.getBoundingClientRect();
      pillEl.style.width = lr.width + 'px';
      pillEl.style.left  = (lr.left - pr.left) + 'px';
      linksEl.classList.add('has-pill');
    };
    links.forEach(function(link) {
      link.addEventListener('mouseenter', function() { movePillTo(link); });
      link.addEventListener('focus',      function() { movePillTo(link); });
    });
    linksEl.addEventListener('mouseleave', function() {
      linksEl.classList.remove('has-pill');
    });
  })();

  (function() {
    // Mega-menu dropdowns — hover-intent open/close, keyboard a11y, and coordination
    // with the scroll handlers. Triggers keep class .nav-link so the magic-pill still
    // highlights the open item. We never touch transform/filter on nav ancestors.
    var nav = document.getElementById('nav');
    var items = document.querySelectorAll('.nav-item.has-menu, .nav-item.has-mega');
    if (!nav || !items.length) return;
    var navEl = nav;
    var navInner = nav.querySelector('.nav-inner') as HTMLElement | null;
    var OPEN_DELAY = 90, CLOSE_DELAY = 240;
    var openTimer: ReturnType<typeof setTimeout> | undefined;
    var closeTimer: ReturnType<typeof setTimeout> | undefined;
    var current: Element | null = null;

    function navBlocked() {
      // Disabled while the hero-zoom slid the nav up / set pointer-events:none.
      return (parseFloat(navEl.style.top) || 0) < -40 ||
             (!!navInner && navInner.style.pointerEvents === 'none');
    }
    function clampPanel(item: Element) {
      var panel = item.querySelector('.nav-dropdown') as HTMLElement | null;
      var card = panel && panel.querySelector('.mega-inner, .menu-inner');
      if (!panel || !card) return;
      panel.style.transform = '';            // reset to the CSS default before measuring
      var r = card.getBoundingClientRect();
      var pad = 16, vw = window.innerWidth;
      if (r.right > vw - pad)      panel.style.transform = 'translate(calc(-50% - ' + (r.right - vw + pad) + 'px), 0)';
      else if (r.left < pad)       panel.style.transform = 'translate(calc(-50% + ' + (pad - r.left) + 'px), 0)';
    }
    function open(item: Element) {
      if (navBlocked()) return;
      if (current && current !== item) close(current);
      clearTimeout(closeTimer);
      item.classList.add('is-open');
      var t = item.querySelector('.nav-trigger');
      if (t) t.setAttribute('aria-expanded', 'true');
      current = item;
      clampPanel(item);
    }
    function close(item: Element | null) {
      if (!item) return;
      item.classList.remove('is-open');
      var t = item.querySelector('.nav-trigger');
      if (t) t.setAttribute('aria-expanded', 'false');
      if (current === item) current = null;
    }

    // Track input modality so keyboard focus opens the panel (making its links
    // reachable by Tab) without a mouse/touch press opening-then-closing it via
    // the click toggle below.
    var usingKeyboard = false;
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Tab') usingKeyboard = true;
    }, true);
    document.addEventListener('mousedown', function() { usingKeyboard = false; }, true);

    items.forEach(function(item) {
      var trig = item.querySelector('.nav-trigger') as HTMLElement | null;
      item.addEventListener('mouseenter', function() {
        clearTimeout(closeTimer);
        clearTimeout(openTimer);
        openTimer = setTimeout(function() { open(item); }, OPEN_DELAY);
      });
      item.addEventListener('mouseleave', function() {
        clearTimeout(openTimer);
        clearTimeout(closeTimer);
        // Close whatever panel is actually open, not this item: grazing a sibling
        // must not leave the previously-open panel stuck (shared-timer race).
        closeTimer = setTimeout(function() { if (current) close(current); }, CLOSE_DELAY);
      });
      // Keyboard: focusing into the item reveals the panel; leaving it closes.
      item.addEventListener('focusin', function() {
        if (!usingKeyboard) return;
        clearTimeout(closeTimer);
        open(item);
      });
      item.addEventListener('focusout', function(e) {
        var next = (e as FocusEvent).relatedTarget as Node | null;
        if (next && item.contains(next)) return; // focus still inside — keep open
        close(item);
      });
      if (trig) {
        trig.addEventListener('click', function(e) {
          e.preventDefault();
          item.classList.contains('is-open') ? close(item) : open(item);
        });
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && current) {
        var t = current.querySelector('.nav-trigger') as HTMLElement | null;
        close(current);
        if (t) t.focus();
      }
    });
    // Scroll closes any open panel (also covers the hero-zoom slide).
    window.addEventListener('scroll', function() { if (current) close(current); }, { passive: true });
    // Click outside closes.
    document.addEventListener('click', function(e) {
      if (current && !current.contains(e.target as Node)) close(current);
    });
    window.addEventListener('resize', function() { if (current) clampPanel(current); });
  })();

  (function() {
    // Promo card glare — a soft highlight tracks the cursor across the "Lucra för byråer" card.
    var promo = document.querySelector('.mega-promo') as HTMLElement | null;
    if (!promo) return;
    var promoEl = promo;
    var raf: number | null = null;
    promoEl.addEventListener('mousemove', function(e: MouseEvent) {
      if (raf) return;
      raf = requestAnimationFrame(function() {
        raf = null;
        var r = promoEl.getBoundingClientRect();
        promoEl.style.setProperty('--mx', (((e.clientX - r.left) / r.width) * 100).toFixed(1) + '%');
        promoEl.style.setProperty('--my', (((e.clientY - r.top) / r.height) * 100).toFixed(1) + '%');
      });
    });
    promoEl.addEventListener('mouseleave', function() {
      promoEl.style.setProperty('--mx', '78%');
      promoEl.style.setProperty('--my', '12%');
    });
  })();
</script>

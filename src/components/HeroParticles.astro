---
// HeroParticles — the hero dot-field "fog wipe". The core (cursor-reactive
// wipe, glow, refog) lives in the shared `src/scripts/particleField.ts` module
// so it can be reused on other sections (see ParticleField.astro). This file
// adds the hero-only choreography: the canvas is injected into the existing
// `.hero-falling` container (Hero.astro carries the .hero-falling__canvas rule),
// the intro reveal bursts the dots out from the orb, and clicking the orb sweeps
// the field clean. The load-intro orchestrator (Hero.astro) calls the guarded
// `window.lucraFogIntro()` hook at the orb-pulse moment to play that intro.
---

<script>
  import { initParticleField } from '../scripts/particleField';

  function initHeroParticles(field: HTMLElement): void {
    const hero = document.querySelector<HTMLElement>('.hero');
    const orb = document.getElementById('hero-orb');
    if (!hero) return;

    const controller = initParticleField({
      canvasParent: field,
      surface: hero,
      canvasClass: 'hero-falling__canvas',
      startCleared: true,
    });
    if (!controller) return;

    // Orb centre in CSS px relative to the hero (the field's coordinate space).
    function orbCenter(): { x: number; y: number } {
      const hr = hero!.getBoundingClientRect();
      const or = orb ? orb.getBoundingClientRect() : null;
      return {
        x: or ? (or.left + or.width / 2) - hr.left : hr.width / 2,
        y: or ? (or.top + or.height / 2) - hr.top : hr.height * 0.18,
      };
    }

    // Orb click — ripple the orb's WebGL shader (no field sweep).
    if (orb) {
      orb.style.pointerEvents = 'auto';
      orb.style.cursor = 'pointer';
      orb.addEventListener('click', function () {
        const orbPulse = (window as any).lucraOrbPulse;
        if (orbPulse) orbPulse();
      });
    }

    // Exposed for the load-intro orchestrator: burst the dots in from the orb at
    // the pulse moment. Runs once; a watchdog shows the dots even if never called.
    let fogIntroPlayed = false;
    const fogIntro = function (): void {
      if (fogIntroPlayed) return;
      fogIntroPlayed = true;
      controller.reveal(orbCenter);
    };
    (window as any).lucraFogIntro = fogIntro;
    setTimeout(function () { fogIntro(); }, 2500);
  }

  // ── Lazy init ─────────────────────────────────────────────────────────────
  // The fog field lives at the top of the page, so the IntersectionObserver
  // (with a 200px rootMargin) fires essentially immediately on load. Defining
  // `window.lucraFogIntro` happens inside initHeroParticles, so Hero's guarded
  // `if (window.lucraFogIntro)` call simply no-ops for the brief moment before
  // the field inits — acceptable and matches legacy sequencing. The internal
  // 2500ms watchdog reveals the dots even if the orchestrator never fires.
  const el = document.querySelector<HTMLElement>('.hero-falling');
  if (el && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ric: (cb: () => void) => void =
      (window as any).requestIdleCallback
        ? (cb) => (window as any).requestIdleCallback(cb)
        : (cb) => { setTimeout(cb, 1); };
    const start = (): void => ric(() => initHeroParticles(el));
    const io = new IntersectionObserver((entries, obs) => {
      if (entries.some((entry) => entry.isIntersecting)) {
        obs.disconnect();
        start();
      }
    }, { rootMargin: '200px' });
    io.observe(el);
  }
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Funktioner from '../components/sections/Funktioner.astro';
import ForVem from '../components/sections/ForVem.astro';
import Sakerhet from '../components/sections/Sakerhet.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import Footer from '../components/Footer.astro';
import RevealScript from '../components/RevealScript.astro';
import { getStrings } from '../i18n/utils';
const lang = 'sv' as const;
const s = getStrings(lang);
---
<BaseLayout lang={lang} title={s.metaTitle} description={s.metaDescription} path="/">
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Problem lang={lang} />
  <Funktioner lang={lang} />
  <ForVem lang={lang} />
  <Sakerhet lang={lang} />
  <CtaSection lang={lang} />
  <Footer lang={lang} />
  <RevealScript />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import LegalArticle from '../../components/LegalArticle.astro';
import Footer from '../../components/Footer.astro';
import { Content } from '../../legal/privacy.en.md';
import { getStrings } from '../../i18n/utils';

const lang = 'en' as const;
const s = getStrings(lang);
---
<BaseLayout lang={lang} title={s.privacyMetaTitle} description={s.privacyMetaDescription} path="/privacy">
  <Nav lang={lang} />
  <main id="main">
    <LegalArticle>
      <Content />
    </LegalArticle>
  </main>
  <Footer lang={lang} />
</BaseLayout>

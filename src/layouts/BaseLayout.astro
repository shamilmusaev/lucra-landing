---
import '../styles/colors_and_type.css';
import '../styles/global.css';
import SmoothScroll from '../components/SmoothScroll.astro';
import ScrollFx from '../components/ScrollFx.astro';
import CalendlyPopup from '../components/CalendlyPopup.astro';
import { getStrings } from '../i18n/utils';

export interface Props {
  lang: 'sv' | 'en';
  title: string;
  description: string;
  /** Path of the current page without language prefix, e.g. "/" */
  path?: string;
  /** Excludes the page from indexing and drops canonical/hreflang (404). */
  noindex?: boolean;
}

const { lang, title, description, path = '/', noindex = false } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
// trailingSlash: 'always' — keep canonical/hreflang in the slashed form so they
// match the emitted dir/index.html and the sitemap.
const normalizedPath = path === '/' ? '/' : `${path.replace(/\/$/, '')}/`;
const svUrl = `${site}${normalizedPath}`;
const enUrl = `${site}/en${normalizedPath}`;
const canonical = lang === 'sv' ? svUrl : enUrl;
const s = getStrings(lang);
// Per-language social card; everything else (title/description) reuses the props.
const ogImage = `${site}/${lang === 'en' ? 'og-image-en.png' : 'og-image.png'}`;
const ogLocale = lang === 'en' ? 'en_US' : 'sv_SE';
const ogLocaleAlt = lang === 'en' ? 'sv_SE' : 'en_US';
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: 'Lucra', url: site, logo: `${site}/assets/logo.svg` },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Lucra', url: site, inLanguage: lang === 'en' ? 'en-US' : 'sv-SE' },
];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#F1F5F9" />
    {noindex ? (
      <meta name="robots" content="noindex, follow" />
    ) : (
      <Fragment>
        <link rel="canonical" href={canonical} />
        <link rel="alternate" hreflang="sv" href={svUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={svUrl} />
      </Fragment>
    )}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Lucra" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={s.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image:alt" content={s.ogImageAlt} />
    <!-- Only the above-the-fold General Sans weights are preloaded. Inter /
         Plus Jakarta Sans are product-demo-only (below the fold) and load on
         demand, so they don't compete in the LCP window. -->
    <link rel="preload" href="/fonts/GeneralSans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeneralSans-500.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{s.skipToContent}</a>
    <SmoothScroll />
    <ScrollFx />
    <slot />
    <!-- Global Calendly popup loader — any [data-calendly] trigger (every "Boka
         demo" button) opens the in-page scheduling popup, on all pages. -->
    <CalendlyPopup />
    <script>
      // The product demo's interactive controllers and the hero orb gate on
      // viewport width ONCE at load and don't tear down — a desktop window
      // dragged across a breakpoint keeps the interactive demo running over the
      // static layout (it can't switch to static without a reload). Reload when
      // the width crosses a major JS breakpoint (720 = orb, 1200 = demo
      // interactive/static) so the page re-initialises in the right mode. Only on
      // pages that have the demo; debounced so it fires once dragging stops.
      if (document.querySelector('.hero-chrome-wrap')) {
        const bucket = (w: number): number => (w >= 1200 ? 2 : w >= 720 ? 1 : 0);
        let current = bucket(window.innerWidth);
        let timer = 0;
        window.addEventListener('resize', () => {
          window.clearTimeout(timer);
          timer = window.setTimeout(() => {
            const next = bucket(window.innerWidth);
            if (next !== current) { current = next; location.reload(); }
          }, 250);
        });
      }
    </script>
  </body>
</html>
